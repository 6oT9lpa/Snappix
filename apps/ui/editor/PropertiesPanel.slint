                    fill: pick-touch.has-hover ? Themes.current.primary-text : Themes.current.secondary-text;
                }
            }
        }
    }
}

component ColorSwatch inherits Rectangle {
    in property <string> hex: "#ffffff";
    in property <color> swatch-color: #ffffff;
    in property <bool> is-selected: false;
    callback picked(string);

    width: 26px;
    height: 26px;
    border-radius: 4px;
    border-width: is-selected ? 2px : 1px;
    border-color: is-selected ? Themes.current.active-color : Themes.current.border-color;
    background: swatch-color;

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: MouseCursor.pointer;
        clicked => { root.picked(root.hex); }
    }
}

component ColorPickerHandle inherits Rectangle {
    in property <length> size: 18px;
    in property <color> accent-color: #707070;

    width: root.size;
    height: root.size;
    border-radius: self.width / 2;
    border-width: 2px;
    border-color: Colors.white;
    background: transparent;
    drop-shadow-color: Themes.shadow-color;
    drop-shadow-blur: 8px;

    Rectangle {
        x: 4px;
        y: 4px;
        width: parent.width - 8px;
        height: parent.height - 8px;
        border-radius: self.width / 2;
        border-width: 2px;
        border-color: Themes.current.primary-bg;
        background: root.accent-color;
    }
}

component MultilineStringField inherits Rectangle {
    in property <string> label: "";
    in-out property <string> value: "";
    in property <length> input-height: 88px;
    callback value-changed(string);

    height: input-height + 5px;
    horizontal-stretch: 1;
    background: transparent;

    VerticalBox {
        padding: 0;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;

        TextEdit {
            height: root.input-height;
            text <=> root.value;
            wrap: word-wrap;
            font-size: 12px;
            edited => { root.value-changed(root.value); }
        }
    }
}

component ChoiceField inherits Rectangle {
    in property <string> label: "";
    in property <[string]> options: [];
    in-out property <string> value: "";
    callback value-changed(string);

    height: 28px;
    horizontal-stretch: 1;
    background: Themes.current.primary-bg;
    border-radius: 4px;
    border-width: 1px;
    border-color: Themes.current.border-color;

    HorizontalBox {
        padding: 0;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;

        Rectangle {
            width: 106px;
            height: parent.height;
            background: transparent;

            Text {
                height: 20px;
                horizontal-alignment: TextHorizontalAlignment.left;
                text: root.label == "" ? I18n.t("Value") : root.label;
                font-size: 12px;
                color: Themes.current.secondary-text;
                font-weight: 600;
                vertical-alignment: TextVerticalAlignment.center;
                width: parent.width;
                overflow: elide;
            }
        }

        VerticalBox {
            padding: 4px;
            
            Rectangle {
                horizontal-stretch: 1;
                height: 20px;
                background: transparent;

                ComboBox {
                    width: parent.width;
                    height: parent.height;
                    model: root.options;
                    current-value <=> root.value;
                    selected(value) => { root.value-changed(value); }
                }
            }
        }
    }
}

component ToggleField inherits Rectangle {
    in property <string> label: "";
    in property <bool> checked: false;
    callback toggled(bool);

    height: 28px;
    horizontal-stretch: 1;
    background: Themes.current.primary-bg;
    border-radius: 4px;
    border-width: 1px;
    border-color: Themes.current.border-color;

    HorizontalBox {
        padding: 0;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;

        Text {
            text: root.label == "" ? I18n.t("Value") : root.label;
            font-size: 12px;
            color: Themes.current.secondary-text;
            vertical-alignment: TextVerticalAlignment.center;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }

        VerticalBox {
            padding: 4px;
            Rectangle {
                width: 58px;
                height: 20px;
                border-radius: 4px;
                border-width: 1px;
                border-color: root.checked ? Themes.current.active-color : Themes.current.border-color;
                background: root.checked ? Themes.current.active-color : Themes.current.secondary-bg;

                toggle-touch := TouchArea {
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { root.toggled(!root.checked); }
                }

                Text {
                    text: root.checked ? "true" : "false";
                    color: root.checked ? Themes.on-accent-text : Themes.current.primary-text;
                    font-size: 10px;
                    horizontal-alignment: TextHorizontalAlignment.center;
                    vertical-alignment: TextVerticalAlignment.center;
                }
            }
        }
    }
}

export component PropertiesPanel inherits Rectangle {
    in property <string> selected-element-id: "";
    in property <string> selected-element-type: "";
    in property <CanvasBounds> element-bounds: { position: { x: 0px, y: 0px }, size: { width: 100px, height: 100px } };
    in property <float> element-rotation: 0;
    in property <string> element-text: "";
    in property <bool> element-checked: false;
    in property <string> element-container-mode: "absolute";
    in property <bool> element-allow-absolute-children: false;
    in property <float> element-layout-padding: 8;
    in property <float> element-layout-spacing: 8;
    in property <float> element-layout-margin: 0;
    in property <float> element-layout-order: 0;
    in property <string> element-stack-alignment: "stretch";
    in property <string> element-flex-direction: "column";
    in property <string> element-flex-wrap: "nowrap";
    in property <string> element-justify-items: "stretch";
    in property <string> element-justify-content: "flex-start";
    in property <string> element-align-items: "stretch";
    in property <string> element-align-content: "stretch";
    in property <string> element-place-items: "stretch stretch";
    in property <string> element-flex-flow: "column nowrap";
    in property <string> element-grid-template-columns: "1fr 1fr";
    in property <string> element-grid-template-rows: "auto auto";
    in property <string> element-grid-template-areas: "";
    in property <string> element-checkbox-box-side: "left";
    in property <string> element-checkbox-check-color: "#f5f5f5";
    in property <string> element-checkbox-box-color: "#151515";
    in property <string> element-checkbox-box-border-color: "#4a4a4a";
    in property <float> element-checkbox-box-border-width: 1;
    in property <bool> element-checkbox-space-between: false;
    in property <string> element-background: "#ffffff";
    in property <string> element-border-color: "#4a4a4a";
    in property <float> element-border-width: 0;
    in property <float> element-border-radius: 4;
    in property <float> element-font-size: 14;
    in property <string> element-font-family: "Sans";
    in property <string> element-text-wrap: "wrap";
    in property <string> element-text-color: "#f5f5f5";
    in property <string> element-placeholder: "";
    in property <string> element-background-image: "";
    in property <string> element-image-source: "";
    in property <string> element-image-source-display: "";
    in property <bool> element-inherit-text-style: true;

    callback bounds-changed(CanvasBounds, float);
    callback text-changed(string);
    callback style-changed(string, string, float, float, float, string, string, string, string, string, string, bool, bool, string, string, string, string, float, bool);
    callback container-settings-changed(string, bool, float, float, float, float, string, string, string, string, string, string, string, string, string, string, string, string);
    callback browse-image-source-requested();

    property <CanvasBounds> editing-bounds: element-bounds;
    property <float> editing-rotation: element-rotation;
    property <string> editing-text: element-text;
    property <bool> editing-checked: element-checked;
    property <string> editing-container-mode: element-container-mode;
    property <bool> editing-allow-absolute-children: element-allow-absolute-children;
    property <float> editing-layout-padding: element-layout-padding;
    property <float> editing-layout-spacing: element-layout-spacing;
    property <float> editing-layout-margin: element-layout-margin;
    property <float> editing-layout-order: element-layout-order;
    property <string> editing-stack-alignment: element-stack-alignment;
    property <string> editing-flex-direction: element-flex-direction;
    property <string> editing-flex-wrap: element-flex-wrap;
    property <string> editing-justify-items: element-justify-items;
    property <string> editing-justify-content: element-justify-content;
    property <string> editing-align-items: element-align-items;
    property <string> editing-align-content: element-align-content;
    property <string> editing-place-items: element-place-items;
    property <string> editing-flex-flow: element-flex-flow;
    property <string> editing-grid-template-columns: element-grid-template-columns;
    property <string> editing-grid-template-rows: element-grid-template-rows;
    property <string> editing-grid-template-areas: element-grid-template-areas;
    property <string> editing-checkbox-box-side: element-checkbox-box-side;
    property <string> editing-checkbox-check-color: element-checkbox-check-color;
    property <string> editing-checkbox-box-color: element-checkbox-box-color;
    property <string> editing-checkbox-box-border-color: element-checkbox-box-border-color;
    property <float> editing-checkbox-box-border-width: element-checkbox-box-border-width;
    property <bool> editing-checkbox-space-between: element-checkbox-space-between;
    property <string> editing-background: element-background;
    property <string> editing-border-color: element-border-color;
    property <float> editing-border-width: element-border-width;
    property <float> editing-border-radius: element-border-radius;
    property <float> editing-font-size: element-font-size;
    property <string> editing-font-family: element-font-family;
    property <string> editing-text-wrap: element-text-wrap;
    property <string> editing-text-color: element-text-color;
    property <string> editing-placeholder: element-placeholder;
    property <string> editing-background-image: element-background-image;
    property <string> editing-image-source: element-image-source;
    property <bool> editing-inherit-text-style: element-inherit-text-style;
    property <bool> is-container:
        selected-element-type == "div"
        || selected-element-type == "flex"
        || selected-element-type == "flex-container"
        || selected-element-type == "grid"
        || selected-element-type == "grid-container"
        || selected-element-type == "stack"
        || selected-element-type == "stack-container";
    property <bool> supports-container-settings: root.is-container;
    property <string> effective-container-mode:
        selected-element-type == "div" ? editing-container-mode
        : selected-element-type == "flex" ? "flex"
        : selected-element-type == "flex-container" ? "flex"
        : selected-element-type == "grid" ? "grid"
        : selected-element-type == "grid-container" ? "grid"
        : selected-element-type == "stack" ? "stack"
        : selected-element-type == "stack-container" ? "stack"
        : "absolute";
    property <bool> supports-stack-layout: root.supports-container-settings && root.effective-container-mode == "stack";
    property <bool> supports-flex-layout: root.supports-container-settings && root.effective-container-mode == "flex";
    property <bool> supports-grid-layout: root.supports-container-settings && root.effective-container-mode == "grid";
    property <bool> supports-container-layout-controls:
        root.supports-container-settings && root.effective-container-mode != "absolute";
    property <bool> supports-text-content:
        selected-element-type == "div"
        || selected-element-type == "text"
        || selected-element-type == "label"
        || selected-element-type == "button"
        || selected-element-type == "input"
        || selected-element-type == "textarea"
        || selected-element-type == "checkbox";
    property <bool> supports-text-style:
        root.is-container || root.supports-text-content;
    property <bool> supports-placeholder:
        selected-element-type == "input" || selected-element-type == "textarea";
    property <bool> supports-checked: selected-element-type == "checkbox";
    property <bool> supports-checkbox-style: selected-element-type == "checkbox";
    property <bool> supports-image-source: selected-element-type == "image";
    property <bool> supports-background-image: root.is-container;
    property <bool> color-picker-open: false;
    property <string> color-picker-target: "";
    property <string> color-picker-label: "";
    property <string> color-picker-value: "#ffffff";
    property <color> color-picker-selected-color: #ffffff;
    property <bool> color-picker-selection-known: false;
    property <bool> color-picker-preview-visible: false;
    property <string> color-picker-preview-value: "#ffffff";
    property <color> color-picker-preview-color: #ffffff;
    property <length> color-picker-preview-x: 0px;
    property <length> color-picker-preview-y: 0px;
    property <string> recent-color-1-hex: "";
    property <color> recent-color-1-color: #ffffff;
    property <string> recent-color-2-hex: "";
    property <color> recent-color-2-color: #ffffff;
    property <string> recent-color-3-hex: "";
    property <color> recent-color-3-color: #ffffff;
    property <string> recent-color-4-hex: "";
    property <color> recent-color-4-color: #ffffff;
    property <string> recent-color-5-hex: "";
    property <color> recent-color-5-color: #ffffff;
    property <string> recent-color-6-hex: "";
    property <color> recent-color-6-color: #ffffff;
    property <string> recent-color-7-hex: "";
    property <color> recent-color-7-color: #ffffff;
    property <string> recent-color-8-hex: "";
    property <color> recent-color-8-color: #ffffff;
    property <bool> no-recent-colors:
        root.recent-color-1-hex == ""
        && root.recent-color-2-hex == ""
        && root.recent-color-3-hex == ""
        && root.recent-color-4-hex == ""
        && root.recent-color-5-hex == ""
        && root.recent-color-6-hex == ""
        && root.recent-color-7-hex == ""
        && root.recent-color-8-hex == "";
    property <int> color-disc-grid-size: 29;
    property <int> color-ring-segment-count: 84;
    property <float> color-picker-base-hue: 0.0;
    property <float> color-picker-base-saturation: 1.0;
    property <float> color-picker-ring-phase: 0.75;
    property <color> color-picker-base-color:
        Colors.hsv(root.color-picker-base-hue, root.color-picker-base-saturation, 1.0);

    function clamp01(value: float) -> float {
        Math.max(0, Math.min(1, value))
    }

    function normalize-angle(value: float) -> float {
        let wrapped = value - Math.floor(value / 360) * 360;
        wrapped < 0 ? wrapped + 360 : wrapped
    }

    function normalize-phase(value: float) -> float {
        let wrapped = value - Math.floor(value);
        wrapped < 0 ? wrapped + 1 : wrapped
    }

    function wheel-hue(dx: float, dy: float) -> float {
        root.normalize-angle(Math.atan2(dy, dx) / 1deg + 90)
    }

    function wheel-saturation(dx: float, dy: float) -> float {
        root.clamp01(Math.sqrt(dx * dx + dy * dy))
    }

    function wheel-color(dx: float, dy: float) -> color {
        Colors.hsv(root.wheel-hue(dx, dy), root.wheel-saturation(dx, dy), 1.0)
    }

    function shade-color(base: color, phase: float) -> color {
        let wrapped = root.normalize-phase(phase);
        wrapped < 0.25
            ? Colors.white.mix(base, wrapped / 0.25)
            : wrapped < 0.5
                ? base.mix(Colors.black, (wrapped - 0.25) / 0.25)
                : wrapped < 0.75
                    ? Colors.black.mix(base, (wrapped - 0.5) / 0.25)
                    : base.mix(Colors.white, (wrapped - 0.75) / 0.25)
    }

    function hex-digit(value: float) -> string {
        value < 0.5 ? "0"
        : value < 1.5 ? "1"
        : value < 2.5 ? "2"
        : value < 3.5 ? "3"
        : value < 4.5 ? "4"
        : value < 5.5 ? "5"
        : value < 6.5 ? "6"
        : value < 7.5 ? "7"
        : value < 8.5 ? "8"
        : value < 9.5 ? "9"
        : value < 10.5 ? "a"
        : value < 11.5 ? "b"
        : value < 12.5 ? "c"
        : value < 13.5 ? "d"
        : value < 14.5 ? "e"
        : "f"
    }

    function hex-byte(value: float) -> string {
        let clamped = Math.max(0, Math.min(255, value));
        let high = Math.floor(clamped / 16);
        let low = clamped - high * 16;
        root.hex-digit(high) + root.hex-digit(low)
    }

    function color-to-hex(value: color) -> string {
        "#" + root.hex-byte(value.red) + root.hex-byte(value.green) + root.hex-byte(value.blue)
    }

    function set-picker-color(next-color: color) {
        root.color-picker-selected-color = next-color;
        root.color-picker-selection-known = true;
        root.color-picker-value = root.color-to-hex(next-color);
    }

    function preview-picker-color(next-color: color, pointer-x: length, pointer-y: length) {
        root.preview-color-picker(root.color-to-hex(next-color), next-color, pointer-x, pointer-y);
    }

    function select-wheel-color(hue: float, saturation: float) {
        root.color-picker-base-hue = root.normalize-angle(hue);
        root.color-picker-base-saturation = root.clamp01(saturation);
        root.set-picker-color(root.shade-color(root.color-picker-base-color, root.color-picker-ring-phase));
    }

    function preview-wheel-color(hue: float, saturation: float, pointer-x: length, pointer-y: length) {
        let preview-base = Colors.hsv(root.normalize-angle(hue), root.clamp01(saturation), 1.0);
        root.preview-picker-color(
            root.shade-color(preview-base, root.color-picker-ring-phase),
            pointer-x,
            pointer-y
        );
    }

    function select-ring-color(phase: float) {
        root.color-picker-ring-phase = root.normalize-phase(phase);
        root.set-picker-color(root.shade-color(root.color-picker-base-color, root.color-picker-ring-phase));
    }

    function preview-ring-color(phase: float, pointer-x: length, pointer-y: length) {
        root.preview-picker-color(
            root.shade-color(root.color-picker-base-color, root.normalize-phase(phase)),
            pointer-x,
            pointer-y
        );
    }

    function emit-style-change() {
        root.style-changed(
            editing-background,
            editing-border-color,
            editing-border-width,
            editing-border-radius,
            editing-font-size,
            editing-text-color,
            editing-font-family,
            editing-text-wrap,
            editing-placeholder,
            editing-background-image,
            editing-image-source,
            editing-inherit-text-style,
            editing-checked,
            editing-checkbox-box-side,
            editing-checkbox-check-color,
            editing-checkbox-box-color,
            editing-checkbox-box-border-color,
            editing-checkbox-box-border-width,
            editing-checkbox-space-between
        );
    }

    function emit-container-settings-change() {
        root.container-settings-changed(
            editing-container-mode,
            editing-allow-absolute-children,
            editing-layout-padding,
            editing-layout-spacing,
            editing-layout-margin,
            editing-layout-order,
            editing-stack-alignment,
            editing-flex-direction,
            editing-flex-wrap,
            editing-justify-items,
            editing-justify-content,
            editing-align-items,
            editing-align-content,
            editing-place-items,
            editing-flex-flow,
            editing-grid-template-columns,
            editing-grid-template-rows,
            editing-grid-template-areas
        );
    }

    function open-color-picker(target: string, label: string, current-value: string) {
        root.color-picker-target = target;
        root.color-picker-label = label;
        root.color-picker-value = current-value == "" ? "#ffffff" : current-value;
        root.color-picker-base-hue = 0;
        root.color-picker-base-saturation = 1;
        root.color-picker-ring-phase = 0.75;
        root.color-picker-selected-color = root.shade-color(root.color-picker-base-color, root.color-picker-ring-phase);
        root.color-picker-selection-known = false;
        root.color-picker-preview-visible = false;
        root.color-picker-preview-value = root.color-picker-value;
        root.color-picker-preview-color = root.color-picker-selected-color;
        root.color-picker-preview-x = 0px;
        root.color-picker-preview-y = 0px;
        root.color-picker-open = true;
    }

    function close-color-picker() {
        root.color-picker-open = false;
        root.color-picker-target = "";
        root.color-picker-label = "";
        root.color-picker-preview-visible = false;
    }

    function preview-color-picker(hex: string, swatch-color: color, pointer-x: length, pointer-y: length) {
        root.color-picker-preview-visible = true;
        root.color-picker-preview-value = hex;
        root.color-picker-preview-color = swatch-color;
        root.color-picker-preview-x = pointer-x;
        root.color-picker-preview-y = pointer-y;
    }

    function select-color-picker(hex: string, swatch-color: color) {
        root.color-picker-value = hex;
        root.color-picker-selected-color = swatch-color;
        root.color-picker-selection-known = true;
        if root.color-picker-preview-visible {
            root.preview-color-picker(hex, swatch-color, root.color-picker-preview-x, root.color-picker-preview-y);
        }
    }

    function remember-color(hex: string, swatch-color: color) {
        if hex == "" {
            return;
        }
        if root.recent-color-1-hex == hex {
            root.recent-color-1-color = swatch-color;
            return;
        }

        root.recent-color-8-hex = root.recent-color-7-hex;
        root.recent-color-8-color = root.recent-color-7-color;
        root.recent-color-7-hex = root.recent-color-6-hex;
        root.recent-color-7-color = root.recent-color-6-color;
        root.recent-color-6-hex = root.recent-color-5-hex;
        root.recent-color-6-color = root.recent-color-5-color;
        root.recent-color-5-hex = root.recent-color-4-hex;
        root.recent-color-5-color = root.recent-color-4-color;
        root.recent-color-4-hex = root.recent-color-3-hex;
        root.recent-color-4-color = root.recent-color-3-color;
        root.recent-color-3-hex = root.recent-color-2-hex;
        root.recent-color-3-color = root.recent-color-2-color;
        root.recent-color-2-hex = root.recent-color-1-hex;
        root.recent-color-2-color = root.recent-color-1-color;
        root.recent-color-1-hex = hex;
        root.recent-color-1-color = swatch-color;
    }

    function apply-color-picker() {
        let next-value = root.color-picker-value == "" ? "#ffffff" : root.color-picker-value;

        if root.color-picker-target == "background" {
            editing-background = next-value;
        } else if root.color-picker-target == "border-color" {
            editing-border-color = next-value;
        } else if root.color-picker-target == "text-color" {
            editing-inherit-text-style = false;
            editing-text-color = next-value;
        } else if root.color-picker-target == "checkbox-check-color" {
            editing-checkbox-check-color = next-value;
        } else if root.color-picker-target == "checkbox-box-color" {
            editing-checkbox-box-color = next-value;
        } else if root.color-picker-target == "checkbox-box-border-color" {
            editing-checkbox-box-border-color = next-value;
        }

        if root.color-picker-selection-known && next-value == root.color-picker-value {
            root.remember-color(next-value, root.color-picker-selected-color);
        }

        root.emit-style-change();
        root.close-color-picker();
    }

    changed element-bounds => { editing-bounds = element-bounds; }
    changed element-rotation => { editing-rotation = element-rotation; }
    changed element-text => { editing-text = element-text; }
    changed element-checked => { editing-checked = element-checked; }
    changed element-container-mode => { editing-container-mode = element-container-mode; }
    changed element-allow-absolute-children => { editing-allow-absolute-children = element-allow-absolute-children; }
    changed element-layout-padding => { editing-layout-padding = element-layout-padding; }
    changed element-layout-spacing => { editing-layout-spacing = element-layout-spacing; }
    changed element-layout-margin => { editing-layout-margin = element-layout-margin; }
    changed element-layout-order => { editing-layout-order = element-layout-order; }
    changed element-stack-alignment => { editing-stack-alignment = element-stack-alignment; }
    changed element-flex-direction => { editing-flex-direction = element-flex-direction; }
    changed element-flex-wrap => { editing-flex-wrap = element-flex-wrap; }
    changed element-justify-items => { editing-justify-items = element-justify-items; }
    changed element-justify-content => { editing-justify-content = element-justify-content; }
    changed element-align-items => { editing-align-items = element-align-items; }
    changed element-align-content => { editing-align-content = element-align-content; }
    changed element-place-items => { editing-place-items = element-place-items; }
    changed element-flex-flow => { editing-flex-flow = element-flex-flow; }
    changed element-grid-template-columns => { editing-grid-template-columns = element-grid-template-columns; }
    changed element-grid-template-rows => { editing-grid-template-rows = element-grid-template-rows; }
    changed element-grid-template-areas => { editing-grid-template-areas = element-grid-template-areas; }
    changed element-checkbox-box-side => { editing-checkbox-box-side = element-checkbox-box-side; }
    changed element-checkbox-check-color => { editing-checkbox-check-color = element-checkbox-check-color; }
    changed element-checkbox-box-color => { editing-checkbox-box-color = element-checkbox-box-color; }
    changed element-checkbox-box-border-color => { editing-checkbox-box-border-color = element-checkbox-box-border-color; }
    changed element-checkbox-box-border-width => { editing-checkbox-box-border-width = element-checkbox-box-border-width; }
    changed element-checkbox-space-between => { editing-checkbox-space-between = element-checkbox-space-between; }
    changed element-background => { editing-background = element-background; }
    changed element-border-color => { editing-border-color = element-border-color; }
    changed element-border-width => { editing-border-width = element-border-width; }
    changed element-border-radius => { editing-border-radius = element-border-radius; }
    changed element-font-size => { editing-font-size = element-font-size; }
    changed element-font-family => { editing-font-family = element-font-family; }
    changed element-text-wrap => { editing-text-wrap = element-text-wrap; }
    changed element-text-color => { editing-text-color = element-text-color; }
    changed element-placeholder => { editing-placeholder = element-placeholder; }
    changed element-background-image => { editing-background-image = element-background-image; }
    changed element-image-source => { editing-image-source = element-image-source; }
    changed element-inherit-text-style => { editing-inherit-text-style = element-inherit-text-style; }

    background: Themes.current.primary-bg;

    panel-layout := VerticalBox {
        width: parent.width;
        height: parent.height;
        spacing: 0;
        padding: 0;

        Rectangle {
            height: 40px;
            background: Themes.current.secondary-bg;

            HorizontalBox {
                padding-left: 15px;
                padding-right: 15px;

                Text {
                    height: 24px;
                    text: I18n.t("COMPONENT PROPERTIES");
                    font-size: 14px;
                    font-weight: 600;
                    color: Themes.current.secondary-text;
                    horizontal-stretch: 1;
                    vertical-alignment: TextVerticalAlignment.center;
                    overflow: elide;
                }
            }
        }

        Separator-H {}

        if selected-element-id == "": Rectangle {
            vertical-stretch: 1;
            background: Themes.current.primary-bg;

            Text {
                text: I18n.t("Drop or select an element");
                font-size: 12px;
                color: Themes.current.disabled-text;
                horizontal-alignment: TextHorizontalAlignment.center;
                vertical-alignment: TextVerticalAlignment.center;
            }
        }

        if selected-element-id != "": properties-flickable := Flickable {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            viewport-width: self.width;
            viewport-height: properties-content.preferred-height;

            properties-content := VerticalBox {
            width: properties-flickable.width;
            spacing: 10px;
            padding: 10px;

        Rectangle {
            height: 40px;
            background: Themes.current.primary-bg;
            border-radius: 4px;
            border-width: 1px;
            border-color: Themes.current.border-color;

            VerticalBox {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 2px;

                Text {
                    text: "ID: " + selected-element-id;
                    font-size: 10px;
                    color: Themes.current.secondary-text;
                    overflow: elide;
                }

                Text {
                    text: I18n.t("Type") + ": " + selected-element-type;
                    font-size: 12px;
                    color: Themes.current.primary-text;
                }
            }
        }

        Text {
            text: I18n.t("TRANSFORM");
            font-size: 12px;
            font-weight: 700;
            color: Themes.current.secondary-text;
        }

        NumberAdjust {
            label: "X";
            value: editing-bounds.position.x / 1px;
            step: 1;
            value-changed(v) => {
                editing-bounds.position.x = v * 1px;
                root.bounds-changed(editing-bounds, editing-rotation);
            }
        }

        NumberAdjust {
            label: "Y";
            value: editing-bounds.position.y / 1px;
            step: 1;
            value-changed(v) => {
                editing-bounds.position.y = v * 1px;
                root.bounds-changed(editing-bounds, editing-rotation);
            }
        }

        NumberAdjust {
            label: I18n.t("Width");
            value: editing-bounds.size.width / 1px;
            min: 1;
            step: 2;
            value-changed(v) => {
                editing-bounds.size.width = v * 1px;
                root.bounds-changed(editing-bounds, editing-rotation);
            }
        }

        NumberAdjust {
            label: I18n.t("Height");
            value: editing-bounds.size.height / 1px;
            min: 1;
            step: 2;
            value-changed(v) => {
                editing-bounds.size.height = v * 1px;
                root.bounds-changed(editing-bounds, editing-rotation);
            }
        }

        NumberAdjust {
            label: I18n.t("Rotate");
            value: editing-rotation;
            min: -180;
            max: 180;
            step: 1;
            value-changed(v) => {
                editing-rotation = v;
                root.bounds-changed(editing-bounds, editing-rotation);
            }
        }

        Text {
            text: I18n.t("LAYOUT");
            font-size: 12px;
            font-weight: 700;
            color: Themes.current.secondary-text;
        }

        if selected-element-type == "div": ChoiceField {
            label: "Mode";
            options: ["absolute", "stack", "flex", "grid"];
            value <=> editing-container-mode;
            value-changed(v) => {
                editing-container-mode = v;
                if v != "stack" {
                    editing-allow-absolute-children = false;
                }
                root.emit-container-settings-change();
            }
        }

        if root.supports-container-layout-controls: NumberAdjust {
            label: "Padding";
            value: editing-layout-padding;
            min: 0;
            max: 400;
            step: 1;
            value-changed(v) => {
                editing-layout-padding = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-container-layout-controls: NumberAdjust {
            label: "Spacing";
            value: editing-layout-spacing;
            min: 0;
            max: 400;
            step: 1;
            value-changed(v) => {
                editing-layout-spacing = v;
                root.emit-container-settings-change();
            }
        }

        if selected-element-id != "": NumberAdjust {
            label: "Margin";
            value: editing-layout-margin;
            min: 0;
            max: 400;
            step: 1;
            value-changed(v) => {
                editing-layout-margin = v;
                root.emit-container-settings-change();
            }
        }

        if selected-element-id != "": NumberAdjust {
            label: "Order";
            value: editing-layout-order;
            min: -99;
            max: 99;
            step: 1;
            value-changed(v) => {
                editing-layout-order = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-stack-layout: ChoiceField {
            label: "Align";
            options: ["stretch", "start", "center", "end"];
            value <=> editing-stack-alignment;
            value-changed(v) => {
                editing-stack-alignment = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-stack-layout: Rectangle {
            height: 28px;
            background: Themes.current.primary-bg;
            border-radius: 4px;
            border-width: 1px;
            border-color: Themes.current.border-color;

            HorizontalBox {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;

                Text {
                    text: "Abs Pos";
                    font-size: 12px;
                    color: Themes.current.secondary-text;
                    width: 56px;
                    vertical-alignment: TextVerticalAlignment.center;
                }

                Rectangle {
                    width: 58px;
                    height: 20px;
                    y: 4px;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: editing-allow-absolute-children ? Themes.current.active-color : Themes.current.border-color;
                    background: editing-allow-absolute-children ? Themes.current.active-color : Themes.current.secondary-bg;

                    allow-absolute-touch := TouchArea {
                        mouse-cursor: MouseCursor.pointer;
                        clicked => {
                            editing-allow-absolute-children = !editing-allow-absolute-children;
                            root.emit-container-settings-change();
                        }
                    }

                    Text {
                        text: editing-allow-absolute-children ? "On" : "Off";
                        color: editing-allow-absolute-children ? Themes.on-accent-text : Themes.current.primary-text;
                        font-size: 10px;
                        horizontal-alignment: TextHorizontalAlignment.center;
                        vertical-alignment: TextVerticalAlignment.center;
                    }
                }
            }
        }

        if root.supports-flex-layout: ChoiceField {
            label: "Direction";
            options: ["row", "column"];
            value <=> editing-flex-direction;
            value-changed(v) => {
                editing-flex-direction = v;
                editing-flex-flow = editing-flex-direction + " " + editing-flex-wrap;
                root.emit-container-settings-change();
            }
        }

        if root.supports-flex-layout: ChoiceField {
            label: "Wrap";
            options: ["nowrap", "wrap", "wrap-reverse"];
            value <=> editing-flex-wrap;
            value-changed(v) => {
                editing-flex-wrap = v;
                editing-flex-flow = editing-flex-direction + " " + editing-flex-wrap;
                root.emit-container-settings-change();
            }
        }

        if root.supports-flex-layout: ChoiceField {
            label: "J.Items";
            options: ["stretch", "flex-start", "center", "flex-end"];
            value <=> editing-justify-items;
            value-changed(v) => {
                editing-justify-items = v;
                editing-place-items = editing-justify-items + " " + editing-align-items;
                root.emit-container-settings-change();
            }
        }

        if root.supports-flex-layout: ChoiceField {
            label: "J.Content";
            options: ["flex-start", "center", "flex-end", "space-between", "space-around", "space-evenly"];
            value <=> editing-justify-content;
            value-changed(v) => {
                editing-justify-content = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-flex-layout: ChoiceField {
            label: "A.Items";
            options: ["stretch", "flex-start", "center", "flex-end", "baseline"];
            value <=> editing-align-items;
            value-changed(v) => {
                editing-align-items = v;
                editing-place-items = editing-justify-items + " " + editing-align-items;
                root.emit-container-settings-change();
            }
        }

        if root.supports-flex-layout: ChoiceField {
            label: "A.Content";
            options: ["flex-start", "center", "flex-end", "space-between", "space-around", "stretch"];
            value <=> editing-align-content;
            value-changed(v) => {
                editing-align-content = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-flex-layout: StringField {
            label: "Place";
            value <=> editing-place-items;
            value-changed(v) => {
                editing-place-items = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-flex-layout: StringField {
            label: "Flow";
            value <=> editing-flex-flow;
            value-changed(v) => {
                editing-flex-flow = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-grid-layout: StringField {
            label: "Cols";
            value <=> editing-grid-template-columns;
            value-changed(v) => {
                editing-grid-template-columns = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-grid-layout: StringField {
            label: "Rows";
            value <=> editing-grid-template-rows;
            value-changed(v) => {
                editing-grid-template-rows = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-grid-layout: ChoiceField {
            label: "J.Items";
            options: ["stretch", "flex-start", "center", "flex-end"];
            value <=> editing-justify-items;
            value-changed(v) => {
                editing-justify-items = v;
                editing-place-items = editing-justify-items + " " + editing-align-items;
                root.emit-container-settings-change();
            }
        }

        if root.supports-grid-layout: ChoiceField {
            label: "J.Content";
            options: ["flex-start", "center", "flex-end", "space-between", "space-around", "space-evenly"];
            value <=> editing-justify-content;
            value-changed(v) => {
                editing-justify-content = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-grid-layout: ChoiceField {
            label: "A.Items";
            options: ["stretch", "flex-start", "center", "flex-end"];
            value <=> editing-align-items;
            value-changed(v) => {
                editing-align-items = v;
                editing-place-items = editing-justify-items + " " + editing-align-items;
                root.emit-container-settings-change();
            }
        }

        if root.supports-grid-layout: ChoiceField {
            label: "A.Content";
            options: ["flex-start", "center", "flex-end", "space-between", "space-around", "stretch"];
            value <=> editing-align-content;
            value-changed(v) => {
                editing-align-content = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-grid-layout: StringField {
            label: "Place";
            value <=> editing-place-items;
            value-changed(v) => {
                editing-place-items = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-grid-layout: MultilineStringField {
            label: "Areas";
            value <=> editing-grid-template-areas;
            input-height: 70px;
            value-changed(v) => {
                editing-grid-template-areas = v;
                root.emit-container-settings-change();
            }
        }

        if root.supports-text-content: Text {
            text: I18n.t("TEXT");
            font-size: 12px;
            font-weight: 700;
            color: Themes.current.secondary-text;
        }

        if root.supports-text-content
            && (selected-element-type == "text" || selected-element-type == "label"): MultilineStringField {
            label: I18n.t("Value");
            value <=> editing-text;
            value-changed(v) => {
                editing-text = v;
                root.text-changed(v);
            }
        }

        if root.supports-text-content
            && selected-element-type != "text"
            && selected-element-type != "label": StringField {
            label: I18n.t("Value");
            value <=> editing-text;
            value-changed(v) => {
                editing-text = v;
                root.text-changed(v);
            }
        }

        if root.supports-placeholder: StringField {
            label: "Hint";
            value <=> editing-placeholder;
            value-changed(v) => {
                editing-placeholder = v;
                root.emit-style-change();
            }
        }

        if root.supports-checked: ToggleField {
            label: "Checked";
            checked: editing-checked;
            toggled(next) => {
                editing-checked = next;
                root.emit-style-change();
            }
        }

        if root.supports-checkbox-style: ChoiceField {
            label: "Box Side";
            options: ["left", "right"];
            value: editing-checkbox-box-side;
            value-changed(v) => {
                editing-checkbox-box-side = v.to-lowercase();
                root.emit-style-change();
            }
        }

        if root.supports-checkbox-style: ToggleField {
            label: "Between";
            checked: editing-checkbox-space-between;
            toggled(next) => {
                editing-checkbox-space-between = next;
                root.emit-style-change();
            }
        }

        if root.supports-text-style: ToggleField {
            label: "Inherit";
            checked: editing-inherit-text-style;
            toggled(next) => {
                editing-inherit-text-style = next;
                root.emit-style-change();
            }
        }

        Text {
            text: I18n.t("STYLE");
            font-size: 12px;
            font-weight: 700;
            color: Themes.current.secondary-text;
        }

        if root.supports-checkbox-style: ColorField {
            label: "Check C";
            value <=> editing-checkbox-check-color;
            value-changed(v) => {
                editing-checkbox-check-color = v;
                root.emit-style-change();
            }
            picker-requested => {
                root.open-color-picker("checkbox-check-color", "Check C", editing-checkbox-check-color);
            }
        }

        if root.supports-checkbox-style: ColorField {
            label: "Box C";
            value <=> editing-checkbox-box-color;
            value-changed(v) => {
                editing-checkbox-box-color = v;
                root.emit-style-change();
            }
            picker-requested => {
                root.open-color-picker("checkbox-box-color", "Box C", editing-checkbox-box-color);
            }
        }

        if root.supports-checkbox-style: ColorField {
            label: "Box Border";
            value <=> editing-checkbox-box-border-color;
            value-changed(v) => {
                editing-checkbox-box-border-color = v;
                root.emit-style-change();
            }
            picker-requested => {
                root.open-color-picker("checkbox-box-border-color", "Box Border", editing-checkbox-box-border-color);
            }
        }

        if root.supports-checkbox-style: NumberAdjust {
            label: "Box B.Width";
            value: editing-checkbox-box-border-width;
            min: 0;
            max: 12;
            step: 1;
            value-changed(v) => {
                editing-checkbox-box-border-width = v;
                root.emit-style-change();
            }
        }

        ColorField {
            label: "Background";
            value <=> editing-background;
            value-changed(v) => {
                editing-background = v;
                root.emit-style-change();
            }
            picker-requested => {
                root.open-color-picker("background", "Background", editing-background);
            }
        }

        if root.supports-background-image: StringField {
            label: "Background Image";
            value <=> editing-background-image;
            value-changed(v) => {
                editing-background-image = v;
                root.emit-style-change();
            }
        }

        if root.supports-image-source: BrowseStringField {
            label: "Source";
            value <=> editing-image-source;
            display-value: element-image-source-display;
            read-only: true;
            browse-requested => { root.browse-image-source-requested(); }
        }

        ColorField {
            label: I18n.t("Border");
            value <=> editing-border-color;
            value-changed(v) => {
                editing-border-color = v;
                root.emit-style-change();
            }
            picker-requested => {
                root.open-color-picker("border-color", I18n.t("Border"), editing-border-color);
            }
        }

        NumberAdjust {
            label: "B.Width";
            value: editing-border-width;
            min: 0;
            max: 40;
            step: 1;
            value-changed(v) => {
                editing-border-width = v;
                root.emit-style-change();
            }
        }

        NumberAdjust {
            label: "B.Radius";
            value: editing-border-radius;
            min: 0;
            max: 200;
            step: 1;
            value-changed(v) => {
                editing-border-radius = v;
                root.emit-style-change();
            }
        }

        if root.supports-text-style: NumberAdjust {
            label: I18n.t("Font");
            value: editing-font-size;
            min: 6;
            max: 160;
            step: 1;
            value-changed(v) => {
                editing-inherit-text-style = false;
                editing-font-size = v;
                root.emit-style-change();
            }
        }

        if root.supports-text-style: ColorField {
            label: "Text C";
            value <=> editing-text-color;
            value-changed(v) => {
                editing-inherit-text-style = false;
                editing-text-color = v;
                root.emit-style-change();
            }
            picker-requested => {
                root.open-color-picker("text-color", "Text C", editing-text-color);
            }
        }

        if root.supports-text-style: StringField {
            label: "Font F";
            value <=> editing-font-family;
            value-changed(v) => {
                editing-inherit-text-style = false;
                editing-font-family = v;
                root.emit-style-change();
            }
        }

        if root.supports-text-style: StringField {
            label: "Wrap";
            value <=> editing-text-wrap;
            value-changed(v) => {
                editing-inherit-text-style = false;
                editing-text-wrap = v;
                root.emit-style-change();
            }
        }

        Rectangle { height: 10px; background: transparent; }
            }
        }
    }

    if root.color-picker-open: Rectangle {
        z: 200;
        width: parent.width;
        height: parent.height;
        background: Themes.overlay-strong-bg;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.close-color-picker(); }
        }

        Rectangle {
            z: 1;
            width: parent.width < 328px ? parent.width - 24px : 304px;
            height: 454px;
            x: (parent.width - self.width) / 2;
            y: 20px;
            background: Themes.current.secondary-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: Themes.current.border-color;
            drop-shadow-color: Themes.shadow-color;
            drop-shadow-blur: Themes.shadow-size;

            VerticalBox {
                padding: 12px;
                spacing: 10px;

                Text {
                    text: root.color-picker-label == "" ? I18n.t("Pick Color") : root.color-picker-label;
                    font-size: 13px;
                    font-weight: 700;
                    color: Themes.current.primary-text;
                }

                Rectangle {
                    height: 224px;
                    background: transparent;

                    wheel-stage := Rectangle {
                        width: 220px;
                        height: 220px;
                        x: (parent.width - self.width) / 2;
                        y: 2px;
                        background: transparent;

                        property <length> ring-thickness: 16px;
                        property <length> ring-radius: self.width / 2 - ring-thickness / 2 - 2px;
                        property <length> disc-radius: self.width / 2 - ring-thickness - 12px;
                        property <length> disc-size: disc-radius * 2;
                        property <length> disc-offset: (self.width - disc-size) / 2;
                        property <length> disc-cell-size: disc-size / root.color-disc-grid-size;
                        property <length> center-x: self.width / 2;
                        property <length> center-y: self.height / 2;
                        property <length> ring-handle-size: 18px;
                        property <length> disc-handle-size: 18px;

                        Rectangle {
                            width: parent.width;
                            height: parent.height;
                            background: Themes.current.primary-bg;
                            border-radius: self.width / 2;
                            border-width: 1px;
                            border-color: Themes.current.border-color;
                            drop-shadow-color: Themes.shadow-color;
                            drop-shadow-blur: 10px;
                        }

                        for idx in root.color-ring-segment-count: Rectangle {
                            property <float> ratio: idx / root.color-ring-segment-count;
                            property <float> angle-deg: ratio * 360 - 90;
                            property <length> segment-size: wheel-stage.ring-thickness + 1px;
                            property <length> segment-center-x:
                                wheel-stage.center-x + Math.cos(angle-deg * 1deg) * wheel-stage.ring-radius;
                            property <length> segment-center-y:
                                wheel-stage.center-y + Math.sin(angle-deg * 1deg) * wheel-stage.ring-radius;

                            x: segment-center-x - self.width / 2;
                            y: segment-center-y - self.height / 2;
                            width: segment-size;
                            height: segment-size;
                            border-radius: self.width / 2;
                            background: root.shade-color(root.color-picker-base-color, ratio);
                        }

                        Rectangle {
                            width: wheel-stage.disc-size + 10px;
                            height: wheel-stage.disc-size + 10px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            background: Themes.current.secondary-bg;
                            border-radius: self.width / 2;
                            border-width: 5px;
                            border-color: Colors.white;
                        }

                        ring-touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: MouseCursor.pointer;

                            pointer-event(ev) => {
                                let dx = (self.mouse-x - parent.width / 2) / 1px;
                                let dy = (self.mouse-y - parent.height / 2) / 1px;
                                let distance = Math.sqrt(dx * dx + dy * dy);
                                let outer-radius = (wheel-stage.width / 2 - 2px) / 1px;
                                let inner-radius = (wheel-stage.width / 2 - wheel-stage.ring-thickness - 4px) / 1px;
                                if distance >= inner-radius && distance <= outer-radius {
                                    let phase = root.normalize-phase((Math.atan2(dy, dx) / 1deg + 90) / 360);
                                    if ev.kind == PointerEventKind.move || ev.kind == PointerEventKind.down || ev.kind == PointerEventKind.up {
                                        root.preview-ring-color(
                                            phase,
                                            wheel-stage.x + self.mouse-x,
                                            wheel-stage.y + self.mouse-y
                                        );
                                    }
                                    if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left)
                                        || (ev.kind == PointerEventKind.move && self.pressed) {
                                        root.select-ring-color(phase);
                                    }
                                }
                            }
                        }

                        disc-area := Rectangle {
                            width: wheel-stage.disc-size;
                            height: wheel-stage.disc-size;
                            x: wheel-stage.disc-offset;
                            y: wheel-stage.disc-offset;
                            background: transparent;
                            border-radius: self.width / 2;
                            clip: true;

                            for idx in root.color-disc-grid-size * root.color-disc-grid-size: Rectangle {
                                property <float> grid-size: root.color-disc-grid-size;
                                property <float> row-index: Math.floor(idx / grid-size);
                                property <float> col-index: idx - row-index * grid-size;
                                property <float> norm-x: ((col-index + 0.5) / grid-size) * 2 - 1;
                                property <float> norm-y: ((row-index + 0.5) / grid-size) * 2 - 1;
                                property <float> distance-squared: norm-x * norm-x + norm-y * norm-y;

                                x: col-index * wheel-stage.disc-cell-size;
                                y: row-index * wheel-stage.disc-cell-size;
                                width: wheel-stage.disc-cell-size + 0.5px;
                                height: wheel-stage.disc-cell-size + 0.5px;
                                border-radius: self.width / 2;
                                background: distance-squared <= 1 ? root.wheel-color(norm-x, norm-y) : transparent;
                            }

                            disc-touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: MouseCursor.pointer;

                                pointer-event(ev) => {
                                    let local-x = ((self.mouse-x - parent.width / 2) / Math.max(1px, wheel-stage.disc-radius));
                                    let local-y = ((self.mouse-y - parent.height / 2) / Math.max(1px, wheel-stage.disc-radius));
                                    let distance = Math.sqrt(local-x * local-x + local-y * local-y);
                                    if distance <= 1 {
                                        let hue = root.wheel-hue(local-x, local-y);
                                        let saturation = root.wheel-saturation(local-x, local-y);
                                        if ev.kind == PointerEventKind.move || ev.kind == PointerEventKind.down || ev.kind == PointerEventKind.up {
                                            root.preview-wheel-color(
                                                hue,
                                                saturation,
                                                wheel-stage.x + parent.x + self.mouse-x,
                                                wheel-stage.y + parent.y + self.mouse-y
                                            );
                                        }
                                        if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left)
                                            || (ev.kind == PointerEventKind.move && self.pressed) {
                                            root.select-wheel-color(hue, saturation);
                                        }
                                    }
                                }
                            }
                        }

                        ColorPickerHandle {
                            x:
                                wheel-stage.center-x
                                + Math.cos((root.color-picker-base-hue - 90) * 1deg)
                                    * (root.color-picker-base-saturation * wheel-stage.disc-radius)
                                - self.width / 2;
                            y:
                                wheel-stage.center-y
                                + Math.sin((root.color-picker-base-hue - 90) * 1deg)
                                    * (root.color-picker-base-saturation * wheel-stage.disc-radius)
                                - self.height / 2;
                            size: wheel-stage.disc-handle-size;
                            accent-color: root.shade-color(root.color-picker-base-color, root.color-picker-ring-phase);
                        }

                        ColorPickerHandle {
                            x:
                                wheel-stage.center-x
                                + Math.cos((root.color-picker-ring-phase * 360 - 90) * 1deg)
                                    * wheel-stage.ring-radius
                                - self.width / 2;
                            y:
                                wheel-stage.center-y
                                + Math.sin((root.color-picker-ring-phase * 360 - 90) * 1deg)
                                    * wheel-stage.ring-radius
                                - self.height / 2;
                            size: wheel-stage.ring-handle-size;
                            accent-color: root.shade-color(root.color-picker-base-color, root.color-picker-ring-phase);
                        }

                        if root.color-picker-preview-visible: Rectangle {
                            z: 3;
                            width: 22px;
                            height: 22px;
                            x: Math.max(
                                4px,
                                Math.min(parent.width - self.width - 4px, root.color-picker-preview-x + 14px)
                            );
                            y: Math.max(
                                4px,
                                Math.min(parent.height - self.height - 4px, root.color-picker-preview-y - self.height - 10px)
                            );
                            border-radius: self.width / 2;
                            border-width: 2px;
                            border-color: Themes.current.primary-text;
                            background: root.color-picker-preview-color;
                            drop-shadow-color: Themes.shadow-color;
                            drop-shadow-blur: 8px;
                        }
                    }
                }

                Rectangle {
                    height: 28px;
                    background: Themes.current.primary-bg;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Themes.current.border-color;
                    clip: true;

                    TextInput {
                        width: parent.width - 16px;
                        x: 8px;
                        y: 1px;
                        text <=> root.color-picker-value;
                        font-size: 12px;
                        color: Themes.current.primary-text;
                        single-line: true;
                        horizontal-alignment: TextHorizontalAlignment.right;
                        vertical-alignment: TextVerticalAlignment.center;
                        edited => {
                            root.color-picker-selection-known = false;
                            root.color-picker-preview-visible = false;
                        }
                        accepted => { root.apply-color-picker(); }
                    }
                }

                Text {
                    text: I18n.t("Recent Colors");
                    font-size: 11px;
                    font-weight: 600;
                    color: Themes.current.secondary-text;
                }

                if root.no-recent-colors: Rectangle {
                    height: 26px;
                    background: Themes.current.primary-bg;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Themes.current.border-color;

                    Text {
                        text: I18n.t("No recent colors");
                        color: Themes.current.secondary-text;
                        font-size: 11px;
                        horizontal-alignment: TextHorizontalAlignment.center;
                        vertical-alignment: TextVerticalAlignment.center;
                    }
                }

                if !root.no-recent-colors: HorizontalBox {
                    spacing: 6px;

                    if root.recent-color-1-hex != "": ColorSwatch {
                        hex: root.recent-color-1-hex;
                        swatch-color: root.recent-color-1-color;
                        is-selected: root.color-picker-value == root.recent-color-1-hex;
                        picked(hex) => { root.select-color-picker(hex, root.recent-color-1-color); }
                    }
                    if root.recent-color-2-hex != "": ColorSwatch {
                        hex: root.recent-color-2-hex;
                        swatch-color: root.recent-color-2-color;
                        is-selected: root.color-picker-value == root.recent-color-2-hex;
                        picked(hex) => { root.select-color-picker(hex, root.recent-color-2-color); }
                    }
                    if root.recent-color-3-hex != "": ColorSwatch {
                        hex: root.recent-color-3-hex;
                        swatch-color: root.recent-color-3-color;
                        is-selected: root.color-picker-value == root.recent-color-3-hex;
                        picked(hex) => { root.select-color-picker(hex, root.recent-color-3-color); }
                    }
                    if root.recent-color-4-hex != "": ColorSwatch {
                        hex: root.recent-color-4-hex;
                        swatch-color: root.recent-color-4-color;
                        is-selected: root.color-picker-value == root.recent-color-4-hex;
                        picked(hex) => { root.select-color-picker(hex, root.recent-color-4-color); }
                    }
                    if root.recent-color-5-hex != "": ColorSwatch {
                        hex: root.recent-color-5-hex;
                        swatch-color: root.recent-color-5-color;
                        is-selected: root.color-picker-value == root.recent-color-5-hex;
                        picked(hex) => { root.select-color-picker(hex, root.recent-color-5-color); }
                    }
                    if root.recent-color-6-hex != "": ColorSwatch {
                        hex: root.recent-color-6-hex;
                        swatch-color: root.recent-color-6-color;
                        is-selected: root.color-picker-value == root.recent-color-6-hex;
                        picked(hex) => { root.select-color-picker(hex, root.recent-color-6-color); }
                    }
                    if root.recent-color-7-hex != "": ColorSwatch {
                        hex: root.recent-color-7-hex;
                        swatch-color: root.recent-color-7-color;
                        is-selected: root.color-picker-value == root.recent-color-7-hex;
                        picked(hex) => { root.select-color-picker(hex, root.recent-color-7-color); }
                    }
                    if root.recent-color-8-hex != "": ColorSwatch {
                        hex: root.recent-color-8-hex;
                        swatch-color: root.recent-color-8-color;
                        is-selected: root.color-picker-value == root.recent-color-8-hex;
                        picked(hex) => { root.select-color-picker(hex, root.recent-color-8-color); }
                    }
                }

                Rectangle { height: 1px; background: Themes.current.border-color; }

                HorizontalBox {
                    spacing: 6px;

                    Rectangle {
                        horizontal-stretch: 1;
                        background: transparent;
                    }

                    Rectangle {
                        width: 68px;
                        height: 28px;
                        border-radius: 4px;
                        background: cancel-touch.has-hover ? Themes.current.hover-color : Themes.current.primary-bg;

                        cancel-touch := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => { root.close-color-picker(); }
                        }

                        Text {
                            text: I18n.t("Cancel");
                            font-size: 12px;
                            font-weight: 600;
                            color: Themes.current.primary-text;
                            horizontal-alignment: TextHorizontalAlignment.center;
                            vertical-alignment: TextVerticalAlignment.center;
                        }
                    }

                    Rectangle {
                        width: 68px;
                        height: 28px;
                        border-radius: 4px;
                        background: apply-touch.has-hover ? Themes.current.hover-color : Themes.current.active-color;

                        apply-touch := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => { root.apply-color-picker(); }
                        }

                        Text {
                            text: I18n.t("Apply");
                            font-size: 12px;
                            font-weight: 600;
                            color: Themes.on-accent-text;
                            horizontal-alignment: TextHorizontalAlignment.center;
                            vertical-alignment: TextVerticalAlignment.center;
                        }
                    }
                }
            }
        }
    }
}
