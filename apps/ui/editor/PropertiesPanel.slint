import { VerticalBox, HorizontalBox, TextEdit, ComboBox } from "std-widgets.slint";
import { Themes, Separator-H } from "../components/Themes.slint";
import { I18n } from "../components/I18n.slint";
import { CanvasBounds } from "../models/EditorModels.slint";

component NumberAdjust inherits Rectangle {
    in property <string> label: "";
    in property <float> value: 0;
    in property <float> min: -9999;
    in property <float> max: 9999;
    in property <float> step: 1;
    callback value-changed(float);
    property <bool> editing: false;
    property <string> editing-text: "";
    property <string> error-message: "";
    private property <bool> has-error: root.error-message != "";

    function begin-editing() {
        root.editing = true;
        root.error-message = "";
        root.editing-text = (round(root.value * 100) / 100) + "";
    }

    function commit-editing() {
        if root.editing-text == "" || root.editing-text == "-" || root.editing-text == "." || root.editing-text == "-." {
            root.error-message = I18n.t("Invalid number");
            return;
        }

        let parsed = root.editing-text.to-float();
        if parsed != parsed {
            root.error-message = I18n.t("Invalid number");
            return;
        }

        let nv = Math.max(root.min, Math.min(root.max, parsed));
        root.value-changed(nv);
        root.error-message = "";
        root.editing = false;
    }

    height: root.has-error ? 42px : 28px;
    horizontal-stretch: 1;
    background: transparent;

    VerticalBox {
        padding: 0;
        spacing: 2px;

        Rectangle {
            height: 28px;
            background: Themes.current.primary-bg;
            border-radius: 4px;
            border-width: 1px;
            border-color: root.has-error ? Themes.error-text : Themes.current.border-color;

            HorizontalBox {
                padding: 0;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;

                Rectangle {
                    height: parent.height;
                    background: transparent;

                    Text {
                        height: 28px;
                        text: root.label == "" ? I18n.t("Value") : root.label;
                        font-size: 12px;
                        color: Themes.current.secondary-text;
                        width: parent.width;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                HorizontalBox {
                    padding: 0;
                    padding-top: 4px;
                    width: 100px;

                    Rectangle {
                        width: 20px;
                        height: 20px;
                        border-radius: 4px;
                        background: minus-touch.has-hover ? Themes.current.hover-color : Themes.current.secondary-bg;

                        minus-touch := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => {
                                root.error-message = "";
                                let nv = Math.max(root.min, root.value - root.step);
                                root.value-changed(nv);
                            }
                        }

                        Text {
                            text: "–";
                            font-size: 14px;
                            font-weight: 600;
                            color: Themes.current.primary-text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: transparent;

                        value-touch := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            double-clicked => { root.begin-editing(); }
                        }

                        if !root.editing: Text {
                            height: 24px;
                            width: 50px;
                            text: round(root.value * 100) / 100;
                            font-size: 12px;
                            font-weight: 600;
                            color: Themes.current.primary-text;
                            horizontal-alignment: TextHorizontalAlignment.center;
                            vertical-alignment: TextVerticalAlignment.center;
                        }

                        if root.editing: TextInput {
                            text <=> root.editing-text;
                            input-type: InputType.number;
                            horizontal-alignment: TextHorizontalAlignment.center;
                             vertical-alignment: TextVerticalAlignment.center;
                            color: Themes.current.primary-text;
                            font-size: 12px;
                            font-weight: 600;
                            accepted => { root.commit-editing(); }
                            edited => { root.error-message = ""; }
                        }
                    }

                    Rectangle {
                        width: 20px;
                        height: 20px;
                        border-radius: 4px;
                        background: plus-touch.has-hover ? Themes.current.hover-color : Themes.current.secondary-bg;

                        plus-touch := TouchArea {
                            mouse-cursor: MouseCursor.pointer;
                            clicked => {
                                root.error-message = "";
                                let nv = Math.min(root.max, root.value + root.step);
                                root.value-changed(nv);
                            }
                        }

                        Text {
                            text: "+";
                            font-size: 14px;
                            font-weight: 600;
                            color: Themes.current.primary-text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                
            }
        }

        if root.has-error: Rectangle {
            height: 12px;
            background: transparent;

            Text {
                x: 8px;
                width: parent.width - 16px;
                text: root.error-message;
                font-size: 10px;
                color: Themes.error-text;
                horizontal-alignment: TextHorizontalAlignment.left;
                vertical-alignment: TextVerticalAlignment.center;
                overflow: elide;
            }
        }
    }
}

component StringField inherits Rectangle {
    in property <string> label: "";
    in-out property <string> value: "";
    callback value-changed(string);

    height: 28px;
    horizontal-stretch: 1;
    background: Themes.current.primary-bg;
    border-radius: 4px;
    border-width: 1px;
    border-color: Themes.current.border-color;

    HorizontalBox {
        padding: 0;
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;

        Rectangle {
            width: 106px;
            height: parent.height;
            background: transparent;

            Text {
                height: 20px;
                horizontal-alignment: TextHorizontalAlignment.left;
                text: root.label == "" ? I18n.t("Value") : root.label;
                font-size: 12px;
                color: Themes.current.secondary-text;
                font-weight: 600;
                vertical-alignment: TextVerticalAlignment.center;
                width: parent.width;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            height: 25px;
            background: transparent;
            clip: true;

            TextInput {
                width: parent.width;
                height: parent.height;
                horizontal-alignment: TextHorizontalAlignment.right;
                vertical-alignment: TextVerticalAlignment.center;
                single-line: true;
                text <=> root.value;
                font-size: 12px;
                color: Themes.current.primary-text;
                edited => { root.value-changed(root.value); }
            }
        }
    }
}

component BrowseStringField inherits Rectangle {
    in property <string> label: "";
    in-out property <string> value: "";
    in property <string> display-value: "";
    in property <bool> read-only: false;
    callback value-changed(string);
    callback browse-requested();

    height: 28px;
    horizontal-stretch: 1;
    background: Themes.current.primary-bg;
    border-radius: 4px;
    border-width: 1px;
    border-color: Themes.current.border-color;

    HorizontalBox {
        padding: 0;
        padding-left: 8px;
        padding-right: 6px;
        spacing: 6px;

        Rectangle {
            width: 106px;
            height: parent.height;
            background: transparent;

            Text {
                height: 20px;
                horizontal-alignment: TextHorizontalAlignment.left;
                text: root.label == "" ? I18n.t("Value") : root.label;
                font-size: 12px;
                color: Themes.current.secondary-text;
                font-weight: 600;
                vertical-alignment: TextVerticalAlignment.center;
                width: parent.width;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            height: 25px;
            background: transparent;
            clip: true;

            if root.read-only: Text {
                width: parent.width;
                height: parent.height;
                horizontal-alignment: TextHorizontalAlignment.right;
                vertical-alignment: TextVerticalAlignment.center;
                text: root.display-value == "" ? root.value : root.display-value;
                font-size: 12px;
                color: Themes.current.primary-text;
                overflow: elide;
            }

            if !root.read-only: TextInput {
                width: parent.width;
                height: parent.height;
                horizontal-alignment: TextHorizontalAlignment.right;
                vertical-alignment: TextVerticalAlignment.center;
                single-line: true;
                text <=> root.value;
                font-size: 12px;
                color: Themes.current.primary-text;
                edited => { root.value-changed(root.value); }
            }
        }

        VerticalBox {
            padding: 4px;

            Rectangle {
                width: 42px;
                height: 20px;
                border-radius: 4px;
                background: browse-touch.has-hover ? Themes.current.hover-color : Themes.current.secondary-bg;

                browse-touch := TouchArea {
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { root.browse-requested(); }
                }

                Text {
                    text: "Open";
                    font-size: 10px;
                    font-weight: 700;
                    color: Themes.current.primary-text;
                    horizontal-alignment: TextHorizontalAlignment.center;
                    vertical-alignment: TextVerticalAlignment.center;
                }
            }
        }
    }
}

