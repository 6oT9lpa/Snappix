export component ContextMenuClickComment inherits CanvasContextMenuSurface {
    in property <bool> has-image: false;
    in-out property <float> title-font-size: 16;
    in-out property <float> body-font-size: 13;

    callback paste-image-requested();
    callback delete-image-requested();
    callback delete-comment-requested();
    callback title-font-size-requested(float);
    callback body-font-size-requested(float);
    callback dismiss-requested();

    VerticalBox {
        alignment: LayoutAlignment.stretch;
        horizontal-stretch: 1;
        padding: 6px;
        spacing: 5px;
        vertical-stretch: 1;

        CanvasContextMenuActionRow {
            title: I18n.t("Paste Image from Clipboard");
            hotkey: "Clipboard";
            selected => { root.paste-image-requested(); }
        }

        if root.has-image: CanvasContextMenuActionRow {
            title: I18n.t("Delete Image");
            selected => { root.delete-image-requested(); }
        }

        CanvasContextMenuActionRow {
            title: I18n.t("Delete Comment");
            hotkey: "Del";
            selected => { root.delete-comment-requested(); }
        }

        Separator-H {}

        CanvasContextMenuNumberAdjust {
            title: I18n.t("Title size");
            value: root.title-font-size;
            min: 10;
            max: 36;
            step: 1;
            value-changed(next) => {
                root.title-font-size = next;
                root.title-font-size-requested(next);
            }
        }

        CanvasContextMenuNumberAdjust {
            title: I18n.t("Body size");
            value: root.body-font-size;
            min: 10;
            max: 30;
            step: 1;
            value-changed(next) => {
                root.body-font-size = next;
                root.body-font-size-requested(next);
            }
        }

        Separator-H {}

        CanvasContextMenuActionRow {
            title: I18n.t("Cancel");
            selected => { root.dismiss-requested(); }
        }
    }
}
