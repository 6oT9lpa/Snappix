import { HorizontalBox, VerticalBox } from "std-widgets.slint";
import { Themes, Separator-H } from "../components/Themes.slint";
import { CanvasZoomControls } from "./CanvasZoomControls.slint";
import { BlueprintLinkInfo, BlueprintNodeInfo, SelectionInfo } from "../models/EditorModels.slint";
import { StringSearch } from "../utils/StringSearch.slint";

component NodeMenuRow inherits Rectangle {
    in property <string> title: "";
    in property <string> descriptor-id: "";
    in property <string> query: "";
    callback selected(string);

    visible: query == "" || StringSearch.contains(title, query) || StringSearch.contains(descriptor-id, query);
    height: self.visible ? 28px : 0px;
    border-radius: 4px;
    background: touch.has-hover ? Themes.current.hover-color : transparent;
    clip: true;

    touch := TouchArea {
        mouse-cursor: MouseCursor.pointer;
        clicked => { root.selected(root.descriptor-id); }
    }

    Text {
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.title;
        color: Themes.current.primary-text;
        font-size: 12px;
        vertical-alignment: TextVerticalAlignment.center;
        overflow: elide;
    }
}

component MenuGroupHeader inherits Rectangle {
    in property <string> title: "";
    in-out property <bool> expanded: false;

    height: 30px;
    border-radius: 4px;
    background: transparent;

    dropdown-touch := TouchArea {
        height: 30px;
        mouse-cursor: MouseCursor.pointer;
        clicked => {
            root.expanded = !root.expanded;
        }

        HorizontalBox {
            padding-left: 10px;

            Path {
                stroke: Themes.current.secondary-text;
                stroke-width: 1.5px;
                transform-rotation: root.expanded ? 90deg : 0deg;
                fill: transparent;
                width: 10px;
                height: 12px;
                commands: "M 0 0 L 6 6 L 0 12";
                animate transform-rotation { duration: 150ms; }
            }

            Text {
                text: root.title;
                font-size: 12px;
                color: root.expanded || dropdown-touch.has-hover ?  Themes.current.secondary-text: Themes.current.primary-text;
                font-weight: 700;
                vertical-alignment: TextVerticalAlignment.center;
                horizontal-stretch: 1;
                animate color { duration: 150ms; }
            }
        }
    }
}

component NodeContextAction inherits Rectangle {
    in property <string> title: "";
    callback selected();

    height: 28px;
    border-radius: 4px;
    background: touch.has-hover ? Themes.current.hover-color : transparent;

    touch := TouchArea {
        mouse-cursor: MouseCursor.pointer;
        clicked => { root.selected(); }
    }

    Text {
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.title;
        color: Themes.current.primary-text;
        font-size: 12px;
        vertical-alignment: TextVerticalAlignment.center;
        overflow: elide;
    }
}

component BlueprintNodeCard inherits Rectangle {
    in property <string> node-id: "";
    in property <string> title: "Getter";
    in property <string> element-type: "";
    in property <string> descriptor-id: "";
    in property <bool> is-event: false;
    in property <bool> is-bound-event: false;
    in property <bool> has-exec-input: false;
    in property <string> exec-output-1: "";
    in property <string> exec-output-2: "";
    in property <string> exec-output-3: "";
    in property <bool> exec-output-1-connected: false;
    in property <bool> exec-output-2-connected: false;
    in property <bool> exec-output-3-connected: false;
    in property <string> data-output-name: "value";
    in property <string> data-output-type: "bool";
    in property <color> data-output-color: #5ac68b;
    in property <bool> data-output-connected: false;
    in property <string> data-input-name: "";
    in property <string> data-input-type: "";
    in property <color> data-input-color: #5ac68b;
    in property <float> world-x: 0;
    in property <float> world-y: 0;
    in property <float> live-world-x: 0;
    in property <float> live-world-y: 0;
    in property <length> screen-x: 0px;
    in property <length> screen-y: 0px;
    in property <float> zoom-level: 1.0;
    in property <bool> is-selected: false;
    in property <float> drag-delta-x: 0;
    in property <float> drag-delta-y: 0;
    in property <int> drag-commit-seq: 0;
    in property <float> marquee-min-x: 0;
    in property <float> marquee-max-x: 0;
    in property <float> marquee-min-y: 0;
    in property <float> marquee-max-y: 0;
    in property <int> marquee-apply-seq: 0;

    callback consume-canvas-left-down();
    callback node-select-requested(string, bool);
    callback node-menu-requested(string, string, bool, bool, length, length);
    callback node-drag-started(string, float, float, length, length, bool);
    callback node-drag-updated(length, length);
    callback node-drag-finished();
    callback node-drag-cancelled();
    callback wire-started(string, string, int, color, length, length);
    callback wire-updated(length, length);
    callback wire-released(length, length);
    callback node-moved-requested(string, float, float);
    callback marquee-hit(string);

    property <length> base-node-width: root.is-event ? 250px : 270px;
    property <bool> is-getter: root.descriptor-id == "variable.get";
    property <length> base-node-height:
        root.is-getter ? 60px
        : root.exec-output-3 != "" ? 150px
        : root.exec-output-2 != "" ? 126px
        : root.data-input-name != "" ? 118px
        : 94px;
    property <length> header-height: 34px * root.zoom-level;
    property <length> exec-label-x: root.width - 108px * root.zoom-level;
    property <length> exec-pin-x: root.width - 20px * root.zoom-level;
    property <length> exec-input-y: root.header-height + 18px * root.zoom-level;
    property <length> exec-row-1-label-y: root.header-height + 10px * root.zoom-level;
    property <length> exec-row-1-pin-y: root.header-height + 18px * root.zoom-level;
    property <length> exec-row-2-label-y: root.header-height + 38px * root.zoom-level;
    property <length> exec-row-2-pin-y: root.header-height + 46px * root.zoom-level;
    property <length> exec-row-3-label-y: root.header-height + 66px * root.zoom-level;
    property <length> exec-row-3-pin-y: root.header-height + 74px * root.zoom-level;
    property <length> data-label-y: root.is-getter ? root.header-height + 2px * root.zoom-level : root.header-height + 40px * root.zoom-level;
    property <length> data-pin-y: root.is-getter ? root.header-height + 10px * root.zoom-level : root.header-height + 48px * root.zoom-level;
    property <color> header-glow-color:
        root.is-event ? #ea555c8a
        : root.is-getter ? root.data-output-color.with-alpha(0.50)
        : #676666;
    property <length> node-width: root.is-event ? (root.base-node-width - 100px) * root.zoom-level : root.base-node-width * root.zoom-level;
    property <length> node-height: root.base-node-height * root.zoom-level;
    property <float> base-width-world: root.base-node-width / 1px;
    property <float> base-height-world: root.base-node-height / 1px;
    property <string> exec-arrow-commands:
        "M 4 2 L 10 2 Q 11.5 2 12.5 3.5 L 18 10 Q 19 11 18 12 L 12.5 18.5 Q 11.5 20 10 20 L 4 20 Q 2 20 2 18 L 2 4 Q 2 2 4 2 Z";

    x: root.screen-x;
    y: root.screen-y;
    width: root.node-width;
    height: root.node-height;
    border-radius: 7px * root.zoom-level;
    border-width: root.is-selected ? 2px : 1px;
    border-color: root.is-selected ? Themes.current.active-color : Themes.current.border-color;
    background: Themes.secondary-background-transparent;

    changed drag-commit-seq => {
        if root.is-selected && (Math.abs(root.drag-delta-x) > 0.001 || Math.abs(root.drag-delta-y) > 0.001) {
            root.node-moved-requested(
                root.node-id,
                root.world-x + root.drag-delta-x,
                root.world-y + root.drag-delta-y
            );
        }
    }

    changed marquee-apply-seq => {
        let node-min-x = root.world-x;
        let node-max-x = root.world-x + root.base-width-world;
        let node-min-y = root.world-y;
        let node-max-y = root.world-y + root.base-height-world;
        let intersects = node-max-x >= root.marquee-min-x
            && node-min-x <= root.marquee-max-x
            && node-max-y >= root.marquee-min-y
            && node-min-y <= root.marquee-max-y;
        if intersects {
            root.marquee-hit(root.node-id);
        }
    }
    Rectangle {
        clip: true;

        VerticalBox {
            padding: 0;
            z: 1;

            header := Rectangle {
                z: 3;
                width: parent.width;
                height: root.header-height;
                border-radius: 7px * root.zoom-level;
                background: transparent;

                Rectangle {
                    x: 8px * root.zoom-level;
                    y: 5px * root.zoom-level;
                    width: parent.width - 16px * root.zoom-level;
                    drop-shadow-offset-y: -15px;
                    height: parent.height - 10px * root.zoom-level;
                    border-radius: self.height / 2;
                    drop-shadow-blur: 40px * root.zoom-level;
                    drop-shadow-color: root.header-glow-color;
                }

                Text {
                    x: 12px * root.zoom-level;
                    width: parent.width - 24px * root.zoom-level;
                    height: parent.height;
                    text: root.is-event ? root.element-type : root.title;
                    color: Themes.current.primary-text;
                    font-size: 12px * root.zoom-level;
                    font-weight: 700;
                    vertical-alignment: TextVerticalAlignment.center;
                    overflow: elide;
                }

                TouchArea {
                    z: 1;
                    mouse-cursor: MouseCursor.move;
                    pointer-event(ev) => {
                        if ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down {
                            root.consume-canvas-left-down();
                        }
                        let sx = root.x + self.mouse-x;
                        let sy = root.y + self.mouse-y;
                        if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right {
                            root.node-menu-requested(root.node-id, root.descriptor-id, root.is-event, root.is-bound-event, sx, sy);
                        }
                        if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                            root.node-drag-started(root.node-id, root.world-x, root.world-y, sx, sy, ev.modifiers.control);
                        }
                        if ev.kind == PointerEventKind.move {
                            root.node-drag-updated(sx, sy);
                        }
                        if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                            root.node-drag-finished();
                        }
                        if ev.kind == PointerEventKind.cancel {
                            root.node-drag-cancelled();
                        }
                    }
                }
            }
        }
    }

    if root.has-exec-input: Rectangle {
        z: 3;
        x: 5px * root.zoom-level;
        y: root.exec-input-y;
        width: 15px * root.zoom-level;
        height: 15px * root.zoom-level;

        Path {
            width: parent.width;
            height: parent.height;
            viewbox-width: 20;
            viewbox-height: 20;
            fill: Themes.current.primary-text;
            stroke: Themes.current.primary-text;
            stroke-width: 2px;
            commands: root.exec-arrow-commands;
        }
    }

    if root.exec-output-1 != "": Text {
        z: 3;
        x: root.exec-label-x;
        y: root.exec-row-1-label-y;
        width: 80px * root.zoom-level;
        height: 30px * root.zoom-level;
        text: root.exec-output-1;
        color: Themes.current.primary-text;
        font-size: 13px * root.zoom-level;
        horizontal-alignment: TextHorizontalAlignment.right;
        vertical-alignment: TextVerticalAlignment.center;
        overflow: elide;
    }

    if root.exec-output-1 != "": Rectangle {
        z: 4;
        x: root.exec-pin-x;
        y: root.exec-row-1-pin-y;
        width: 15px * root.zoom-level;
        height: 15px * root.zoom-level;
        background: transparent;

        Path {
            width: parent.width;
            height: parent.height;
            viewbox-width: 20;
            viewbox-height: 20;
            fill: root.exec-output-1-connected ? Themes.current.primary-text : transparent;
            stroke: Themes.current.primary-text;
            stroke-width: 2px;
            commands: root.exec-arrow-commands;
        }

        TouchArea {
            mouse-cursor: MouseCursor.crosshair;
            pointer-event(ev) => {
                let sx = root.x + parent.x + self.mouse-x;
                let sy = root.y + parent.y + self.mouse-y;
                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                    root.consume-canvas-left-down();
                    root.wire-started(root.node-id, "exec", 0, #f5f5f5, sx, sy);
                }
                if ev.kind == PointerEventKind.move && self.pressed {
                    root.wire-updated(sx, sy);
                }
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.wire-released(sx, sy);
                }
                if ev.kind == PointerEventKind.cancel {
                    root.wire-released(sx, sy);
                }
            }
        }
    }

    if root.exec-output-2 != "": Text {
        z: 3;
        x: root.exec-label-x;
        y: root.exec-row-2-label-y;
        width: 80px * root.zoom-level;
        height: 30px * root.zoom-level;
        text: root.exec-output-2;
        color: Themes.current.primary-text;
        font-size: 13px * root.zoom-level;
        horizontal-alignment: TextHorizontalAlignment.right;
        vertical-alignment: TextVerticalAlignment.center;
        overflow: elide;
    }

    if root.exec-output-2 != "": Rectangle {
        z: 4;
        x: root.exec-pin-x;
        y: root.exec-row-2-pin-y;
        width: 15px * root.zoom-level;
        height: 15px * root.zoom-level;
        background: transparent;

        Path {
            width: parent.width;
            height: parent.height;
            viewbox-width: 20;
            viewbox-height: 20;
            fill: root.exec-output-2-connected ? Themes.current.primary-text : transparent;
            stroke: Themes.current.primary-text;
            stroke-width: 2px;
            commands: root.exec-arrow-commands;
        }

        TouchArea {
            mouse-cursor: MouseCursor.crosshair;
            pointer-event(ev) => {
                let sx = root.x + parent.x + self.mouse-x;
                let sy = root.y + parent.y + self.mouse-y;
                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                    root.consume-canvas-left-down();
                    root.wire-started(root.node-id, "exec", 1, #f5f5f5, sx, sy);
                }
                if ev.kind == PointerEventKind.move && self.pressed {
                    root.wire-updated(sx, sy);
                }
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.wire-released(sx, sy);
                }
                if ev.kind == PointerEventKind.cancel {
                    root.wire-released(sx, sy);
                }
            }
        }
    }

    if root.exec-output-3 != "": Text {
        z: 3;
        x: root.exec-label-x;
        y: root.exec-row-3-label-y;
        width: 80px * root.zoom-level;
        height: 30px * root.zoom-level;
        text: root.exec-output-3;
        color: Themes.current.primary-text;
        font-size: 13px * root.zoom-level;
        horizontal-alignment: TextHorizontalAlignment.right;
        vertical-alignment: TextVerticalAlignment.center;
        overflow: elide;
    }

    if root.exec-output-3 != "": Rectangle {
        z: 4;
        x: root.exec-pin-x;
        y: root.exec-row-3-pin-y;
        width: 15px * root.zoom-level;
        height: 15px * root.zoom-level;
        background: transparent;

        Path {
            width: parent.width;
            height: parent.height;
            viewbox-width: 20;
            viewbox-height: 20;
            fill: root.exec-output-3-connected ? Themes.current.primary-text : transparent;
            stroke: Themes.current.primary-text;
            stroke-width: 2px;
            commands: root.exec-arrow-commands;
        }

        TouchArea {
            mouse-cursor: MouseCursor.crosshair;
            pointer-event(ev) => {
                let sx = root.x + parent.x + self.mouse-x;
                let sy = root.y + parent.y + self.mouse-y;
                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                    root.consume-canvas-left-down();
                    root.wire-started(root.node-id, "exec", 2, #f5f5f5, sx, sy);
                }
                if ev.kind == PointerEventKind.move && self.pressed {
                    root.wire-updated(sx, sy);
                }
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.wire-released(sx, sy);
                }
                if ev.kind == PointerEventKind.cancel {
                    root.wire-released(sx, sy);
                }
            }
        }
    }

    if root.data-output-name != "": Text {
        z: 3;
        x: parent.width - 160px * root.zoom-level;
        y: root.data-label-y;
        width: 132px * root.zoom-level;
        height: 28px * root.zoom-level;
        text: root.data-output-name + " : " + root.data-output-type;
        color: Themes.current.secondary-text;
        font-size: 11px * root.zoom-level;
        horizontal-alignment: TextHorizontalAlignment.right;
        vertical-alignment: TextVerticalAlignment.center;
        overflow: elide;
    }

    if root.data-output-name != "": Rectangle {
        z: 4;
        x: parent.width - 15px * root.zoom-level;
        y: root.data-pin-y;
        width: 12px * root.zoom-level;
        height: 12px * root.zoom-level;
        border-radius: 6px * root.zoom-level;
        border-width: 1px;
        border-color: root.data-output-color;
        background: root.data-output-connected ? root.data-output-color : transparent;

        TouchArea {
            mouse-cursor: MouseCursor.crosshair;
            pointer-event(ev) => {
                let sx = root.x + parent.x + self.mouse-x;
                let sy = root.y + parent.y + self.mouse-y;
                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                    root.consume-canvas-left-down();
                    root.wire-started(root.node-id, "data", 0, root.data-output-color, sx, sy);
                }
                if ev.kind == PointerEventKind.move && self.pressed {
                    root.wire-updated(sx, sy);
                }
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.wire-released(sx, sy);
                }
                if ev.kind == PointerEventKind.cancel {
                    root.wire-released(sx, sy);
                }
            }
        }
    }

    TouchArea {
        y: 33px;
        z: 1;
        width: parent.width;
        height: 60px;
        mouse-cursor: MouseCursor.pointer;
        pointer-event(ev) => {
            if ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down {
                root.consume-canvas-left-down();
                root.node-select-requested(root.node-id, ev.modifiers.control);
            }
            if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right {
                root.node-menu-requested(root.node-id, root.descriptor-id, root.is-event, root.is-bound-event, root.x + self.mouse-x, root.y + self.mouse-y);
            }
        }
    }

    if root.data-input-name != "": Rectangle {
        x: 5px * root.zoom-level;
        y: root.data-pin-y;
        width: 12px * root.zoom-level;
        height: 12px * root.zoom-level;
        border-radius: 6px * root.zoom-level;
        background: root.data-input-color;
    }

    if root.data-input-name != "": Text {
        x: 25px * root.zoom-level;
        y: root.data-label-y;
        width: 140px * root.zoom-level;
        height: 28px * root.zoom-level;
        text: root.data-input-name + " : " + root.data-input-type;
        color: Themes.current.secondary-text;
        font-size: 11px * root.zoom-level;
        vertical-alignment: TextVerticalAlignment.center;
        overflow: elide;
    }
}

export component BlueprintCanvas inherits Rectangle {
    in-out property <float> zoom-level: 1.0;
    in-out property <length> offset-x: 0px;
    in-out property <length> offset-y: 0px;
    in property <[BlueprintNodeInfo]> nodes: [
        {
            node-id: "branch_1",
            title: "Branch",
            category: "Flow",
            element-type: "",
            descriptor-id: "flow.branch",

            x: 500.0,
            y: 150.0,

            is-event: false,
            is-bound-event: false,

            has-exec-input: true,

            exec-output-1: "True",
            exec-output-2: "False",
            exec-output-3: "",

            exec-output-1-connected: false,
            exec-output-2-connected: false,
            exec-output-3-connected: false,

            data-output-name: "",
            data-output-type: "",
            data-output-color: #000000,
            data-output-connected: false,

            data-input-name: "Condition",
            data-input-type: "bool",
            data-input-color: #5ac68b
        },
        {
            node-id: "node_1",
            title: "Get IsAlive",
            category: "Variables",
            element-type: "",
            descriptor-id: "variable.get",

            x: 100.0,
            y: 200.0,

            is-event: false,
            is-bound-event: false,

            has-exec-input: false,

            exec-output-1: "",
            exec-output-2: "",
            exec-output-3: "",

            exec-output-1-connected: false,
            exec-output-2-connected: false,
            exec-output-3-connected: false,

            data-output-name: "IsAlive",
            data-output-type: "bool",
            data-output-color: #5ac68b,
            data-output-connected: false,

            data-input-name: "",
            data-input-type: "",
            data-input-color: #000000
        },
        {
            node-id: "event_1",
            title: "",
            category: "Events",
            element-type: "BeginPlay",
            descriptor-id: "event.begin",

            x: 50.0,
            y: 50.0,

            is-event: true,
            is-bound-event: false,

            has-exec-input: false,

            exec-output-1: "execed",
            exec-output-2: "execed",
            exec-output-3: "execed",

            exec-output-1-connected: false,
            exec-output-2-connected: false,
            exec-output-3-connected: false,

            data-output-name: "",
            data-output-type: "",
            data-output-color: #000000,
            data-output-connected: false,

            data-input-name: "",
            data-input-type: "",
            data-input-color: #000000
        },
    ];
    in property <[BlueprintLinkInfo]> links: [];
    in property <[SelectionInfo]> scene-elements: [];
    in property <bool> grid-visible: true;
    in property <length> grid-size: 24px;
    in property <bool> ui-helpers-visible: true;

    callback node-selected(string, bool);
    callback node-moved(string, float, float);
    callback node-delete-requested(string);
    callback node-copy-requested(string);
    callback node-paste-requested(float, float);
    callback node-duplicate-requested(string, float, float);
    callback node-create-requested(string, float, float);
    callback node-bind-source-requested(string, string);
    callback connect-blueprint-nodes(string, string, int, float, float) -> bool;

    property <bool> is-panning: false;
    property <length> pan-start-x: 0px;
    property <length> pan-start-y: 0px;
    property <bool> view-initialized: false;
    property <float> min-zoom: 0.2;
    property <float> max-zoom: 4.0;
    property <string> selected-node-id: "";
    property <string> selected-node-ids: "|";
    property <string> copied-node-id: "";
    property <float> cursor-world-x: 0;
    property <float> cursor-world-y: 0;

    property <bool> is-marquee-armed: false;
    property <bool> is-marquee-active: false;
    property <float> marquee-start-x: 0;
    property <float> marquee-start-y: 0;
    property <float> marquee-current-x: 0;
    property <float> marquee-current-y: 0;

    property <bool> node-menu-open: false;
    property <length> node-menu-x: 0px;
    property <length> node-menu-y: 0px;
    property <string> node-menu-target-id: "";
    property <string> node-menu-target-descriptor-id: "";
    property <bool> node-menu-target-is-event: false;
    property <bool> node-menu-target-is-bound: false;

    property <bool> create-menu-open: false;
    property <length> create-menu-x: 0px;
    property <length> create-menu-y: 0px;
    property <float> create-menu-world-x: 0;
    property <float> create-menu-world-y: 0;
    property <string> create-menu-search: "";
    property <bool> all-nodes-open: false;
    property <bool> events-open: false;
    property <bool> ui-open: false;
    property <bool> pages-open: false;
    property <bool> flow-open: false;
    property <bool> network-open: false;
    property <bool> database-open: false;

    property <bool> dragging-node: false;
    property <string> drag-node-id: "";
    property <float> drag-start-node-x: 0;
    property <float> drag-start-node-y: 0;
    property <length> drag-start-pointer-x: 0px;
    property <length> drag-start-pointer-y: 0px;
    property <float> drag-live-x: 0;
    property <float> drag-live-y: 0;
    property <float> drag-delta-x: 0;
    property <float> drag-delta-y: 0;
    property <int> drag-commit-seq: 0;
    property <bool> skip-next-canvas-left-down: false;
    property <int> marquee-apply-seq: 0;

    property <bool> wire-active: false;
    property <float> wire-start-x: 0;
    property <float> wire-start-y: 0;
    property <float> wire-end-x: 0;
    property <float> wire-end-y: 0;
    property <bool> wire-has-elbow: false;
    property <float> wire-elbow-x: 0;
    property <float> wire-elbow-y: 0;
    property <bool> dragging-wire-elbow: false;
    property <string> wire-source-node-id: "";
    property <string> wire-source-kind: "exec";
    property <int> wire-source-slot: 0;
    property <color> wire-color: #ffffff;

    function world-x(screen-x: length) -> float {
        ((screen-x - root.offset-x) / 1px) / root.zoom-level
    }

    function world-y(screen-y: length) -> float {
        ((screen-y - root.offset-y) / 1px) / root.zoom-level
    }

    function screen-x(world: float) -> length {
        root.offset-x + world * root.zoom-level * 1px
    }

    function screen-y(world: float) -> length {
        root.offset-y + world * root.zoom-level * 1px
    }

    function absf(value: float) -> float {
        value < 0 ? -value : value
    }

    function smooth-control-offset(from-x: float, to-x: float) -> float {
        let distance = root.absf(to-x - from-x);
        let scaled = distance * 0.45;
        scaled < 36 ? 36 : scaled > 220 ? 220 : scaled
    }

    function smooth-curve-commands(from-x: float, from-y: float, to-x: float, to-y: float) -> string {
        let sx = root.screen-x(from-x) / 1px;
        let sy = root.screen-y(from-y) / 1px;
        let tx = root.screen-x(to-x) / 1px;
        let ty = root.screen-y(to-y) / 1px;
        let ctrl = root.smooth-control-offset(from-x, to-x) * root.zoom-level;
        "M "
            + sx + " " + sy
            + " C "
            + (sx + ctrl) + " " + sy + " "
            + (tx - ctrl) + " " + ty + " "
            + tx + " " + ty
    }

    function remember-pointer(screen-x: length, screen-y: length) {
        root.cursor-world-x = root.world-x(screen-x);
        root.cursor-world-y = root.world-y(screen-y);
        if root.wire-active {
            root.wire-end-x = root.cursor-world-x;
            root.wire-end-y = root.cursor-world-y;
            if root.dragging-wire-elbow {
                root.wire-elbow-x = root.cursor-world-x;
                root.wire-elbow-y = root.cursor-world-y;
            }
        }
    }

    function selection-token(node-id: string) -> string {
        "|" + node-id + "|"
    }

    function is-node-selected(node-id: string) -> bool {
        StringSearch.contains(root.selected-node-ids, root.selection-token(node-id))
    }

    function clear-selection() {
        root.selected-node-id = "";
        root.selected-node-ids = "|";
        root.node-selected("", false);
    }

    function append-selected-node(node-id: string) {
        if !root.is-node-selected(node-id) {
            root.selected-node-ids += node-id + "|";
        }
        if root.selected-node-id == "" {
            root.selected-node-id = node-id;
            root.node-selected(node-id, false);
        }
    }

    function select-node(node-id: string, additive: bool) {
        if !additive {
            root.selected-node-id = node-id;
            root.selected-node-ids = root.selection-token(node-id);
            root.node-selected(node-id, false);
            return;
        }
        root.append-selected-node(node-id);
    }

    function live-node-world-x(node-id: string, node-x: float) -> float {
        root.dragging-node && root.is-node-selected(node-id) ? node-x + root.drag-delta-x : node-x
    }

    function live-node-world-y(node-id: string, node-y: float) -> float {
        root.dragging-node && root.is-node-selected(node-id) ? node-y + root.drag-delta-y : node-y
    }

    function live-link-from-x(link: BlueprintLinkInfo) -> float {
        root.dragging-node && root.is-node-selected(link.from-node-id)
            ? link.from-x + root.drag-delta-x
            : link.from-x
    }

    function live-link-from-y(link: BlueprintLinkInfo) -> float {
        root.dragging-node && root.is-node-selected(link.from-node-id)
            ? link.from-y + root.drag-delta-y
            : link.from-y
    }

    function live-link-to-x(link: BlueprintLinkInfo) -> float {
        root.dragging-node && root.is-node-selected(link.to-node-id)
            ? link.to-x + root.drag-delta-x
            : link.to-x
    }

    function live-link-to-y(link: BlueprintLinkInfo) -> float {
        root.dragging-node && root.is-node-selected(link.to-node-id)
            ? link.to-y + root.drag-delta-y
            : link.to-y
    }

    function grid-spacing() -> length {
        root.grid-size * root.zoom-level
    }

    function can-bind-event-source(descriptor-id: string, element-type: string) -> bool {
        let type-name = element-type.to-lowercase();
        descriptor-id == "event.button" ? StringSearch.contains(type-name, "button")
            : descriptor-id == "event.input" ? (StringSearch.contains(type-name, "input") || StringSearch.contains(type-name, "textarea"))
            : descriptor-id == "event.checkbox" ? StringSearch.contains(type-name, "checkbox")
            : descriptor-id == "event.label" ? StringSearch.contains(type-name, "label")
            : descriptor-id == "event.fill" ? (
                StringSearch.contains(type-name, "text")
                    || StringSearch.contains(type-name, "textarea")
                    || StringSearch.contains(type-name, "label")
                    || StringSearch.contains(type-name, "div")
                    || StringSearch.contains(type-name, "container")
                    || StringSearch.contains(type-name, "image")
                    || StringSearch.contains(type-name, "fill")
            )
            : false
    }

    function grid-origin-x() -> length {
        let spacing = root.grid-spacing();
        let safe-spacing = spacing <= 0px ? 1px : spacing;
        root.offset-x - Math.floor((root.offset-x / 1px) / (safe-spacing / 1px)) * safe-spacing
    }

    function grid-origin-y() -> length {
        let spacing = root.grid-spacing();
        let safe-spacing = spacing <= 0px ? 1px : spacing;
        root.offset-y - Math.floor((root.offset-y / 1px) / (safe-spacing / 1px)) * safe-spacing
    }

    function close-menus() {
        root.create-menu-open = false;
        root.node-menu-open = false;
    }

    function open-create-menu(screen-x: length, screen-y: length) {
        root.node-menu-open = false;
        root.create-menu-open = true;
        root.create-menu-search = "";
        root.all-nodes-open = false;
        root.events-open = false;
        root.ui-open = false;
        root.pages-open = false;
        root.flow-open = false;
        root.network-open = false;
        root.database-open = false;
        root.create-menu-x = Math.max(0px, Math.min(root.width - 320px, screen-x));
        root.create-menu-y = Math.max(0px, Math.min(root.height - 420px, screen-y));
        root.create-menu-world-x = root.world-x(screen-x);
        root.create-menu-world-y = root.world-y(screen-y);
    }

    function create-node(descriptor-id: string) {
        root.node-create-requested(descriptor-id, root.create-menu-world-x, root.create-menu-world-y);
        root.create-menu-open = false;
    }

    function open-node-menu(node-id: string, descriptor-id: string, is-event: bool, is-bound: bool, screen-x: length, screen-y: length) {
        root.create-menu-open = false;
        root.node-menu-open = true;
        root.node-menu-target-id = node-id;
        root.node-menu-target-descriptor-id = descriptor-id;
        root.node-menu-target-is-event = is-event;
        root.node-menu-target-is-bound = is-bound;
        root.node-menu-x = Math.max(0px, Math.min(root.width - 230px, screen-x));
        root.node-menu-y = Math.max(0px, Math.min(root.height - 260px, screen-y));
    }

    function start-pan(pointer-x: length, pointer-y: length) {
        root.is-panning = true;
        root.pan-start-x = pointer-x;
        root.pan-start-y = pointer-y;
    }

    function update-pan(pointer-x: length, pointer-y: length) {
        if !root.is-panning {
            return;
        }

        let dx = pointer-x - root.pan-start-x;
        let dy = pointer-y - root.pan-start-y;
        root.offset-x += dx;
        root.offset-y += dy;
        root.pan-start-x = pointer-x;
        root.pan-start-y = pointer-y;
    }

    function stop-pan() {
        root.is-panning = false;
    }

    function zoom-at-cursor(cursor-x: length, cursor-y: length, delta-y: length) {
        let prev-zoom = root.zoom-level;
        let next-zoom = delta-y < 0px
            ? Math.max(root.min-zoom, Math.min(root.max-zoom, prev-zoom / 1.1))
            : delta-y > 0px
                ? Math.max(root.min-zoom, Math.min(root.max-zoom, prev-zoom * 1.1))
                : prev-zoom;

        if next-zoom == prev-zoom {
            return;
        }

        let world-x = ((cursor-x - root.offset-x) / 1px) / prev-zoom;
        let world-y = ((cursor-y - root.offset-y) / 1px) / prev-zoom;
        root.offset-x = ((cursor-x / 1px) - world-x * next-zoom) * 1px;
        root.offset-y = ((cursor-y / 1px) - world-y * next-zoom) * 1px;
        root.zoom-level = next-zoom;
    }

    public function reset-view() {
        root.zoom-level = 1.0;
        root.offset-x = root.width / 2;
        root.offset-y = root.height / 2;
    }

    public function visible-center-world-x() -> float {
        root.world-x(root.width / 2)
    }

    public function visible-center-world-y() -> float {
        root.world-y(root.height / 2)
    }

    public function delete-selected-node() {
        if root.selected-node-id != "" {
            root.node-delete-requested(root.selected-node-id);
            root.clear-selection();
        }
    }

    public function copy-selected-node() {
        if root.selected-node-id != "" {
            root.copied-node-id = root.selected-node-id;
            root.node-copy-requested(root.selected-node-id);
        }
    }

    public function paste-node-at-cursor() {
        if root.copied-node-id != "" {
            root.node-duplicate-requested(root.copied-node-id, root.cursor-world-x, root.cursor-world-y);
        } else {
            root.node-paste-requested(root.cursor-world-x, root.cursor-world-y);
        }
    }

    changed width => {
        if !root.view-initialized && root.width > 0px && root.height > 0px {
            root.view-initialized = true;
            root.reset-view();
        }
    }

    changed height => {
        if !root.view-initialized && root.width > 0px && root.height > 0px {
            root.view-initialized = true;
            root.reset-view();
        }
    }

    background: Themes.canvas-bg;
    clip: true;

    if root.grid-visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        for i in Math.floor(parent.width / root.grid-spacing()) + 3 : Rectangle {
            x: root.grid-origin-x() - root.grid-spacing() + i * root.grid-spacing();
            y: 0;
            width: 1px;
            height: parent.height;
            background: Themes.canvas-grid-color;
        }

        for j in Math.floor(parent.height / root.grid-spacing()) + 3 : Rectangle {
            x: 0;
            y: root.grid-origin-y() - root.grid-spacing() + j * root.grid-spacing();
            width: parent.width;
            height: 1px;
            background: Themes.canvas-grid-color;
        }
    }

    TouchArea {
        z: 1;
        width: parent.width;
        height: parent.height;
        mouse-cursor: root.is-panning ? MouseCursor.grabbing : MouseCursor.default;
        double-clicked => {
            if root.wire-active {
                root.wire-has-elbow = true;
                root.wire-elbow-x = root.cursor-world-x;
                root.wire-elbow-y = root.cursor-world-y;
                root.dragging-wire-elbow = true;
            }
        }

        scroll-event(event) => {
            if event.modifiers.control {
                root.zoom-at-cursor(self.mouse-x, self.mouse-y, event.delta-y);
                return accept;
            }
            reject
        }

        pointer-event(ev) => {
            root.remember-pointer(self.mouse-x, self.mouse-y);
            if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.middle {
                root.start-pan(self.mouse-x, self.mouse-y);
                root.close-menus();
            } else if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right {
                root.open-create-menu(self.mouse-x, self.mouse-y);
            } else if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                if root.skip-next-canvas-left-down {
                    root.skip-next-canvas-left-down = false;
                    return;
                }
                root.close-menus();
                root.is-marquee-armed = true;
                root.is-marquee-active = false;
                root.marquee-start-x = root.cursor-world-x;
                root.marquee-start-y = root.cursor-world-y;
                root.marquee-current-x = root.cursor-world-x;
                root.marquee-current-y = root.cursor-world-y;
                root.clear-selection();
            }

            if ev.kind == PointerEventKind.move {
                root.update-pan(self.mouse-x, self.mouse-y);
                if root.is-marquee-armed {
                    root.marquee-current-x = root.cursor-world-x;
                    root.marquee-current-y = root.cursor-world-y;
                    if Math.abs(root.marquee-current-x - root.marquee-start-x) > 4
                        || Math.abs(root.marquee-current-y - root.marquee-start-y) > 4 {
                        root.is-marquee-active = true;
                    }
                }
            }

            if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.middle {
                root.stop-pan();
            }
            if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                if root.wire-active {
                    root.open-create-menu(self.mouse-x, self.mouse-y);
                    root.wire-active = false;
                    root.dragging-wire-elbow = false;
                }
                if root.is-marquee-active {
                    root.selected-node-id = "";
                    root.selected-node-ids = "|";
                    root.marquee-apply-seq += 1;
                    if root.selected-node-id == "" {
                        root.node-selected("", false);
                    }
                }
                root.is-marquee-armed = false;
                root.is-marquee-active = false;
            }
            if ev.kind == PointerEventKind.cancel {
                root.stop-pan();
                root.is-marquee-armed = false;
                root.is-marquee-active = false;
                root.wire-active = false;
                root.dragging-wire-elbow = false;
            }
        }
    }

    for node in root.nodes: BlueprintNodeCard {
        z: 20;
        node-id: node.node-id;
        title: node.title;
        element-type: node.element-type;
        descriptor-id: node.descriptor-id;
        is-event: node.is-event;
        is-bound-event: node.is-bound-event;
        has-exec-input: node.has-exec-input;
        exec-output-1: node.exec-output-1;
        exec-output-2: node.exec-output-2;
        exec-output-3: node.exec-output-3;
        exec-output-1-connected: node.exec-output-1-connected;
        exec-output-2-connected: node.exec-output-2-connected;
        exec-output-3-connected: node.exec-output-3-connected;
        data-output-name: node.data-output-name;
        data-output-type: node.data-output-type;
        data-output-color: node.data-output-color;
        data-output-connected: node.data-output-connected;
        data-input-name: node.data-input-name;
        data-input-type: node.data-input-type;
        clip: false;
        data-input-color: node.data-input-color;
        world-x: node.x;
        world-y: node.y;
        live-world-x: root.live-node-world-x(node.node-id, node.x);
        live-world-y: root.live-node-world-y(node.node-id, node.y);
        screen-x: root.screen-x(root.live-node-world-x(node.node-id, node.x));
        screen-y: root.screen-y(root.live-node-world-y(node.node-id, node.y));
        zoom-level: root.zoom-level;
        is-selected: root.is-node-selected(node.node-id);
        drag-delta-x: root.drag-delta-x;
        drag-delta-y: root.drag-delta-y;
        drag-commit-seq: root.drag-commit-seq;
        marquee-min-x: Math.min(root.marquee-start-x, root.marquee-current-x);
        marquee-max-x: Math.max(root.marquee-start-x, root.marquee-current-x);
        marquee-min-y: Math.min(root.marquee-start-y, root.marquee-current-y);
        marquee-max-y: Math.max(root.marquee-start-y, root.marquee-current-y);
        marquee-apply-seq: root.marquee-apply-seq;

        consume-canvas-left-down => {
            root.skip-next-canvas-left-down = true;
        }
        node-select-requested(node-id, additive) => {
            root.select-node(node-id, additive);
        }
        node-menu-requested(node-id, descriptor-id, is-event, is-bound, screen-x, screen-y) => {
            if !root.is-node-selected(node-id) {
                root.select-node(node-id, false);
            }
            root.open-node-menu(node-id, descriptor-id, is-event, is-bound, screen-x, screen-y);
        }
        node-drag-started(node-id, world-x, world-y, pointer-x, pointer-y, additive) => {
            root.close-menus();
            if !root.is-node-selected(node-id) {
                root.select-node(node-id, additive);
            }
            root.dragging-node = true;
            root.drag-node-id = node-id;
            root.drag-start-node-x = world-x;
            root.drag-start-node-y = world-y;
            root.drag-live-x = world-x;
            root.drag-live-y = world-y;
            root.drag-start-pointer-x = pointer-x;
            root.drag-start-pointer-y = pointer-y;
            root.drag-delta-x = 0;
            root.drag-delta-y = 0;
        }
        node-drag-updated(pointer-x, pointer-y) => {
            if !root.dragging-node {
                return;
            }
            root.drag-delta-x = ((pointer-x - root.drag-start-pointer-x) / 1px) / root.zoom-level;
            root.drag-delta-y = ((pointer-y - root.drag-start-pointer-y) / 1px) / root.zoom-level;
            root.drag-live-x = root.drag-start-node-x + root.drag-delta-x;
            root.drag-live-y = root.drag-start-node-y + root.drag-delta-y;
        }
        node-drag-finished => {
            if root.dragging-node {
                root.drag-commit-seq += 1;
            }
            root.dragging-node = false;
            root.drag-node-id = "";
        }
        node-drag-cancelled => {
            root.dragging-node = false;
            root.drag-node-id = "";
            root.drag-delta-x = 0;
            root.drag-delta-y = 0;
        }
        wire-started(node-id, source-kind, source-slot, wire-color, pointer-x, pointer-y) => {
            root.wire-active = true;
            root.wire-source-node-id = node-id;
            root.wire-source-kind = source-kind;
            root.wire-source-slot = source-slot;
            root.wire-color = wire-color;
            root.wire-has-elbow = false;
            root.dragging-wire-elbow = false;
            root.remember-pointer(pointer-x, pointer-y);
            root.wire-start-x = root.cursor-world-x;
            root.wire-start-y = root.cursor-world-y;
            root.wire-end-x = root.cursor-world-x;
            root.wire-end-y = root.cursor-world-y;
        }
        wire-updated(pointer-x, pointer-y) => {
            if !root.wire-active {
                return;
            }
            root.remember-pointer(pointer-x, pointer-y);
        }
        wire-released(pointer-x, pointer-y) => {
            if !root.wire-active {
                return;
            }
            root.remember-pointer(pointer-x, pointer-y);
            let connected = root.connect-blueprint-nodes(
                root.wire-source-node-id,
                root.wire-source-kind,
                root.wire-source-slot,
                root.cursor-world-x,
                root.cursor-world-y
            );
            if !connected {
                root.open-create-menu(pointer-x, pointer-y);
            }
            root.wire-active = false;
            root.dragging-wire-elbow = false;
            root.wire-source-node-id = "";
            root.wire-source-kind = "exec";
            root.wire-source-slot = 0;
            root.wire-color = #ffffff;
        }
        node-moved-requested(node-id, x, y) => {
            root.node-moved(node-id, x, y);
        }
        marquee-hit(node-id) => {
            root.append-selected-node(node-id);
        }
    }

    for link in root.links: Path {
        z: 18;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: parent.width / 1px;
        viewbox-height: parent.height / 1px;
        stroke: link.link-color;
        stroke-width: 2px;
        fill: transparent;
        commands: root.smooth-curve-commands(
            root.live-link-from-x(link),
            root.live-link-from-y(link),
            root.live-link-to-x(link),
            root.live-link-to-y(link)
        );
    }

    if root.wire-active: Path {
        z: 40;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: parent.width / 1px;
        viewbox-height: parent.height / 1px;
        stroke: root.wire-color;
        stroke-width: 2px;
        fill: transparent;
        commands: !root.wire-has-elbow
            ? root.smooth-curve-commands(
                root.wire-start-x,
                root.wire-start-y,
                root.wire-end-x,
                root.wire-end-y
            )
            : "M "
                + (root.screen-x(root.wire-start-x) / 1px) + " "
                + (root.screen-y(root.wire-start-y) / 1px) + " L "
                + (root.screen-x(root.wire-elbow-x) / 1px) + " "
                + (root.screen-y(root.wire-start-y) / 1px) + " L "
                + (root.screen-x(root.wire-elbow-x) / 1px) + " "
                + (root.screen-y(root.wire-elbow-y) / 1px) + " L "
                + (root.screen-x(root.wire-end-x) / 1px) + " "
                + (root.screen-y(root.wire-elbow-y) / 1px) + " L "
                + (root.screen-x(root.wire-end-x) / 1px) + " "
                + (root.screen-y(root.wire-end-y) / 1px);
    }

    if root.wire-active && root.wire-has-elbow: Rectangle {
        z: 41;
        x: root.screen-x(root.wire-elbow-x) - 5px;
        y: root.screen-y(root.wire-elbow-y) - 5px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: #ffffff;
        border-width: 1px;
        border-color: Themes.current.border-color;

        TouchArea {
            mouse-cursor: MouseCursor.move;
            pointer-event(ev) => {
                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                    root.dragging-wire-elbow = true;
                }
                if ev.kind == PointerEventKind.move && root.dragging-wire-elbow {
                    root.remember-pointer(parent.x + self.mouse-x, parent.y + self.mouse-y);
                }
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.dragging-wire-elbow = false;
                }
                if ev.kind == PointerEventKind.cancel {
                    root.dragging-wire-elbow = false;
                }
            }
        }
    }

    if root.is-marquee-active: Rectangle {
        z: 45;
        x: root.screen-x(Math.min(root.marquee-start-x, root.marquee-current-x));
        y: root.screen-y(Math.min(root.marquee-start-y, root.marquee-current-y));
        width: Math.abs(root.marquee-current-x - root.marquee-start-x) * root.zoom-level * 1px;
        height: Math.abs(root.marquee-current-y - root.marquee-start-y) * root.zoom-level * 1px;
        border-width: 1px;
        border-color: Themes.selection-border;
        background: Themes.selection-fill;
        border-radius: 2px;
    }

    if root.create-menu-open: Rectangle {
        z: 100;
        x: root.create-menu-x;
        y: root.create-menu-y;
        width: 250px;
        height: 300px;
        border-radius: 7px;
        border-width: 1px;
        border-color: Themes.current.border-color;
        background: Themes.secondary-background-transparent;
        drop-shadow-blur: Themes.shadow-size;
        drop-shadow-color: Themes.shadow-color;

        VerticalBox {
            padding: 8px;
            spacing: 6px;

            Rectangle {
                height: 32px;
                border-radius: 5px;
                border-width: 1px;
                border-color: Themes.current.border-color;
                background: Themes.current.primary-bg;

                create-search := TextInput {
                    x: 8px;
                    y: 8px;
                    width: parent.width - 16px;
                    text <=> root.create-menu-search;
                    color: Themes.current.primary-text;
                    font-size: 12px;
                    height: 20px;
                    single-line: true;
                    selection-background-color: Themes.current.active-color;
                    selection-foreground-color: Themes.on-accent-text;
                    init => { self.focus(); }
                }
            }

            Flickable {
                vertical-stretch: 1;
                viewport-width: self.width;
                viewport-height: menu-content.preferred-height;

                menu-content := VerticalBox {
                    spacing: 4px;
                    padding: 0;

                    MenuGroupHeader { title: "All Nodes"; expanded <=> root.all-nodes-open; }
                    if root.all-nodes-open || root.create-menu-search != "": VerticalBox {
                        spacing: 2px;
                        NodeMenuRow { title: "Event Button"; descriptor-id: "event.button"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event Input"; descriptor-id: "event.input"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event Checkbox"; descriptor-id: "event.checkbox"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event Label"; descriptor-id: "event.label"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Navigate Page"; descriptor-id: "page.navigate"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Set Opacity"; descriptor-id: "ui.set_opacity"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Set Display Mode"; descriptor-id: "ui.set_display_mode"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Branch"; descriptor-id: "flow.branch"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "HTTP Request"; descriptor-id: "network.request"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Database Query"; descriptor-id: "db.query"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                    }

                    Separator-H {}

                    MenuGroupHeader { title: "Events"; expanded <=> root.events-open; }
                    if root.events-open || root.create-menu-search != "": VerticalBox {
                        spacing: 2px;
                        NodeMenuRow { title: "Event Button"; descriptor-id: "event.button"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event Input"; descriptor-id: "event.input"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event Checkbox"; descriptor-id: "event.checkbox"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event Label"; descriptor-id: "event.label"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event Fill"; descriptor-id: "event.fill"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event App Started"; descriptor-id: "event.app_started"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event App Started Delayed"; descriptor-id: "event.app_started_delayed"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Event Page Changed"; descriptor-id: "event.page_changed"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                    }

                    MenuGroupHeader { title: "UI"; expanded <=> root.ui-open; }
                    if root.ui-open || root.create-menu-search != "": VerticalBox {
                        spacing: 2px;
                        NodeMenuRow { title: "Set Opacity"; descriptor-id: "ui.set_opacity"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                        NodeMenuRow { title: "Set Display Mode"; descriptor-id: "ui.set_display_mode"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                    }

                    MenuGroupHeader { title: "Pages"; expanded <=> root.pages-open; }
                    if root.pages-open || root.create-menu-search != "": NodeMenuRow { title: "Navigate Page"; descriptor-id: "page.navigate"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }

                    MenuGroupHeader { title: "Flow"; expanded <=> root.flow-open; }
                    if root.flow-open || root.create-menu-search != "": NodeMenuRow { title: "Branch"; descriptor-id: "flow.branch"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }

                    MenuGroupHeader { title: "Network"; expanded <=> root.network-open; }
                    if root.network-open || root.create-menu-search != "": NodeMenuRow { title: "HTTP Request"; descriptor-id: "network.request"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }

                    MenuGroupHeader { title: "Database"; expanded <=> root.database-open; }
                    if root.database-open || root.create-menu-search != "": NodeMenuRow { title: "Database Query"; descriptor-id: "db.query"; query: root.create-menu-search; selected(id) => { root.create-node(id); } }
                }
            }
        }
    }

    if root.node-menu-open: Rectangle {
        z: 110;
        x: root.node-menu-x;
        y: root.node-menu-y;
        width: 230px;
        height: root.node-menu-target-is-event && !root.node-menu-target-is-bound ? 252px : 132px;
        border-radius: 7px;
        border-width: 1px;
        border-color: Themes.current.border-color;
        background: Themes.secondary-background-transparent;
        drop-shadow-blur: Themes.shadow-size;
        drop-shadow-color: Themes.shadow-color;

        VerticalBox {
            padding: 6px;
            spacing: 4px;

            if root.node-menu-target-is-event && root.node-menu-target-is-bound: NodeContextAction {
                title: "Change event source";
                selected => { }
            }

            if root.node-menu-target-is-event && !root.node-menu-target-is-bound: Text {
                height: 24px;
                text: "Bind to scene object";
                color: Themes.current.secondary-text;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: TextVerticalAlignment.center;
            }

            if root.node-menu-target-is-event && !root.node-menu-target-is-bound: Flickable {
                height: 116px;
                viewport-width: self.width;
                viewport-height: bind-list.preferred-height;

                bind-list := VerticalBox {
                    spacing: 2px;

                    for element in root.scene-elements: NodeContextAction {
                        visible: root.can-bind-event-source(root.node-menu-target-descriptor-id, element.element-type);
                        height: self.visible ? 26px : 0px;
                        title: element.element-name == "" ? element.element-type : element.element-name;
                        selected => {
                            root.node-bind-source-requested(root.node-menu-target-id, element.element-id);
                            root.node-menu-open = false;
                        }
                    }
                }
            }

            if root.node-menu-target-is-event: Separator-H {}

            NodeContextAction {
                title: "Copy";
                selected => {
                    root.copied-node-id = root.node-menu-target-id;
                    root.node-copy-requested(root.node-menu-target-id);
                    root.node-menu-open = false;
                }
            }

            NodeContextAction {
                title: "Delete";
                selected => {
                    root.node-delete-requested(root.node-menu-target-id);
                    root.node-menu-open = false;
                }
            }
        }
    }

    if root.ui-helpers-visible: CanvasZoomControls {
        z: 120;
        x: 12px;
        y: parent.height - self.height - 12px;
        zoom-level: root.zoom-level;
        zoom-out-requested => { root.zoom-at-cursor(root.width / 2, root.height / 2, -1px); }
        zoom-in-requested => { root.zoom-at-cursor(root.width / 2, root.height / 2, 1px); }
        reset-view-requested => { root.reset-view(); }
    }
}
