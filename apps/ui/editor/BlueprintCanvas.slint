                        NodeMenuRow { title: "Int / Float"; descriptor-id: "math.int_float.div"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Int % Float"; descriptor-id: "math.int_float.mod"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Int ^ Float"; descriptor-id: "math.int_float.pow"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "String Concat"; descriptor-id: "string.concat"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                    }

                    if root.create-menu-search == "": MenuGroupHeader { title: "Conditions"; expanded <=> root.conditions-open; }
                    if root.conditions-open && root.create-menu-search == "": VerticalBox {
                        spacing: 2px;
                        NodeMenuRow { title: "Greater Than"; descriptor-id: "compare.gt"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Less Than"; descriptor-id: "compare.lt"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Greater Or Equal"; descriptor-id: "compare.gte"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Less Or Equal"; descriptor-id: "compare.lte"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Equal"; descriptor-id: "compare.eq"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Not Equal"; descriptor-id: "compare.neq"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                    }

                    if root.create-menu-search == "": MenuGroupHeader { title: "Variables"; expanded <=> root.variables-open; }
                    if root.variables-open && root.create-menu-search == "": VerticalBox {
                        spacing: 2px;
                        NodeMenuRow { title: "Get Variable (Dynamic)"; descriptor-id: "variables.get_dynamic"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Set Variable (Dynamic)"; descriptor-id: "variables.set_dynamic"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                    }

                    if root.create-menu-search == "": MenuGroupHeader { title: "Functions"; expanded <=> root.functions-open; }
                    if root.functions-open && root.create-menu-search == "": NodeMenuRow { title: "Function Return"; descriptor-id: "functions.return"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }

                    if root.create-menu-search == "": MenuGroupHeader { title: "Types"; expanded <=> root.types-open; }
                    if root.types-open && root.create-menu-search == "": VerticalBox {
                        spacing: 2px;
                        NodeMenuRow { title: "Struct Make"; descriptor-id: "types.struct_make"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                        NodeMenuRow { title: "Enum Value"; descriptor-id: "types.enum_value"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                    }

                    if root.create-menu-search == "": MenuGroupHeader { title: "Network"; expanded <=> root.network-open; }
                    if root.network-open && root.create-menu-search == "": NodeMenuRow { title: "HTTP Request"; descriptor-id: "network.request"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }

                    if root.create-menu-search == "": MenuGroupHeader { title: "Database"; expanded <=> root.database-open; }
                    if root.database-open && root.create-menu-search == "": NodeMenuRow { title: "Database Query"; descriptor-id: "db.query"; query: root.create-menu-search; selected(id) => { root.create-node(id); } tooltip-requested(text, row-y) => { root.open-create-menu-tooltip(text, row-y); } tooltip-cleared => { root.close-create-menu-tooltip(); } }
                }
            }
        }
    }

    if root.create-menu-open && root.create-menu-tooltip-open: Rectangle {
        z: 130;
        x: Math.max(0px, Math.min(root.width - 270px, root.create-menu-x + 258px));
        y: Math.max(0px, Math.min(root.height - 78px, root.create-menu-y + 46px + root.create-menu-tooltip-y));
        width: 260px;
        height: 70px;
        border-radius: 6px;
        border-width: 1px;
        border-color: Themes.current.border-color;
        background: Themes.secondary-background-transparent;
        drop-shadow-blur: Themes.shadow-size;
        drop-shadow-color: Themes.shadow-color;

        Text {
            x: 10px;
            y: 8px;
            width: parent.width - 20px;
            height: parent.height - 16px;
            text: root.create-menu-tooltip-text;
            color: Themes.current.primary-text;
            font-size: 11px;
            wrap: word-wrap;
            vertical-alignment: TextVerticalAlignment.center;
        }
    }

    if root.node-menu-open: Rectangle {
        z: 110;
        x: root.node-menu-x;
        y: root.node-menu-y;
        width: 230px;
        height: root.node-menu-target-is-event && !root.node-menu-target-is-bound
            ? 252px
            : root.node-menu-target-descriptor-id == "variable.get" && root.node-menu-target-data-output-type == "Object" && root.node-menu-object-open
                ? 320px
                : root.node-menu-target-descriptor-id == "variable.get" && root.node-menu-target-data-output-type == "Object"
                    ? 168px
                    : 132px;
        border-radius: 7px;
        border-width: 1px;
        border-color: Themes.current.border-color;
        background: Themes.secondary-background-transparent;
        drop-shadow-blur: Themes.shadow-size;
        drop-shadow-color: Themes.shadow-color;

        VerticalBox {
            padding: 6px;
            spacing: 4px;

            if root.node-menu-target-is-event && root.node-menu-target-is-bound: NodeContextAction {
                title: "Change event source";
                selected => { }
            }

            if root.node-menu-target-is-event && !root.node-menu-target-is-bound: Text {
                height: 24px;
                text: "Bind to scene object";
                color: Themes.current.secondary-text;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: TextVerticalAlignment.center;
            }

            if root.node-menu-target-is-event && !root.node-menu-target-is-bound: Flickable {
                height: 116px;
                viewport-width: self.width;
                viewport-height: bind-list.preferred-height;

                bind-list := VerticalBox {
                    spacing: 2px;

                    for element in root.scene-elements: NodeContextAction {
                        visible: root.can-bind-event-source(root.node-menu-target-descriptor-id, element.element-type);
                        height: self.visible ? 26px : 0px;
                        title: element.element-name == "" ? element.element-type : element.element-name;
                        selected => {
                            root.node-bind-source-requested(root.node-menu-target-id, element.element-id);
                            root.node-menu-open = false;
                        }
                    }
                }
            }

            if root.node-menu-target-is-event: Separator-H {}

            if root.node-menu-target-descriptor-id == "variable.get" && root.node-menu-target-data-output-type == "Object": NodeContextAction {
                title: root.node-menu-object-open ? "Hide objects" : "Choose object";
                selected => {
                    root.node-menu-object-open = !root.node-menu-object-open;
                }
            }

            if root.node-menu-target-descriptor-id == "variable.get" && root.node-menu-target-data-output-type == "Object" && root.node-menu-object-open: Flickable {
                height: 152px;
                viewport-width: self.width;
                viewport-height: object-list.preferred-height;

                object-list := VerticalBox {
                    spacing: 2px;

                    Text {
                        height: 20px;
                        text: "Pages";
                        color: Themes.current.secondary-text;
                        font-size: 11px;
                        font-weight: 700;
                        vertical-alignment: TextVerticalAlignment.center;
                    }

                    for page in root.page-items: NodeContextAction {
                        title: page.page-name;
                        selected => {
                            root.node-set-object-requested(
                                root.node-menu-target-variable-id,
                                "page",
                                page.page-id,
                                page.page-name
                            );
                            root.node-menu-open = false;
                        }
                    }
                }
            }

            NodeContextAction {
                title: "Copy";
                selected => {
                    root.copied-node-id = root.node-menu-target-id;
                    root.node-copy-requested(root.node-menu-target-id);
                    root.node-menu-open = false;
                }
            }

            NodeContextAction {
                title: "Delete";
                selected => {
                    root.node-delete-requested(root.node-menu-target-id);
                    root.node-menu-open = false;
                }
            }
        }
    }

    if root.input-object-menu-open: Rectangle {
        z: 140;
        x: root.input-object-menu-x;
        y: root.input-object-menu-y;
        width: 210px;
        height: 190px;
        border-radius: 6px;
        border-width: 1px;
        border-color: Themes.current.border-color;
        background: Themes.secondary-background-transparent;
        drop-shadow-blur: Themes.shadow-size;
        drop-shadow-color: Themes.shadow-color;
        clip: true;

        Flickable {
            x: 6px;
            y: 6px;
            width: parent.width - 12px;
            height: parent.height - 12px;
            viewport-width: self.width;
            viewport-height: object-input-list.preferred-height;

            object-input-list := VerticalBox {
                spacing: 2px;

                NodeContextAction {
                    title: "None";
                    selected => {
                        root.node-input-value-changed(root.input-object-menu-node-id, root.input-object-menu-slot, "");
                        root.input-object-menu-open = false;
                    }
                }

                Text {
                    visible: root.input-object-menu-type == "object" || root.input-object-menu-type == "page";
                    height: self.visible ? 18px : 0px;
                    text: "Pages";
                    color: Themes.current.secondary-text;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: TextVerticalAlignment.center;
                }

                for page in root.page-items: NodeContextAction {
                    visible: root.input-object-menu-type == "object" || root.input-object-menu-type == "page";
                    height: self.visible ? 28px : 0px;
                    title: page.page-name;
                    selected => {
                        root.node-input-value-changed(
                            root.input-object-menu-node-id,
                            root.input-object-menu-slot,
                            root.input-object-menu-type == "page" ? page.page-id : "{\"kind\":\"page\",\"id\":\"" + page.page-id + "\",\"name\":\"" + page.page-name + "\"}"
                        );
                        root.input-object-menu-open = false;
                    }
                }

                Text {
                    visible: root.input-object-menu-type == "object" || root.input-object-menu-type == "element";
                    height: self.visible ? 18px : 0px;
                    text: "Elements";
                    color: Themes.current.secondary-text;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: TextVerticalAlignment.center;
                }

                for element in root.scene-elements: NodeContextAction {
                    visible: root.input-object-menu-type == "object" || root.input-object-menu-type == "element";
                    height: self.visible ? 28px : 0px;
                    title: element.element-name == "" ? element.element-type : element.element-name;
                    selected => {
                        root.node-input-value-changed(
                            root.input-object-menu-node-id,
                            root.input-object-menu-slot,
                            root.input-object-menu-type == "element" ? element.element-id : "{\"kind\":\"element\",\"id\":\"" + element.element-id + "\",\"name\":\"" + (element.element-name == "" ? element.element-type : element.element-name) + "\"}"
                        );
                        root.input-object-menu-open = false;
                    }
                }
            }
        }
    }

    if root.ui-helpers-visible: CanvasZoomControls {
        z: 120;
        x: 12px;
        y: parent.height - self.height - 12px;
        zoom-level: root.zoom-level;
        zoom-out-requested => { root.zoom-at-cursor(root.width / 2, root.height / 2, -1px); }
        zoom-in-requested => { root.zoom-at-cursor(root.width / 2, root.height / 2, 1px); }
        reset-view-requested => { root.reset-view(); }
    }
}

