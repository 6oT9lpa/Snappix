// Иконки компонентов для библиотеки и canvas

import { Themes } from "../../components/Themes.slint";

// === Layout Container Icons ===

/// Иконка Flex контейнера
export component IconFlexContainer inherits Path {
    width: 16px;
    height: 16px;
    stroke: Themes.current.primary-text;
    stroke-width: 1px;
    fill: transparent;
    commands: "M 0 2 L 16 2 M 0 8 L 16 8 M 0 14 L 16 14 M 4 0 L 4 4 M 12 6 L 12 10 M 4 12 L 4 16";
}

/// Иконка Grid контейнера
export component IconGridContainer inherits Path {
    width: 16px;
    height: 16px;
    stroke: Themes.current.primary-text;
    stroke-width: 1px;
    fill: transparent;
    commands: "M 0 0 L 16 0 L 16 16 L 0 16 Z M 0 5.5 L 16 5.5 M 0 11 L 16 11 M 5.5 0 L 5.5 16 M 11 0 L 11 16";
}

/// Иконка Stack контейнера
export component IconStackContainer inherits Path {
    width: 16px;
    height: 16px;
    stroke: Themes.current.primary-text;
    stroke-width: 1px;
    fill: transparent;
    commands: "M 2 2 L 14 2 L 14 6 L 2 6 Z M 4 7 L 16 7 L 16 11 L 4 11 Z M 2 12 L 14 12 L 14 16 L 2 16 Z";
}

