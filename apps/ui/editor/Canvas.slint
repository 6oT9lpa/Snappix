                if root.editing-text-element-id == element.element-id && root.freeform-text-edit-active: label-text-editor := TextInput {
                    text <=> root.editing-freeform-text;
                    color: element.text-color;
                    font-size: element.font-size * root.current-zoom * 1px;
                    font-family: element.font-family;
                    x: 4px;
                    y: 4px;
                    width: parent.width - 8px;
                    height: parent.height - 8px;
                    init => {
                        self.focus();
                        self.select-all();
                    }
                    accepted => { root.finish-active-text-edit(true); }
                    edited => {
                        root.freeform-text-dirty = true;
                    }
                }

                if root.editing-text-element-id != element.element-id: Text {
                    text: element.text-content;
                    color: element.text-color;
                    font-size: element.font-size * root.current-zoom * 1px;
                    font-family: element.font-family;
                    x: 4px;
                    y: (parent.height - self.height) / 2;
                    width: parent.width - 8px;
                    overflow: elide;
                }
            }

            if element.element-type == "button": Text {
                text: element.text-content;
                color: element.text-color;
                font-size: element.font-size * root.current-zoom * 1px;
                font-family: element.font-family;
                wrap: is-nowrap-text ? no-wrap : word-wrap;
                horizontal-alignment: TextHorizontalAlignment.center;
                vertical-alignment: TextVerticalAlignment.center;
            }

            if (element.element-type == "input" || element.element-type == "textarea") && root.editing-text-element-id == element.element-id: TextInput {
                property <bool> is-multiline: element.element-type == "textarea";
                text: element.text-content;
                color: element.text-color;
                font-size: element.font-size * root.current-zoom * 1px;
                font-family: element.font-family;
                width: parent.width - 12px;
                x: 6px;
                y: is-multiline ? 6px : 5px;
                height: is-multiline ? parent.height - 12px : parent.height - 10px;
                edited => {
                    root.element-text-edited(element.element-id, self.text);
                }
                accepted => {
                    if !is-multiline {
                        root.finish-active-text-edit(false);
                    }
                }
            }

            if element.element-type == "input" && root.editing-text-element-id != element.element-id: Text {
                text: element.text-content == "" ? (element.placeholder == "" ? I18n.t("Input") : element.placeholder) : element.text-content;
                color: element.text-content == "" ? Themes.current.secondary-text : element.text-color;
                font-size: element.font-size * root.current-zoom * 1px;
                font-family: element.font-family;
                x: 8px;
                y: (parent.height - self.height) / 2;
                overflow: elide;
            }

            if element.element-type == "textarea" && root.editing-text-element-id != element.element-id: Text {
                text: element.text-content == "" ? (element.placeholder == "" ? I18n.t("Textarea") : element.placeholder) : element.text-content;
                color: element.text-content == "" ? Themes.current.secondary-text : element.text-color;
                font-size: element.font-size * root.current-zoom * 1px;
                font-family: element.font-family;
                x: 8px;
                y: 8px;
                width: parent.width - 12px;
                height: parent.height - 12px;
                wrap: is-nowrap-text ? no-wrap : word-wrap;
            }

            if element.element-type == "checkbox": Rectangle {
                background: transparent;

                property <bool> checkbox-box-right: element.checkbox-box-side == "right";
                property <bool> checkbox-space-between: element.checkbox-space-between;
                property <length> checkbox-padding: 6px * root.current-zoom;
                property <length> checkbox-gap: 6px * root.current-zoom;
                property <length> checkbox-box-size: Math.max(
                    12px * root.current-zoom,
                    Math.min(
                        18px * root.current-zoom,
                        parent.height - 8px * root.current-zoom
                    )
                );
                property <length> checkbox-box-x: checkbox-box-right
                    ? parent.width - checkbox-padding - checkbox-box-size
                    : checkbox-padding;
                property <length> checkbox-label-x: checkbox-box-right
                    ? checkbox-padding
                    : checkbox-box-x + checkbox-box-size + checkbox-gap;
                property <length> checkbox-label-width: checkbox-box-right
                    ? Math.max(0px, checkbox-box-x - checkbox-gap - checkbox-padding)
                    : Math.max(0px, parent.width - checkbox-label-x - checkbox-padding);

                Rectangle {
                    x: parent.checkbox-box-x;
                    y: (parent.height - parent.checkbox-box-size) / 2;
                    width: parent.checkbox-box-size;
                    height: parent.checkbox-box-size;
                    border-width: Math.max(0px, element.checkbox-box-border-width * root.current-zoom * 1px);
                    border-color: element.checkbox-box-border-color;
                    border-radius: 3px;
                    background: element.checkbox-box-color;

                    if element.checked: Path {
                        x: 2px * root.current-zoom;
                        y: 3px * root.current-zoom;
                        width: parent.width - 4px * root.current-zoom;
                        height: parent.height - 7px * root.current-zoom;
                        stroke: element.checkbox-check-color;
                        stroke-width: 1.8px;
                        fill: transparent;
                        commands: "M 0 4 L 4 8 L 12 0";
                    }
                }

                Text {
                    text: element.text-content == "" ? I18n.t("Checkbox") : element.text-content;
                    color: element.text-color;
                    font-size: element.font-size * root.current-zoom * 1px;
                    font-family: element.font-family;
                    x: parent.checkbox-label-x;
                    y: (parent.height - self.height) / 2;
                    width: parent.checkbox-label-width;
                    horizontal-alignment: parent.checkbox-space-between
                        ? (parent.checkbox-box-right
                            ? TextHorizontalAlignment.left
                            : TextHorizontalAlignment.right)
                        : TextHorizontalAlignment.left;
                    overflow: elide;
                }
            }

            if element.element-type == "image": Rectangle {
                background: transparent;

                if element.image-source-path != "": Image {
                    width: parent.width;
                    height: parent.height;
                    source: element.image-source;
                    image-fit: contain;
                }

                if element.image-source-path == "": Text {
                    text: element.text-content == "" ? "No image" : element.text-content;
                    color: element.text-color;
                    font-size: 11 * root.current-zoom * 1px;
                    horizontal-alignment: TextHorizontalAlignment.center;
                    vertical-alignment: TextVerticalAlignment.center;
                }
            }

            if element.element-type == "div" && element.text-content != "": Path {
                width: parent.width;
                height: parent.height;
                stroke: element.border-color;
                stroke-width: Math.max(1px, element.border-width * root.current-zoom * 1px);
                fill: transparent;
                commands: element.text-content;
            }

            if is-selected
                && root.active-control-tool == "cursor"
                && root.cursor-subtool == "cursor"
                : Rectangle {
                background: transparent;

                ResizeHandle {
                    x: -4px;
                    y: -4px;
                    mode: "resize-nw";
                    cursor-kind: root.resize-cursor-kind(self.mode, element-rect.display-rotation);
                    pressed(mode, mx, my, from-center) => {
                        root.begin-transform(
                            element.element-id,
                            mode,
                            element.bounds.position.x / 1px,
                            element.bounds.position.y / 1px,
                            element.bounds.size.width / 1px,
                            element.bounds.size.height / 1px,
                            element.rotation,
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            from-center
                        );
                    }
                    moved(mx, my) => {
                        root.update-active-transform(
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation)
                        );
                    }
                    released(commit) => { root.finish-transform(commit); }
                }

                ResizeHandle {
                    x: parent.width / 2 - 4px;
                    y: -4px;
                    mode: "resize-n";
                    cursor-kind: root.resize-cursor-kind(self.mode, element-rect.display-rotation);
                    pressed(mode, mx, my, from-center) => {
                        root.begin-transform(
                            element.element-id,
                            mode,
                            element.bounds.position.x / 1px,
                            element.bounds.position.y / 1px,
                            element.bounds.size.width / 1px,
                            element.bounds.size.height / 1px,
                            element.rotation,
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            from-center
                        );
                    }
                    moved(mx, my) => {
                        root.update-active-transform(
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation)
                        );
                    }
                    released(commit) => { root.finish-transform(commit); }
                }

                ResizeHandle {
                    x: parent.width - 4px;
                    y: -4px;
                    mode: "resize-ne";
                    cursor-kind: root.resize-cursor-kind(self.mode, element-rect.display-rotation);
                    pressed(mode, mx, my, from-center) => {
                        root.begin-transform(
                            element.element-id,
                            mode,
                            element.bounds.position.x / 1px,
                            element.bounds.position.y / 1px,
                            element.bounds.size.width / 1px,
                            element.bounds.size.height / 1px,
                            element.rotation,
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            from-center
                        );
                    }
                    moved(mx, my) => {
                        root.update-active-transform(
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation)
                        );
                    }
                    released(commit) => { root.finish-transform(commit); }
                }

                ResizeHandle {
                    x: parent.width - 4px;
                    y: parent.height / 2 - 4px;
                    mode: "resize-e";
                    cursor-kind: root.resize-cursor-kind(self.mode, element-rect.display-rotation);
                    pressed(mode, mx, my, from-center) => {
                        root.begin-transform(
                            element.element-id,
                            mode,
                            element.bounds.position.x / 1px,
                            element.bounds.position.y / 1px,
                            element.bounds.size.width / 1px,
                            element.bounds.size.height / 1px,
                            element.rotation,
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            from-center
                        );
                    }
                    moved(mx, my) => {
                        root.update-active-transform(
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation)
                        );
                    }
                    released(commit) => { root.finish-transform(commit); }
                }

                ResizeHandle {
                    x: parent.width - 4px;
                    y: parent.height - 4px;
                    mode: "resize-se";
                    cursor-kind: root.resize-cursor-kind(self.mode, element-rect.display-rotation);
                    pressed(mode, mx, my, from-center) => {
                        root.begin-transform(
                            element.element-id,
                            mode,
                            element.bounds.position.x / 1px,
                            element.bounds.position.y / 1px,
                            element.bounds.size.width / 1px,
                            element.bounds.size.height / 1px,
                            element.rotation,
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            from-center
                        );
                    }
                    moved(mx, my) => {
                        root.update-active-transform(
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation)
                        );
                    }
                    released(commit) => { root.finish-transform(commit); }
                }

                ResizeHandle {
                    x: parent.width / 2 - 4px;
                    y: parent.height - 4px;
                    mode: "resize-s";
                    cursor-kind: root.resize-cursor-kind(self.mode, element-rect.display-rotation);
                    pressed(mode, mx, my, from-center) => {
                        root.begin-transform(
                            element.element-id,
                            mode,
                            element.bounds.position.x / 1px,
                            element.bounds.position.y / 1px,
                            element.bounds.size.width / 1px,
                            element.bounds.size.height / 1px,
                            element.rotation,
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            from-center
                        );
                    }
                    moved(mx, my) => {
                        root.update-active-transform(
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation)
                        );
                    }
                    released(commit) => { root.finish-transform(commit); }
                }

                ResizeHandle {
                    x: -4px;
                    y: parent.height - 4px;
                    mode: "resize-sw";
                    cursor-kind: root.resize-cursor-kind(self.mode, element-rect.display-rotation);
                    pressed(mode, mx, my, from-center) => {
                        root.begin-transform(
                            element.element-id,
                            mode,
                            element.bounds.position.x / 1px,
                            element.bounds.position.y / 1px,
                            element.bounds.size.width / 1px,
                            element.bounds.size.height / 1px,
                            element.rotation,
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            from-center
                        );
                    }
                    moved(mx, my) => {
                        root.update-active-transform(
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation)
                        );
                    }
                    released(commit) => { root.finish-transform(commit); }
                }

                ResizeHandle {
                    x: -4px;
                    y: parent.height / 2 - 4px;
                    mode: "resize-w";
                    cursor-kind: root.resize-cursor-kind(self.mode, element-rect.display-rotation);
                    pressed(mode, mx, my, from-center) => {
                        root.begin-transform(
                            element.element-id,
                            mode,
                            element.bounds.position.x / 1px,
                            element.bounds.position.y / 1px,
                            element.bounds.size.width / 1px,
                            element.bounds.size.height / 1px,
                            element.rotation,
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            from-center
                        );
                    }
                    moved(mx, my) => {
                        root.update-active-transform(
                            root.local-to-canvas-x(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation),
                            root.local-to-canvas-y(mx / root.current-zoom, my / root.current-zoom, element-rect.display-canvas-x, element-rect.display-canvas-y, element-rect.display-canvas-w, element-rect.display-canvas-h, element-rect.display-rotation)
                        );
                    }
                    released(commit) => { root.finish-transform(commit); }
                }

            }
        }

        if root.is-marquee-selecting: Rectangle {
            z: 60;
            x: Math.min(root.marquee-start-canvas-x, root.marquee-current-canvas-x) * root.current-zoom * 1px;
            y: Math.min(root.marquee-start-canvas-y, root.marquee-current-canvas-y) * root.current-zoom * 1px;
            width: Math.abs(root.marquee-current-canvas-x - root.marquee-start-canvas-x) * root.current-zoom * 1px;
            height: Math.abs(root.marquee-current-canvas-y - root.marquee-start-canvas-y) * root.current-zoom * 1px;
            border-width: 1px;
            border-color: Themes.selection-border;
            background: Themes.selection-fill;
            border-radius: 2px;
        }

    }

    for comment[idx] in root.comments: comment-card := Rectangle {
        visible: root.comments-visible && comment-card.is-in-viewport;
        z: 35;

        property <bool> is-selected: root.selected-comment-id == comment.comment-id;
        property <bool> is-editing: root.editing-comment-id == comment.comment-id;
        property <string> draft-title: comment.title;
        property <string> draft-body: comment.body;
        property <string> synced-title: comment.title;
        property <string> synced-body: comment.body;
        property <bool> body-empty: comment-card.draft-body == "";
        property <float> source-x-world: root.active-comment-id == comment.comment-id ? root.comment-live-x : comment.position.x / 1px;
        property <float> source-y-world: root.active-comment-id == comment.comment-id ? root.comment-live-y : comment.position.y / 1px;
        property <float> display-x-world: source-x-world;
        property <float> display-width-world: root.active-comment-id == comment.comment-id ? root.comment-live-width : comment.width;
        property <float> display-body-height-world: root.active-comment-id == comment.comment-id ? root.comment-live-body-height : comment.body-height;
        property <float> cached-body-height-world: comment.body-height;
        property <float> last-body-measure-width-world: 0;
        property <string> last-body-measure-text: "";
        property <length> scale-padding: 10px * root.current-zoom;
        property <length> scale-gap: 8px * root.current-zoom;
        property <length> text-padding: 8px * root.current-zoom;
        property <length> viewport-overscan: 240px;
        property <length> content-width: comment-card.display-width-world * root.current-zoom * 1px;
        property <length> title-height: Math.max(
            30px * root.current-zoom,
            comment.title-font-size * root.current-zoom * 1px + 12px * root.current-zoom
        );
        property <length> body-width: content-width - scale-padding * 2;
        property <length> body-base-height: comment-card.display-body-height-world * root.current-zoom * 1px;
        property <length> measure-text-width: Math.max(1px, body-width - text-padding * 2);
        property <length> image-display-height: comment.has-image
            && comment.image-width > 0
            && comment.image-height > 0
            ? Math.min(
                220px * root.current-zoom,
                (body-width / 1px) * comment.image-height / Math.max(1, comment.image-width) * 1px
            )
            : 0px;
        property <float> image-extra-height-world: comment.has-image
            ? ((scale-gap + image-display-height) / root.current-zoom / 1px)
            : 0;
        property <length> body-height: comment-card.cached-body-height-world * root.current-zoom * 1px;
        property <float> world-total-height:
            (
                scale-padding
                + title-height
                + scale-gap
                + body-height
                + (comment.has-image ? scale-gap + image-display-height : 0px)
                + scale-padding
            ) / root.current-zoom / 1px;
        property <float> display-y-world: root.comment-display-y(
            comment-card.source-x-world,
            comment-card.source-y-world,
            comment-card.display-width-world,
            comment-card.world-total-height,
            comment-card.image-extra-height-world
        );
        property <length> screen-x: root.canvas-offset-x + comment-card.display-x-world * root.current-zoom * 1px;
        property <length> screen-y: root.canvas-offset-y + comment-card.display-y-world * root.current-zoom * 1px;
        property <bool> is-in-viewport:
            comment-card.screen-x + comment-card.content-width >= 0px - comment-card.viewport-overscan
            && comment-card.screen-x <= root.width + comment-card.viewport-overscan
            && comment-card.screen-y + comment-card.height >= 0px - comment-card.viewport-overscan
            && comment-card.screen-y <= root.height + comment-card.viewport-overscan;
        property <bool> should-measure-body:
            (comment-card.is-editing || comment-card.is-body-in-viewport)
            && (
                comment-card.last-body-measure-text != comment-card.draft-body
                || Math.abs(comment-card.last-body-measure-width-world - comment-card.display-width-world) > 0.01
            );
        property <length> measured-body-height: Math.max(
            body-base-height,
            body-measure.preferred-height + text-padding * 2
        );
        property <float> measured-body-height-world: comment-card.measured-body-height / root.current-zoom / 1px;
        property <float> world-body-height: comment-card.body-height / root.current-zoom / 1px;
        property <length> body-screen-y: comment-card.screen-y + scale-padding + title-height + scale-gap;
        property <bool> is-body-in-viewport:
            comment-card.body-screen-y + comment-card.body-height >= 0px - comment-card.viewport-overscan
            && comment-card.body-screen-y <= root.height + comment-card.viewport-overscan;
        property <bool> should-render-body-content: root.comments-visible && comment-card.is-body-in-viewport;
        property <length> image-screen-y:
            comment-card.body-screen-y + comment-card.body-height + scale-gap;
        property <bool> should-render-image:
            comment.has-image
            && root.comments-visible
            && comment-card.image-screen-y + comment-card.image-display-height >= 0px - comment-card.viewport-overscan
            && comment-card.image-screen-y <= root.height + comment-card.viewport-overscan;
        property <bool> editor-focused: title-editor.has-focus || body-editor.has-focus;

        changed synced-title => {
            if !self.is-editing {
                self.draft-title = self.synced-title;
            }
        }
        changed synced-body => {
            if !self.is-editing {
                self.draft-body = self.synced-body;
            }
        }
        changed measured-body-height-world => {
            if self.should-measure-body {
                let next-height = Math.max(
                    root.comment-min-body-height,
                    Math.min(root.comment-max-body-height, self.measured-body-height-world)
                );
                if Math.abs(self.cached-body-height-world - next-height) > 0.01 {
                    self.cached-body-height-world = next-height;
                }
                self.last-body-measure-width-world = self.display-width-world;
                self.last-body-measure-text = self.draft-body;
            }
        }
        changed is-editing => {
            if !self.is-editing {
                root.comment-editor-active = false;
                if self.draft-title != self.synced-title || self.draft-body != self.synced-body {
                    root.update-comment-content-requested(
                        comment.comment-id,
                        self.draft-title,
                        self.draft-body
                    );
                }
                if Math.abs(self.cached-body-height-world - comment.body-height) > 0.01 {
                    root.update-comment-size-requested(
                        comment.comment-id,
                        self.display-width-world,
                        self.cached-body-height-world
                    );
                }
            }
        }
        changed editor-focused => {
            if self.is-editing {
                root.comment-editor-active = self.editor-focused;
            }
        }

        x: comment-card.screen-x;
        y: comment-card.screen-y;
        width: content-width;
        height: scale-padding + title-height + scale-gap + body-height
            + (comment.has-image ? scale-gap + image-display-height : 0px)
            + scale-padding;
        border-radius: 8px * root.current-zoom;
        border-width: is-selected ? 2px : 1px;
        border-color: is-selected ? Themes.current.active-color : Themes.current.border-color;
        background: Themes.current.secondary-bg;
        drop-shadow-color: Themes.shadow-color;
        drop-shadow-blur: Themes.shadow-size;

        card-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: MouseCursor.pointer;

            scroll-event(event) => {
                if event.modifiers.control {
                    root.zoom-at-cursor(comment-card.x + self.mouse-x, comment-card.y + self.mouse-y, event.delta-y);
                    return accept;
                }
                reject
            }

            pointer-event(ev) => {
                let root-x = comment-card.x + self.mouse-x;
                let root-y = comment-card.y + self.mouse-y;
                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left && !comment-card.is-editing {
                    root.finish-active-text-edit(true);
                    root.clear-comment-drag-arm();
                    root.active-comment-id = "";
                    root.active-comment-mode = "none";
                    root.active-comment-zone = "";
                    root.element-select-requested("", false, true);
                    root.selected-comment-id = comment.comment-id;
                }
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    if !comment-card.is-editing {
                        root.selected-comment-id = comment.comment-id;
                        root.editing-comment-id = comment.comment-id;
                        body-editor.focus();
                    }
                }
                if ev.kind == PointerEventKind.cancel {
                    root.clear-comment-drag-arm();
                }
                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right {
                    root.finish-active-text-edit(true);
                    root.active-comment-id = "";
                    root.active-comment-mode = "none";
                    root.active-comment-zone = "";
                    root.element-select-requested("", false, true);
                    root.selected-comment-id = comment.comment-id;
                    root.clear-comment-drag-arm();
                    root.close-comment-editor();
                    root.open-comment-context-menu(
                        comment.comment-id,
                        comment-card.x + self.mouse-x,
                        comment-card.y + self.mouse-y,
                        ((comment-card.x + self.mouse-x) - root.canvas-offset-x) / 1px / root.current-zoom,
                        ((comment-card.y + self.mouse-y) - root.canvas-offset-y) / 1px / root.current-zoom,
                        comment.has-image,
                        comment.title-font-size,
                        comment.body-font-size
                    );
                }
            }
        }

        Rectangle {
            x: scale-padding;
            y: scale-padding;
            width: parent.width - scale-padding * 2;
            height: comment-card.title-height;
            border-radius: 6px * root.current-zoom;
            background: is-selected ? Themes.current.hover-color : Themes.current.primary-bg;

            if !comment-card.is-editing: Text {
                x: 8px * root.current-zoom;
                y: (parent.height - self.height) / 2;
                width: parent.width - 16px * root.current-zoom;
                text: comment.title == "" ? I18n.t("Comment") : comment.title;
                color: Themes.current.primary-text;
                font-size: comment.title-font-size * root.current-zoom * 1px;
                font-weight: 700;
                overflow: elide;
            }

            title-editor := TextInput {
                x: 8px * root.current-zoom;
                y: (parent.height - self.height) / 2;
                width: parent.width - 16px * root.current-zoom;
                height: parent.height;
                visible: comment-card.is-editing;
                enabled: comment-card.is-editing;
                single-line: true;
                text <=> comment-card.draft-title;
                color: Themes.current.primary-text;
                font-size: comment.title-font-size * root.current-zoom * 1px;
                font-weight: 700;
                selection-background-color: Themes.current.active-color;
                selection-foreground-color: Themes.on-accent-text;
                accepted => { root.close-comment-editor(); }
                key-pressed(event) => {
                    if event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt {
                        let key = root.normalize-comment-shortcut-key(event.text);
                        if key == "a" {
                            self.select-all();
                            return accept;
                        }
                        if key == "c" {
                            self.copy();
                            return accept;
                        }
                        if key == "x" {
                            self.cut();
                            return accept;
                        }
                        if key == "v" {
                            self.paste();
                            return accept;
                        }
                    }
                    reject
                }
            }
        }

        Rectangle {
            x: scale-padding;
            y: scale-padding + comment-card.title-height + scale-gap;
            width: body-width;
            height: comment-card.body-height;
            border-radius: 6px * root.current-zoom;
            background: Themes.current.primary-bg;
            border-width: 1px;
            border-color: comment-card.is-selected ? Themes.current.active-color : Themes.current.border-color;
            clip: true;

            body-preview := Text {
                x: text-padding;
                y: text-padding;
                width: comment-card.measure-text-width;
                height: parent.height - text-padding * 2;
                visible: comment-card.should-render-body-content && !comment-card.is-editing;
                text: comment-card.should-render-body-content
                    ? (comment-card.body-empty ? " " : comment-card.draft-body)
                    : "";
                color: Themes.current.secondary-text;
                font-size: comment.body-font-size * root.current-zoom * 1px;
                font-family: Themes.font-family-regular;
                wrap: word-wrap;
            }

            body-measure := Text {
                x: -10000px;
                y: -10000px;
                width: comment-card.measure-text-width;
                visible: comment-card.should-measure-body;
                text: comment-card.should-measure-body
                    ? (comment-card.body-empty ? " " : comment-card.draft-body)
                    : "";
                color: transparent;
                font-size: comment.body-font-size * root.current-zoom * 1px;
                font-family: Themes.font-family-regular;
                wrap: word-wrap;
            }

            body-editor := TextInput {
                x: text-padding;
                y: text-padding;
                width: comment-card.measure-text-width;
                height: parent.height - text-padding * 2;
                visible: comment-card.is-editing;
                enabled: comment-card.is-editing;
                single-line: false;
                wrap: word-wrap;
                text <=> comment-card.draft-body;
                color: Themes.current.primary-text;
                font-size: comment.body-font-size * root.current-zoom * 1px;
                font-family: Themes.font-family-regular;
                selection-background-color: Themes.current.active-color;
                selection-foreground-color: Themes.on-accent-text;
                key-pressed(event) => {
                    if event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt {
                        let key = root.normalize-comment-shortcut-key(event.text);
                        if key == "a" {
                            self.select-all();
                            return accept;
                        }
                        if key == "c" {
                            self.copy();
                            return accept;
                        }
                        if key == "x" {
                            self.cut();
                            return accept;
                        }
                        if key == "v" {
                            self.paste();
                            return accept;
                        }
                    }
                    reject
                }
            }
        }

        if comment.has-image && comment-card.should-render-image: Rectangle {
            x: scale-padding;
            y: scale-padding + comment-card.title-height + scale-gap + comment-card.body-height + scale-gap;
            width: body-width;
            height: image-display-height;
            border-radius: 6px * root.current-zoom;
            background: Themes.current.primary-bg;
            clip: true;

            Image {
                width: parent.width;
                height: parent.height;
                source: comment.image;
                image-fit: contain;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: MouseCursor.pointer;

                scroll-event(event) => {
                    if event.modifiers.control {
                        root.zoom-at-cursor(comment-card.x + parent.x + self.mouse-x, comment-card.y + parent.y + self.mouse-y, event.delta-y);
                        return accept;
                    }
                    reject
                }

                pointer-event(ev) => {
                    let root-x = comment-card.x + parent.x + self.mouse-x;
                    let root-y = comment-card.y + parent.y + self.mouse-y;
                    if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left && !comment-card.is-editing {
                        root.finish-active-text-edit(true);
                        root.clear-comment-drag-arm();
                        root.active-comment-id = "";
                        root.active-comment-mode = "none";
                        root.active-comment-zone = "";
                        root.element-select-requested("", false, true);
                        root.selected-comment-id = comment.comment-id;
                    }
                    if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                        if !comment-card.is-editing {
                            root.selected-comment-id = comment.comment-id;
                            root.editing-comment-id = comment.comment-id;
                            body-editor.focus();
                        }
                    }
                    if ev.kind == PointerEventKind.cancel {
                        root.clear-comment-drag-arm();
                    }
                    if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right {
                        root.finish-active-text-edit(true);
                        root.active-comment-id = "";
                        root.active-comment-mode = "none";
                        root.active-comment-zone = "";
                        root.element-select-requested("", false, true);
                        root.selected-comment-id = comment.comment-id;
                        root.clear-comment-drag-arm();
                        root.close-comment-editor();
                        root.open-comment-context-menu(
                            comment.comment-id,
                            comment-card.x + parent.x + self.mouse-x,
                            comment-card.y + parent.y + self.mouse-y,
                            ((comment-card.x + parent.x + self.mouse-x) - root.canvas-offset-x) / 1px / root.current-zoom,
                            ((comment-card.y + parent.y + self.mouse-y) - root.canvas-offset-y) / 1px / root.current-zoom,
                            comment.has-image,
                            comment.title-font-size,
                            comment.body-font-size
                        );
                    }
                }
            }
        }

        left-width-resize := Rectangle {
            visible: !comment-card.is-editing;
            z: 6;
            x: 0px;
            y: 0px;
            width: 5px;
            height: parent.height;
            background: #0000;

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: MouseCursor.col-resize;

                pointer-event(ev) => {
                    let root-x = comment-card.x + left-width-resize.x + self.mouse-x;
                    let root-y = comment-card.y + left-width-resize.y + self.mouse-y;
                    if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                        root.begin-comment-interaction(
                            comment.comment-id,
                            "resize-w",
                            root.comment-zone(
                                comment-card.source-x-world,
                                comment-card.source-y-world,
                                comment-card.display-width-world,
                                comment-card.world-total-height
                            ),
                            root-x,
                            root-y,
                            comment-card.source-x-world,
                            comment-card.source-y-world,
                            comment-card.display-width-world,
                            comment-card.world-body-height,
                            comment-card.world-total-height
                        );
                    }
                    if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right {
                        root.finish-active-text-edit(true);
                        root.active-comment-id = "";
                        root.active-comment-mode = "none";
                        root.active-comment-zone = "";
                        root.element-select-requested("", false, true);
                        root.selected-comment-id = comment.comment-id;
                        root.clear-comment-drag-arm();
                        root.close-comment-editor();
                        root.open-comment-context-menu(
                            comment.comment-id,
                            root-x,
                            root-y,
                            (root-x - root.canvas-offset-x) / 1px / root.current-zoom,
                            (root-y - root.canvas-offset-y) / 1px / root.current-zoom,
                            comment.has-image,
                            comment.title-font-size,
                            comment.body-font-size
                        );
                    }
                }
            }
        }

        right-width-resize := Rectangle {
            visible: !comment-card.is-editing;
            z: 6;
            x: parent.width - self.width;
            y: 0px;
            width: 5px;
            height: parent.height;
            background: #0000;

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: MouseCursor.col-resize;

                pointer-event(ev) => {
                    let root-x = comment-card.x + right-width-resize.x + self.mouse-x;
                    let root-y = comment-card.y + right-width-resize.y + self.mouse-y;
                    if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                        root.begin-comment-interaction(
                            comment.comment-id,
                            "resize-e",
                            root.comment-zone(
                                comment-card.source-x-world,
                                comment-card.source-y-world,
                                comment-card.display-width-world,
                                comment-card.world-total-height
                            ),
                            root-x,
                            root-y,
                            comment-card.source-x-world,
                            comment-card.source-y-world,
                            comment-card.display-width-world,
                            comment-card.world-body-height,
                            comment-card.world-total-height
                        );
                    }
                    if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right {
                        root.finish-active-text-edit(true);
                        root.active-comment-id = "";
                        root.active-comment-mode = "none";
                        root.active-comment-zone = "";
                        root.element-select-requested("", false, true);
                        root.selected-comment-id = comment.comment-id;
                        root.clear-comment-drag-arm();
                        root.close-comment-editor();
                        root.open-comment-context-menu(
                            comment.comment-id,
                            root-x,
                            root-y,
                            (root-x - root.canvas-offset-x) / 1px / root.current-zoom,
                            (root-y - root.canvas-offset-y) / 1px / root.current-zoom,
                            comment.has-image,
                            comment.title-font-size,
                            comment.body-font-size
                        );
                    }
                }
            }
        }

    }

    if root.active-comment-mode != "none": TouchArea {
        z: 25;
        width: parent.width;
        height: parent.height;
        mouse-cursor: root.active-comment-mode == "move" ? MouseCursor.move : MouseCursor.col-resize;

        pointer-event(ev) => {
            let root-x = self.mouse-x;
            let root-y = self.mouse-y;

            if ev.kind == PointerEventKind.move {
                if root.active-comment-mode == "move" {
                    root.update-active-comment-move(
                        root-x,
                        root-y,
                        root.comment-live-width,
                        root.comment-live-total-height
                    );
                } else {
                    root.update-active-comment-resize(
                        root-x,
                        root-y,
                        root.comment-live-total-height,
                        root.comment-live-body-height
                    );
                }
            }

            if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                root.finish-active-comment-interaction(true);
            }

            if ev.kind == PointerEventKind.cancel {
                root.finish-active-comment-interaction(false);
            }
        }
    }

    if root.active-control-tool == "cursor" && root.cursor-subtool == "hand": Path {
        z: 4000;
        width: 20px;
        height: 20px;
        x: root.last-pointer-root-x - 8px;
        y: root.last-pointer-root-y - 5px;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: root.hand-cursor-path;
        stroke: Themes.current.primary-text;
        stroke-width: 1.5px;
        fill: transparent;
        stroke-line-cap: round;
        stroke-line-join: round;
    }

    if viewport.y > 0px: Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: viewport.y;
        background: transparent;
        z: 5;

        TouchArea {
            width: parent.width;
            height: parent.height;
            scroll-event(event) => {
                if event.modifiers.control {
                    root.zoom-at-cursor(parent.x + self.mouse-x, parent.y + self.mouse-y, event.delta-y);
                    return accept;
                }
                reject
            }
            pointer-event(ev) => {
                let root-x = parent.x + self.mouse-x;
                let root-y = parent.y + self.mouse-y;
                root.handle-outside-canvas-pointer(
                    ev.kind,
                    ev.button,
                    root-x,
                    root-y,
                    ev.modifiers.control,
                    ev.modifiers.shift,
                    ev.modifiers.alt
                );
            }
        }
    }

    if viewport.x > 0px: Rectangle {
        x: 0;
        y: 0;
        width: viewport.x;
        height: root.height;
        background: transparent;
        z: 5;

        TouchArea {
            width: parent.width;
            height: parent.height;
            scroll-event(event) => {
                if event.modifiers.control {
                    root.zoom-at-cursor(parent.x + self.mouse-x, parent.y + self.mouse-y, event.delta-y);
                    return accept;
                }
                reject
            }
            pointer-event(ev) => {
                let root-x = parent.x + self.mouse-x;
                let root-y = parent.y + self.mouse-y;
                root.handle-outside-canvas-pointer(
                    ev.kind,
                    ev.button,
                    root-x,
                    root-y,
                    ev.modifiers.control,
                    ev.modifiers.shift,
                    ev.modifiers.alt
                );
            }
        }
    }

    if viewport.x + viewport.width < root.width: Rectangle {
        x: viewport.x + viewport.width;
        y: 0;
        width: root.width - self.x;
        height: root.height;
        background: transparent;
        z: 5;

        TouchArea {
            width: parent.width;
            height: parent.height;
            scroll-event(event) => {
                if event.modifiers.control {
                    root.zoom-at-cursor(parent.x + self.mouse-x, parent.y + self.mouse-y, event.delta-y);
                    return accept;
                }
                reject
            }
            pointer-event(ev) => {
                let root-x = parent.x + self.mouse-x;
                let root-y = parent.y + self.mouse-y;
                root.handle-outside-canvas-pointer(
                    ev.kind,
                    ev.button,
                    root-x,
                    root-y,
                    ev.modifiers.control,
                    ev.modifiers.shift,
                    ev.modifiers.alt
                );
            }
        }
    }

    if viewport.y + viewport.height < root.height: Rectangle {
        x: 0;
        y: viewport.y + viewport.height;
        width: root.width;
        height: root.height - self.y;
        background: transparent;
        z: 5;

        TouchArea {
            width: parent.width;
            height: parent.height;
            scroll-event(event) => {
                if event.modifiers.control {
                    root.zoom-at-cursor(parent.x + self.mouse-x, parent.y + self.mouse-y, event.delta-y);
                    return accept;
                }
                reject
            }
            pointer-event(ev) => {
                let root-x = parent.x + self.mouse-x;
                let root-y = parent.y + self.mouse-y;
                root.handle-outside-canvas-pointer(
                    ev.kind,
                    ev.button,
                    root-x,
                    root-y,
                    ev.modifiers.control,
                    ev.modifiers.shift,
                    ev.modifiers.alt
                );
            }
        }
    }

    pan-area := TouchArea {
        z: 20;
        enabled: is-panning
            || drag-state == DragState.Dragging
            || is-transforming
            || active-mode != "none";
        width: parent.width;
        height: parent.height;
        mouse-cursor: is-panning ? MouseCursor.grabbing
            : active-mode == "rotate" ? MouseCursor.alias
            : active-mode != "none" && active-mode != "move"
                ? (root.resize-cursor-kind(active-mode, root.start-element-rotation) == "col"
                    ? MouseCursor.col-resize
                    : root.resize-cursor-kind(active-mode, root.start-element-rotation) == "row"
                        ? MouseCursor.row-resize
                        : root.resize-cursor-kind(active-mode, root.start-element-rotation) == "ne"
                            ? MouseCursor.ne-resize
                            : MouseCursor.nw-resize)
            : active-mode != "none" ? MouseCursor.move
            : drag-state == DragState.Dragging ? MouseCursor.copy
            : MouseCursor.default;

        scroll-event(event) => {
            if event.modifiers.control {
                root.zoom-at-cursor(self.mouse-x, self.mouse-y, event.delta-y);
                return accept;
            }
            reject
        }

        pointer-event(ev) => {
            root.report-pointer-button(
                ev.kind,
                ev.button,
                ev.modifiers.control,
                ev.modifiers.shift,
                ev.modifiers.alt
            );

            let canvas-x = ((self.mouse-x - canvas-offset-x) / 1px) / current-zoom;
            let canvas-y = ((self.mouse-y - canvas-offset-y) / 1px) / current-zoom;
            root.remember-pointer(self.mouse-x, self.mouse-y, canvas-x, canvas-y);
            if ev.kind == PointerEventKind.down {
                root.cursor-tools-menu-open = false;
                root.rectangle-tools-menu-open = false;
            }

            if drag-state == DragState.Dragging {
                drag-preview-x = self.mouse-x + 14px;
                drag-preview-y = self.mouse-y + 14px;
            }

            let root-x = self.mouse-x;
            let root-y = self.mouse-y;
            if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.middle {
                root.start-pan(root-x, root-y, "overlay");
                context-menu.visible-menu = false;
            }
            if ev.kind == PointerEventKind.move {
                root.update-pan(root-x, root-y, "overlay");
                root.update-active-transform(canvas-x, canvas-y);
            }
            if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.middle {
                root.stop-pan();
            }

            if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left && root.is-primary-held {
                root.finish-transform(true);
            }

            if ev.kind == PointerEventKind.cancel {
                root.finish-transform(false);
                if drag-state == DragState.Dragging {
                    root.drag-cancelled();
                }
            }

            if drag-state == DragState.Dragging && ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                context-menu.visible-menu = false;
                if canvas-x >= 0 && canvas-y >= 0 && canvas-x <= page-width / 1px && canvas-y <= page-height / 1px {
                    root.element-dropped(dragging-component-id, canvas-x, canvas-y, 0, 0, "");
                } else {
                    root.drag-cancelled();
                }
            }
        }
    }

    if drag-state == DragState.Dragging: Rectangle {
        x: canvas-offset-x;
        y: canvas-offset-y;
        width: page-width * current-zoom;
        height: page-height * current-zoom;
        border-width: 2px;
        border-color: Themes.selection-border;
        border-radius: 6px;
        background: Themes.selection-fill;
    }

    if drag-state == DragState.Dragging: Rectangle {
        x: drag-preview-x;
        y: drag-preview-y;
        width: drag-label.preferred-width + 26px;
        height: 28px;
        border-radius: 6px;
        border-width: 1px;
        border-color: Themes.selection-border;
        background: Themes.selection-panel-bg;

        HorizontalBox {
            padding-left: 10px;
            padding-right: 10px;
            spacing: 6px;

            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background: Themes.selection-border;
                y: 11px;
            }

            drag-label := Text {
                text: dragging-component-name == "" ? dragging-component-id : dragging-component-name;
                font-size: 11px;
                color: Themes.selection-text;
                vertical-alignment: TextVerticalAlignment.center;
            }
        }

    }

    context-menu := Rectangle {
        z: 50;
        in-out property <length> mouse-x: 0px;
        in-out property <length> mouse-y: 0px;
        in-out property <bool> visible-menu: false;
        in-out property <string> menu-kind: "empty";
        in-out property <float> drop-x: 0;
        in-out property <float> drop-y: 0;
        in-out property <float> raw-drop-x: 0;
        in-out property <float> raw-drop-y: 0;
        in-out property <string> comment-target-id: "";
        in-out property <bool> comment-target-has-image: false;
        in-out property <float> comment-target-title-font-size: 16;
        in-out property <float> comment-target-body-font-size: 13;
        property <length> empty-menu-height: 145px;
        property <length> outside-menu-height: 145px;
        property <length> selected-menu-height: 310px;
        property <length> comment-menu-height: 230px;
        property <length> comment-menu-height-with-image: 333px;

        visible: visible-menu;
        opacity: visible-menu ? 1.0 : 0.0;

        x: mouse-x;
        y: mouse-y;
        width: 280px;
        height: menu-kind == "selected" ? selected-menu-height
            : menu-kind == "outside" ? outside-menu-height
            : menu-kind == "comment"
                ? (comment-target-has-image ? comment-menu-height-with-image : comment-menu-height)
                : empty-menu-height;

        ContextMenuClickEmptyCanvas {
            visible: context-menu.menu-kind == "empty";
            width: parent.width;
            height: parent.height;
            paste-requested => {
                root.paste-requested(context-menu.drop-x, context-menu.drop-y);
                context-menu.visible-menu = false;
            }
            toggle-ui-requested => {
                root.set-ui-visibility-requested(!root.ui-helpers-visible);
                context-menu.visible-menu = false;
            }
            toggle-comments-requested => {
                root.set-comments-visibility-requested(!root.comments-visible);
                context-menu.visible-menu = false;
            }
            dismiss-requested => { context-menu.visible-menu = false; }
        }

        ContextMenuClickSelectedObject {
            visible: context-menu.menu-kind == "selected";
            width: parent.width;
            height: parent.height;
            copy-requested => {
                root.copy-requested();
                context-menu.visible-menu = false;
            }
            paste-requested => {
                root.paste-requested(context-menu.drop-x, context-menu.drop-y);
                context-menu.visible-menu = false;
            }
            paste-replace-requested => {
                root.paste-replace-requested(context-menu.drop-x, context-menu.drop-y);
                context-menu.visible-menu = false;
            }
            group-requested => {
                root.group-requested();
                context-menu.visible-menu = false;
            }
            ungroup-requested => {
                root.ungroup-requested();
                context-menu.visible-menu = false;
            }
            flip-vertical-requested => {
                root.flip-vertical-requested();
                context-menu.visible-menu = false;
            }
            flip-horizontal-requested => {
                root.flip-horizontal-requested();
                context-menu.visible-menu = false;
            }
            go-to-blueprint-requested => {
                root.go-to-blueprint-requested(root.selected-element-id);
                context-menu.visible-menu = false;
            }
            dismiss-requested => { context-menu.visible-menu = false; }
        }

        ContextMenuClickOutsideCanvas {
            visible: context-menu.menu-kind == "outside";
            width: parent.width;
            height: parent.height;
            create-comment-requested => {
                root.create-comment-requested(
                    context-menu.raw-drop-x,
                    context-menu.raw-drop-y
                );
                context-menu.visible-menu = false;
            }
            toggle-ui-requested => {
                root.set-ui-visibility-requested(!root.ui-helpers-visible);
                context-menu.visible-menu = false;
            }
            toggle-comments-requested => {
                root.set-comments-visibility-requested(!root.comments-visible);
                context-menu.visible-menu = false;
            }
            dismiss-requested => { context-menu.visible-menu = false; }
        }

        ContextMenuClickComment {
            visible: context-menu.menu-kind == "comment";
            width: parent.width;
            height: parent.height;
            has-image: context-menu.comment-target-has-image;
            title-font-size <=> context-menu.comment-target-title-font-size;
            body-font-size <=> context-menu.comment-target-body-font-size;
            paste-image-requested => {
                root.paste-comment-image-requested(context-menu.comment-target-id);
                context-menu.visible-menu = false;
            }
            delete-image-requested => {
                root.clear-comment-image-requested(context-menu.comment-target-id);
                context-menu.visible-menu = false;
            }
            delete-comment-requested => {
                root.delete-comment-requested(context-menu.comment-target-id);
                context-menu.visible-menu = false;
            }
            title-font-size-requested(next) => {
                root.update-comment-font-sizes-requested(
                    context-menu.comment-target-id,
                    next,
                    context-menu.comment-target-body-font-size
                );
            }
            body-font-size-requested(next) => {
                root.update-comment-font-sizes-requested(
                    context-menu.comment-target-id,
                    context-menu.comment-target-title-font-size,
                    next
                );
            }
            dismiss-requested => { context-menu.visible-menu = false; }
        }

        animate opacity { duration: 100ms; }
    }

    if !root.comments-visible: Rectangle {
        z: 245;
        width: comments-hidden-label.preferred-width + 18px;
        height: 24px;
        x: parent.width - self.width - 12px;
        y: 12px;
        border-radius: 6px;
        border-width: 1px;
        border-color: Themes.current.border-color;
        background: Themes.current.secondary-bg;

        comments-hidden-label := Text {
            x: 9px;
            width: parent.width - 18px;
            height: parent.height;
            text: I18n.t("Comments hidden");
            color: Themes.current.secondary-text;
            font-size: 11px;
            vertical-alignment: TextVerticalAlignment.center;
            horizontal-alignment: TextHorizontalAlignment.center;
        }
    }

    if root.ui-helpers-visible: CanvasZoomControls {
        z: 40;
        x: 10px;
        y: parent.height - self.height - 10px;
        zoom-level: root.current-zoom;
        zoom-out-requested => {
            root.zoom-at-cursor(root.width / 2, root.height / 2, -1px);
            root.sync-viewport-state(true);
        }
        zoom-in-requested => {
            root.zoom-at-cursor(root.width / 2, root.height / 2, 1px);
            root.sync-viewport-state(true);
        }
        reset-view-requested => { root.reset-view(); }
    }
}
