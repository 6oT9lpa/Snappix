                    text <=> root.editing-freeform-text;
                    color: element.text-color;
                    font-size: element.font-size * root.current-zoom * 1px;
                    font-family: element.font-family;
                    width: parent.width - 8px;
                    height: parent.height - 8px;
                    x: 4px;
                    y: 4px;
                    init => {
                        self.focus();
                        self.select-all();
