                x: i * root.state.grid-size * current-zoom;
                y: 0;
                width: 1px;
                height: parent.height;
                background: Themes.canvas-grid-color;
            }

            for j in Math.floor(parent.height / (root.state.grid-size * current-zoom)) + 1 : Rectangle {
