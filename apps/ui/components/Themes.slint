import "../assets/fonts/Comic-Regular.ttf";
import "../assets/fonts/Roboto-Regular.ttf";
import "../assets/fonts/Roboto-Medium.ttf";
import "../assets/fonts/Roboto-Bold.ttf";

export component Separator-V inherits Rectangle {
    width: 1px;
    background: Themes.current.divider-color;
}

export component Separator-H inherits Rectangle {
    height: 1px;
    background: Themes.current.divider-color;
}

export global Themes {
    // Font family definitions
    in-out property<string> font-family-regular: "Roboto Regular";
    in-out property<string> font-family-display: "Comic Sans MS";

    in-out property<{
        primary-bg: color,
        secondary-bg: color,
        primary-text: color,
        secondary-text: color,
        disabled-text: color,
        border-color: color,
        divider-color: color,
        hover-color: color,
        active-color: color,
        button-color: color,
        tooltip-bg: color
    }> current: dark;

    in-out property<{
        primary-bg: color,
        secondary-bg: color,
        primary-text: color,
        secondary-text: color,
        disabled-text: color,
        border-color: color,
        divider-color: color,
        hover-color: color,
        active-color: color,
        button-color: color,
        tooltip-bg: color
    }> light: {
        primary-bg: #ffffff,
        secondary-bg: #f5f5f5,
        tooltip-bg: #e1e1e1,

        primary-text: #1e1e1e,
        secondary-text: #5a5a5a,
        disabled-text: #9e9e9e,

        border-color: #e0e0e0,
        divider-color: #c0c0c0,

        hover-color: #ededed,
        active-color: #dddddd,

        button-color: #393737
    };

    in-out property<{
        primary-bg: color,
        secondary-bg: color,
        primary-text: color,
        secondary-text: color,
        disabled-text: color,
        border-color: color,
        divider-color: color,
        hover-color: color,
        active-color: color,
        button-color: color,
        tooltip-bg: color
    }> dark: {
        primary-bg: #222222,
        secondary-bg: #2a2a2a,
        tooltip-bg: #3a3a3a,

        primary-text: #ffffff,
        secondary-text: #858585,
        disabled-text: #6e6e6e,

        border-color: #3e3e3e,
        divider-color: #3b3a3a,

        hover-color: #434343,
        active-color: #acacac,

        button-color: #393737
    };

    in-out property <color> overlay-bg: #00000066;
    in-out property <color> overlay-strong-bg: #00000090;
    in-out property <color> shadow-color: #00000040;
    in-out property <length> shadow-size: 10px;
    in-out property <length> border-radius: 6px;
    in-out property <color> error-bg: #FF444420;
    in-out property <color> error-text: #FF6666;
    in-out property <color> success-color: #7DD97D;
    in-out property <color> warning-color: #F5DC78;
    in-out property <color> selection-border: #4EA1FF;
    in-out property <color> selection-fill: #4EA1FF33;
    in-out property <color> selection-panel-bg: #10203ACC;
    in-out property <color> selection-text: #D9E7FF;
    in-out property <color> on-accent-color: #fad707;
    in-out property <color> on-accent-bg: #fad50753; 
    in-out property <color> on-accent-text: #000000;
    in-out property <color> canvas-bg: #0F0F0F;
    in-out property <color> canvas-grid-color: #2B2B2B;

    in-out property <color> light-overlay-bg: #00000040;
    in-out property <color> light-overlay-strong-bg: #00000066;
    in-out property <color> light-shadow-color: #00000024;
    in-out property <length> light-shadow-size: 8px;
    in-out property <length> light-border-radius: 6px;
    in-out property <color> light-error-bg: #D32F2F1A;
    in-out property <color> light-error-text: #C62828;
    in-out property <color> light-success-color: #2E7D32;
    in-out property <color> light-warning-color: #FFECB3;
    in-out property <color> light-selection-border: #1976D2;
    in-out property <color> light-selection-fill: #1976D233;
    in-out property <color> light-selection-panel-bg: #E3F2FDCC;
    in-out property <color> light-selection-text: #0D47A1;
    in-out property <color> light-on-accent-color: #fad707;
    in-out property <color> light-on-accent-bg: #fad50753; 
    in-out property <color> light-on-accent-text: #000000;
    in-out property <color> light-canvas-bg: #F3F5F8;
    in-out property <color> light-canvas-grid-color: #D6DCE5;

    in-out property <color> dark-overlay-bg: #00000066;
    in-out property <color> dark-overlay-strong-bg: #00000090;
    in-out property <color> dark-shadow-color: #00000040;
    in-out property <length> dark-shadow-size: 10px;
    in-out property <length> dark-border-radius: 6px;
    in-out property <color> dark-error-bg: #FF444420;
    in-out property <color> dark-error-text: #FF6666;
    in-out property <color> dark-success-color: #7DD97D;
    in-out property <color> dark-warning-color: #F5DC78;
    in-out property <color> dark-selection-border: #4EA1FF;
    in-out property <color> dark-selection-fill: #4EA1FF33;
    in-out property <color> dark-selection-panel-bg: #10203ACC;
    in-out property <color> dark-selection-text: #D9E7FF;
    in-out property <color> dark-on-accent-color: #fad707;
    in-out property <color> dark-on-accent-bg: #fad50753; 
    in-out property <color> dark-on-accent-text: #000000;
    in-out property <color> dark-canvas-bg: #0F0F0F;
    in-out property <color> dark-canvas-grid-color: #2B2B2B;

    public function apply-light-extended() {
        overlay-bg = light-overlay-bg;
        overlay-strong-bg = light-overlay-strong-bg;
        shadow-color = light-shadow-color;
        shadow-size = light-shadow-size;
        border-radius = light-border-radius;
        error-bg = light-error-bg;
        error-text = light-error-text;
        success-color = light-success-color;
        warning-color = light-warning-color;
        selection-border = light-selection-border;
        selection-fill = light-selection-fill;
        selection-panel-bg = light-selection-panel-bg;
        selection-text = light-selection-text;
        on-accent-color = light-on-accent-color;
        on-accent-bg = light-on-accent-bg;
        on-accent-text = light-on-accent-text;
        canvas-bg = light-canvas-bg;
        canvas-grid-color = light-canvas-grid-color;
    }

    public function apply-dark-extended() {
        overlay-bg = dark-overlay-bg;
        overlay-strong-bg = dark-overlay-strong-bg;
        shadow-color = dark-shadow-color;
        shadow-size = dark-shadow-size;
        border-radius = dark-border-radius;
        error-bg = dark-error-bg;
        error-text = dark-error-text;
        success-color = dark-success-color;
        warning-color = dark-warning-color;
        selection-border = dark-selection-border;
        selection-fill = dark-selection-fill;
        selection-panel-bg = dark-selection-panel-bg;
        selection-text = dark-selection-text;
        on-accent-color = dark-on-accent-color;
        on-accent-bg = dark-on-accent-bg;
        on-accent-text = dark-on-accent-text;
        canvas-bg = dark-canvas-bg;
        canvas-grid-color = dark-canvas-grid-color;
    }

    function toggle-theme() {
        if current == light {
            current = dark;
            apply-dark-extended();
        } else {
            current = light;
            apply-light-extended();
        }
    }
}
