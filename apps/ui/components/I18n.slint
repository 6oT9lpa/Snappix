        else if key == "blueprint.node.tooltip.page.navigate" { "Переключает приложение на выбранную страницу и продолжает выполнение." }
        else if key == "blueprint.node.tooltip.ui.set_opacity" { "Меняет прозрачность элемента через float-значение от 0.0 до 1.0." }
        else if key == "blueprint.node.tooltip.ui.set_display_mode" { "Меняет отображение элемента: видимость, скрытие или режим layout." }
        else if key == "blueprint.node.tooltip.flow.branch" { "Разделяет выполнение на ветки true и false по boolean-условию." }
        else if key == "blueprint.node.tooltip.flow.delay" { "Ждет указанную длительность перед продолжением выполнения." }
        else if key == "blueprint.node.tooltip.flow.loop" { "Повторяет ветку body, пока условие разрешает итерации." }
        else if key == "blueprint.node.tooltip.flow.while" { "Выполняет body, пока boolean-условие остается true." }
        else if key == "blueprint.node.tooltip.flow.for_range" { "Итерируется от начального int до конечного int и отдает текущий индекс." }
        else if key == "blueprint.node.tooltip.flow.for_each" { "Итерируется по массиву и отдает текущий элемент и индекс." }
