export global I18n {
    in-out property <string> language: "ru";

    public pure function t(key: string) -> string {
        if language == "en" {
            if key == "blueprint.node.tooltip.event.button" { return "Runs when a bound button emits click, hover, or press events."; }
            else if key == "blueprint.node.tooltip.event.input" { return "Runs when a bound input changes text or focus state."; }
            else if key == "blueprint.node.tooltip.event.checkbox" { return "Runs when a bound checkbox is clicked or its checked state changes."; }
            else if key == "blueprint.node.tooltip.event.label" { return "Runs when a bound label is clicked or hovered."; }
            else if key == "blueprint.node.tooltip.event.fill" { return "Runs when a fill-capable element receives or updates text content."; }
            else if key == "blueprint.node.tooltip.event.app_started" { return "Starts execution once when the application opens."; }
            else if key == "blueprint.node.tooltip.event.app_started_delayed" { return "Starts execution after startup delay, when the UI is ready."; }
            else if key == "blueprint.node.tooltip.event.page_changed" { return "Starts execution when the active page changes."; }
            else if key == "blueprint.node.tooltip.page.navigate" { return "Switches to the selected page and continues execution."; }
            else if key == "blueprint.node.tooltip.ui.set_opacity" { return "Changes an element opacity using a float value from 0.0 to 1.0."; }
            else if key == "blueprint.node.tooltip.ui.set_display_mode" { return "Changes how an element is displayed, such as visible, hidden, or layout mode."; }
            else if key == "blueprint.node.tooltip.flow.branch" { return "Splits execution into true and false paths using a boolean condition."; }
            else if key == "blueprint.node.tooltip.flow.delay" { return "Waits for a configured duration before continuing execution."; }
            else if key == "blueprint.node.tooltip.flow.loop" { return "Repeats the body path while the condition allows iteration."; }
            else if key == "blueprint.node.tooltip.flow.while" { return "Runs the body path while the boolean condition remains true."; }
            else if key == "blueprint.node.tooltip.flow.for_range" { return "Iterates from a start integer to an end integer and exposes the current index."; }
            else if key == "blueprint.node.tooltip.flow.for_each" { return "Iterates over an array and exposes the current item and index."; }
            else if key == "blueprint.node.tooltip.value.bool_true" { return "Outputs the constant boolean value true."; }
            else if key == "blueprint.node.tooltip.value.bool_false" { return "Outputs the constant boolean value false."; }
            else if key == "blueprint.node.tooltip.value.int_zero" { return "Outputs the integer literal 0."; }
            else if key == "blueprint.node.tooltip.value.float_zero" { return "Outputs the floating-point literal 0.0."; }
            else if key == "blueprint.node.tooltip.value.string_empty" { return "Outputs an empty string literal."; }
            else if key == "blueprint.node.tooltip.bool.not" { return "Inverts a boolean value and outputs the opposite result."; }
            else if key == "blueprint.node.tooltip.math.negate" { return "Changes a number sign and outputs the negated float value."; }
            else if key == "blueprint.node.tooltip.string.length" { return "Counts characters in text and outputs the length as an integer."; }
            else if key == "blueprint.node.tooltip.string.is_empty" { return "Checks whether text is empty and outputs a boolean result."; }
            else if key == "blueprint.node.tooltip.convert.to_bool" { return "Converts an incoming value to a boolean output."; }
            else if key == "blueprint.node.tooltip.convert.to_int" { return "Converts an incoming value to an integer output."; }
            else if key == "blueprint.node.tooltip.convert.to_float" { return "Converts an incoming value to a floating-point output."; }
            else if key == "blueprint.node.tooltip.convert.to_string" { return "Converts an incoming value to a string output."; }
            else if key == "blueprint.node.tooltip.math.int.add" { return "Adds two integer values and outputs an integer result."; }
            else if key == "blueprint.node.tooltip.math.int.sub" { return "Subtracts the second integer from the first and outputs an integer result."; }
            else if key == "blueprint.node.tooltip.math.int.mul" { return "Multiplies two integer values and outputs an integer result."; }
            else if key == "blueprint.node.tooltip.math.int.div" { return "Divides the first integer by the second and outputs an integer result."; }
            else if key == "blueprint.node.tooltip.math.int.mod" { return "Outputs the integer remainder after division."; }
            else if key == "blueprint.node.tooltip.math.int.pow" { return "Raises an integer base to an integer power."; }
            else if key == "blueprint.node.tooltip.math.float.add" { return "Adds two float values and outputs a float result."; }
            else if key == "blueprint.node.tooltip.math.float.sub" { return "Subtracts the second float from the first and outputs a float result."; }
            else if key == "blueprint.node.tooltip.math.float.mul" { return "Multiplies two float values and outputs a float result."; }
            else if key == "blueprint.node.tooltip.math.float.div" { return "Divides the first float by the second and outputs a float result."; }
            else if key == "blueprint.node.tooltip.math.float.mod" { return "Outputs the floating-point remainder after division."; }
            else if key == "blueprint.node.tooltip.math.float.pow" { return "Raises a float base to a float power."; }
            else if key == "blueprint.node.tooltip.math.int_float.add" { return "Adds an integer and a float, then outputs a float result."; }
            else if key == "blueprint.node.tooltip.math.int_float.sub" { return "Subtracts a float from an integer and outputs a float result."; }
            else if key == "blueprint.node.tooltip.math.int_float.mul" { return "Multiplies an integer by a float and outputs a float result."; }
            else if key == "blueprint.node.tooltip.math.int_float.div" { return "Divides an integer by a float and outputs a float result."; }
            else if key == "blueprint.node.tooltip.math.int_float.mod" { return "Outputs the remainder of an integer divided by a float."; }
            else if key == "blueprint.node.tooltip.math.int_float.pow" { return "Raises an integer base to a float power."; }
            else if key == "blueprint.node.tooltip.string.concat" { return "Joins two text values and outputs the combined string."; }
            else if key == "blueprint.node.tooltip.compare.gt" { return "Checks whether the left value is greater than the right value."; }
            else if key == "blueprint.node.tooltip.compare.lt" { return "Checks whether the left value is less than the right value."; }
            else if key == "blueprint.node.tooltip.compare.gte" { return "Checks whether the left value is greater than or equal to the right value."; }
            else if key == "blueprint.node.tooltip.compare.lte" { return "Checks whether the left value is less than or equal to the right value."; }
            else if key == "blueprint.node.tooltip.compare.eq" { return "Checks whether two values are equal."; }
            else if key == "blueprint.node.tooltip.compare.neq" { return "Checks whether two values are different."; }
            else if key == "blueprint.node.tooltip.variables.get_dynamic" { return "Reads a dynamic variable value and outputs it as any type."; }
            else if key == "blueprint.node.tooltip.variables.set_dynamic" { return "Writes a dynamic variable value and continues execution."; }
            else if key == "blueprint.node.tooltip.functions.return" { return "Finishes the current function and passes the return value."; }
            else if key == "blueprint.node.tooltip.types.struct_make" { return "Builds an object-like structure from field data."; }
            else if key == "blueprint.node.tooltip.types.enum_value" { return "Outputs a selected enum value as text."; }
            else if key == "blueprint.node.tooltip.network.request" { return "Sends a server-side HTTP request and outputs the response text."; }
            else if key == "blueprint.node.tooltip.db.query" { return "Runs a server-side database query and outputs returned rows."; }
            else { return key; }
        }

        if key == "blueprint.node.tooltip.event.button" { "Запускается, когда привязанная кнопка получает click, hover или press." }
        else if key == "blueprint.node.tooltip.event.input" { "Запускается, когда привязанное поле ввода меняет текст или состояние фокуса." }
