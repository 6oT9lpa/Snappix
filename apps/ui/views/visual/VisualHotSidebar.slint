export component VisualHotSidebar inherits Rectangle {
    in-out property <int> active-button: 0;

    callback new-page-clicked();
    callback blueprint-clicked();
    callback show-tooltip(string, length);
    callback hide-tooltip();

    function toggle(id: int) {
        root.active-button = root.active-button == id ? 0 : id;
    }

    function sync-tooltip() {
        if root.explorer-hovered {
            root.show-tooltip("Explorer (Hotkey -> 1)", explorer-button.y + explorer-button.height / 2);
        } else if root.library-hovered {
            root.show-tooltip("Components Library (Hotkey -> 2)", library-button.y + library-button.height / 2);
        } else if root.blueprint-hovered {
            root.show-tooltip("Open Blueprint", blueprint-button.y + blueprint-button.height / 2);
        } else if root.props-hovered {
            root.show-tooltip("Properties", props-button.y + props-button.height / 2);
        } else {
            root.hide-tooltip();
        }
    }

    property <bool> explorer-hovered <=> touch-explorer.has-hover;
    property <bool> library-hovered <=> touch-library.has-hover;
    property <bool> blueprint-hovered <=> touch-blueprint.has-hover;
    property <bool> props-hovered <=> touch-props.has-hover;

    changed explorer-hovered => { root.sync-tooltip(); }
    changed library-hovered => { root.sync-tooltip(); }
    changed blueprint-hovered => { root.sync-tooltip(); }
    changed props-hovered => { root.sync-tooltip(); }

    background: Themes.current.secondary-bg;
    width: 50px;

    VerticalBox {
        padding: 0;
        spacing: 0;

        explorer-button := Rectangle {
            height: 50px;
            background: transparent;

            touch-explorer := TouchArea {
                mouse-cursor: MouseCursor.pointer;
                clicked => { root.toggle(1); }
            }

            Rectangle {
                width: 2px;
                height: 50px;
                x: 0;
                background: root.active-button == 1 ? Themes.current.active-color : transparent;
            }

            IconExplorer {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                stroke: touch-explorer.has-hover || root.active-button == 1 ? Themes.current.active-color : Themes.current.secondary-text;
            }
        }

        library-button := Rectangle {
            height: 50px;
            background: transparent;

            touch-library := TouchArea {
                mouse-cursor: MouseCursor.pointer;
                clicked => { root.toggle(2); }
            }

            Rectangle {
                x: 0;
                width: 2px;
                height: 50px;
                background: root.active-button == 2 ? Themes.current.active-color : transparent;
            }

            IconLibrary {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                fill: touch-library.has-hover || root.active-button == 2 ? Themes.current.active-color : Themes.current.secondary-text;
            }
        }

        blueprint-button := Rectangle {
            height: 50px;
            background: transparent;

            touch-blueprint := TouchArea {
                mouse-cursor: MouseCursor.pointer;
                clicked => { root.blueprint-clicked(); }
            }

            IconBlueprint {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                fill: touch-blueprint.has-hover ? Themes.current.active-color : Themes.current.secondary-text;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: transparent;
        }

        props-button := Rectangle {
            height: 50px;
            background: transparent;

            touch-props := TouchArea {
                mouse-cursor: MouseCursor.pointer;
                clicked => { root.toggle(3); }
            }

            IconProps {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                fill: touch-props.has-hover ? Themes.current.active-color : Themes.current.secondary-text;
            }
        }
    }
}
