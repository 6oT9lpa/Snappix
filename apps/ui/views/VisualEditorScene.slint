import { HorizontalBox, VerticalBox } from "std-widgets.slint";
import { Themes, Separator-V } from "../components/Themes.slint";
import { I18n } from "../components/I18n.slint";
import { Canvas } from "../editor/Canvas.slint";
import { RenameDialog } from "../dialogs/RenameDialog.slint";
import { PageTabsBar } from "../editor/PageTabs.slint";
import { Tooltip } from "../components/Tooltip.slint";
import { CanvasBounds, CanvasCommentInfo, CanvasState, DragState, EditorDocumentInfo, SelectionInfo, ProjectPageInfo, HotkeyBinding, TimelineEntry } from "../models/EditorModels.slint";
import { HistoryPreviewOverlay } from "./visual/HistoryPreviewOverlay.slint";
import { PressedKeysOverlay } from "./visual/PressedKeysOverlay.slint";
import { VisualHotSidebar } from "./visual/VisualHotSidebar.slint";
import { VisualSidebarPanel } from "./visual/VisualSidebarPanel.slint";

export component VisualEditorScene inherits Rectangle {
    background: Themes.current.primary-bg;
    forward-focus: hotkey-scope;

    in-out property <string> project-name: "";
    in-out property <[EditorDocumentInfo]> editor-documents: [];
    in-out property <int> active-document-index: 0;
    in-out property <[ProjectPageInfo]> project-page-items: [];
    in-out property <int> active-page-index: 0;
    in-out property <float> zoom-level: 1.0;

    in-out property <length> page-width: 1920px;
    in-out property <length> page-height: 1080px;

    in-out property <CanvasState> canvas-state: {
        zoom-level: 1.0,
        offset: { x: 0px, y: 0px },
        grid-visible: true,
        grid-size: 20px,
        snap-to-grid: true,
        show-rulers: true
    };
    in-out property <[SelectionInfo]> canvas-elements: [];
    in-out property <[CanvasCommentInfo]> canvas-comments: [];
    in-out property <[SelectionInfo]> outline-elements: [];
    in-out property <[TimelineEntry]> timeline-events: [];
    in-out property <int> active-timeline-index: -1;
    in-out property <bool> history-preview-active: false;
    in-out property <string> selected-element-id: "";
    in-out property <string> selected-element-name: "";
    in-out property <DragState> drag-state: DragState.None;
    in-out property <string> dragging-component-id: "";
    in-out property <string> dragging-component-name: "";
    in-out property <string> dragging-component-icon: "";

    in-out property <string> selected-element-type: "";
    in-out property <CanvasBounds> selected-element-bounds: { position: { x: 0px, y: 0px }, size: { width: 100px, height: 100px } };
    in-out property <float> selected-element-rotation: 0;
    in-out property <string> selected-element-text: "";
    in-out property <bool> selected-element-checked: false;
    in-out property <string> selected-element-container-mode: "absolute";
    in-out property <bool> selected-element-allow-absolute-children: false;
    in-out property <float> selected-element-layout-padding: 8;
    in-out property <float> selected-element-layout-padding-left: 8;
    in-out property <float> selected-element-layout-padding-right: 8;
    in-out property <float> selected-element-layout-padding-top: 8;
    in-out property <float> selected-element-layout-padding-bottom: 8;
    in-out property <float> selected-element-layout-spacing: 8;
    in-out property <float> selected-element-layout-margin: 0;
    in-out property <float> selected-element-layout-margin-left: 0;
    in-out property <float> selected-element-layout-margin-right: 0;
    in-out property <float> selected-element-layout-margin-top: 0;
    in-out property <float> selected-element-layout-margin-bottom: 0;
    in-out property <float> selected-element-layout-order: 0;
    in-out property <string> selected-element-stack-alignment: "stretch";
    in-out property <string> selected-element-flex-direction: "column";
    in-out property <string> selected-element-flex-wrap: "nowrap";
    in-out property <string> selected-element-justify-items: "stretch";
    in-out property <string> selected-element-justify-content: "flex-start";
    in-out property <string> selected-element-align-items: "stretch";
    in-out property <string> selected-element-align-content: "stretch";
    in-out property <string> selected-element-place-items: "stretch stretch";
    in-out property <string> selected-element-flex-flow: "column nowrap";
    in-out property <string> selected-element-grid-template-columns: "1fr 1fr";
    in-out property <string> selected-element-grid-template-rows: "auto auto";
    in-out property <string> selected-element-grid-template-areas: "";
    in-out property <string> selected-element-checkbox-box-side: "left";
    in-out property <string> selected-element-checkbox-check-color: "#f5f5f5";
    in-out property <string> selected-element-checkbox-box-color: "#151515";
    in-out property <string> selected-element-checkbox-box-border-color: "#4a4a4a";
    in-out property <float> selected-element-checkbox-box-border-width: 1;
    in-out property <bool> selected-element-checkbox-space-between: false;
    in-out property <string> selected-element-background: "#ffffff";
    in-out property <string> selected-element-border-color: "#4a4a4a";
    in-out property <float> selected-element-border-width: 0;
    in-out property <float> selected-element-border-radius: 6;
    in-out property <float> selected-element-font-size: 14;
    in-out property <string> selected-element-font-family: "Sans";
    in-out property <string> selected-element-text-wrap: "wrap";
    in-out property <string> selected-element-text-color: "#f5f5f5";
    in-out property <string> selected-element-placeholder: "";
    in-out property <string> selected-element-background-image: "";
    in-out property <string> selected-element-image-source: "";
    in-out property <string> selected-element-image-source-display: "";
    in-out property <float> selected-element-opacity: 1.0;
    in-out property <string> selected-element-display-mode: "visible";
    in-out property <bool> selected-element-inherit-text-style: true;
    in-out property <HotkeyBinding> select-all-hotkey: { key: "a", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> undo-hotkey: { key: "z", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> redo-hotkey: { key: "z", ctrl: false, shift: true, alt: false };
    in-out property <HotkeyBinding> cut-hotkey: { key: "x", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> copy-hotkey: { key: "c", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> paste-hotkey: { key: "v", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> paste-replace-hotkey: { key: "r", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> hide-selection-hotkey: { key: "h", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> delete-hotkey: { key: "delete", ctrl: false, shift: false, alt: false };
    in-out property <HotkeyBinding> rename-hotkey: { key: "f2", ctrl: false, shift: false, alt: true };
    in-out property <HotkeyBinding> exit-project-hotkey: { key: "q", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> create-menu-hotkey: { key: "w", ctrl: false, shift: false, alt: false };
    in-out property <HotkeyBinding> create-comment-hotkey: { key: "m", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> outline-prev-hotkey: { key: "a", ctrl: false, shift: false, alt: false };
    in-out property <HotkeyBinding> outline-next-hotkey: { key: "d", ctrl: false, shift: false, alt: false };
    in-out property <HotkeyBinding> group-hotkey: { key: "g", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> ungroup-hotkey: { key: "g", ctrl: false, shift: true, alt: false };
    in-out property <HotkeyBinding> flip-vertical-hotkey: { key: "v", ctrl: false, shift: true, alt: false };
    in-out property <HotkeyBinding> flip-horizontal-hotkey: { key: "h", ctrl: false, shift: true, alt: false };
    in-out property <HotkeyBinding> toggle-ui-hotkey: { key: "/", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> toggle-comments-hotkey: { key: "c", ctrl: false, shift: true, alt: false };
    in-out property <HotkeyBinding> reset-view-hotkey: { key: "0", ctrl: true, shift: false, alt: false };
    in-out property <HotkeyBinding> explorer-hotkey: { key: "1", ctrl: false, shift: false, alt: false };
    in-out property <HotkeyBinding> library-hotkey: { key: "2", ctrl: false, shift: false, alt: false };
    in-out property <bool> pressed-keys-enabled: true;
    in-out property <bool> pressed-keys-show-mouse-buttons: true;
    in-out property <length> sidebar-width: 320px;

    property <int> active-sidebar-button: 0;
    property <bool> hotkey-rename-dialog-open: false;
    property <string> hotkey-rename-value: "";
    property <bool> pressed-ctrl: false;
    property <bool> pressed-shift: false;
    property <bool> pressed-alt: false;
    property <string> pressed-key: "";
    property <bool> pressed-lbm: false;
    property <bool> pressed-rbm: false;
    property <bool> pressed-mbm: false;
    property <bool> sidebar-resize-active: false;
    property <bool> ui-chrome-visible: true;
    property <bool> comments-visible: true;
    property <bool> sidebar-tooltip-visible: false;
    property <string> sidebar-tooltip-text: "";
    property <length> sidebar-tooltip-anchor-y: 0px;
    property <int> sidebar-button-before-hidden: 0;
    property <length> sidebar-resize-start-pointer-x: 0px;
    property <length> sidebar-resize-start-width: 320px;
    property <length> sidebar-resize-pending-width: 320px;
    property <float> sidebar-resize-step-px: 2;

    callback new-page-requested();
    callback document-selected(int);
    callback document-closed(int);
    callback element-dropped(string, float, float, float, float, string);
    callback element-select-requested(string, bool, bool);
    callback marquee-select-requested(float, float, float, float, bool);
    callback element-updated(string, float, float, float, float, float);
    callback transform-previewed(string, float, float, float, float, float);
    callback transform-finished(string, bool, float, float, float, float, float);
    callback element-text-edited(string, string);
    callback element-style-updated(string, string, string, float, float, float, string, string, string, string, string, string, bool, bool, string, string, string, string, float, bool, float, string);
    callback element-container-settings-updated(string, string, bool, float, float, float, float, float, float, float, float, float, float, float, float, string, string, string, string, string, string, string, string, string, string, string, string);
    callback browse-image-source-requested(string);
    callback element-settings-requested(string);
    callback toggle-outline-node(string);
    callback reparent-element(string, string);
    callback rename-element(string, string);
    callback group-selected();
    callback ungroup-selected();
    callback select-all-requested();
    callback undo-requested();
    callback redo-requested();
    callback cut-requested();
    callback copy-requested();
    callback paste-requested(float, float);
    callback paste-replace-requested(float, float);
    callback hide-selection-requested();
    callback flip-vertical-requested();
    callback flip-horizontal-requested();
    callback exit-project-requested();
    callback outline-select-prev-requested();
    callback outline-select-next-requested();
    callback timeline-entry-selected(int);
    callback exit-history-preview-requested();
    callback open-project-page(int);
    callback open-active-page-blueprint-requested();
    callback open-selected-element-blueprint(string);
    callback rename-project-page(int, string);
    callback delete-element(string);
    callback delete-project-page(int);
    callback create-comment-requested(float, float);
    callback update-comment-content-requested(string, string, string);
    callback update-comment-position-requested(string, float, float);
    callback update-comment-size-requested(string, float, float);
    callback update-comment-font-sizes-requested(string, float, float);
    callback delete-comment-requested(string);
    callback paste-comment-image-requested(string);
    callback clear-comment-image-requested(string);

    function normalize-control-hotkey(text: string) -> string {
        text == "\u{1}" ? "a"
            : text == "\u{3}" ? "c"
            : text == "\u{7}" ? "g"
            : text == "\u{d}" ? "m"
            : text == "\u{12}" ? "r"
            : text == "\u{16}" ? "v"
            : text == "\u{18}" ? "x"
            : text == "\u{1a}" ? "z"
            : text;
    }

    function normalize-layout-hotkey(text: string) -> string {
        if text == "й" { "q" } else if text == "ц" { "w" } else if text == "у" { "e" } else if text == "к" { "r" } else if text == "е" { "t" } else if text == "н" { "y" } else if text == "г" { "u" } else if text == "ш" { "i" } else if text == "щ" { "o" } else if text == "з" { "p" } else if text == "х" { "[" } else if text == "ъ" { "]" } else if text == "ф" { "a" } else if text == "ы" || text == "і" { "s" } else if text == "в" { "d" } else if text == "а" { "f" } else if text == "п" { "g" } else if text == "р" { "h" } else if text == "о" { "j" } else if text == "л" { "k" } else if text == "д" { "l" } else if text == "ж" { ";" } else if text == "э" || text == "є" { "'" } else if text == "я" { "z" } else if text == "ч" { "x" } else if text == "с" { "c" } else if text == "м" { "v" } else if text == "и" { "b" } else if text == "т" { "n" } else if text == "ь" { "m" } else if text == "б" { "," } else if text == "ю" { "." } else { text }
    }

    function normalize-special-hotkey(text: string) -> string {
        text == "\u{7f}" ? "delete"
            : text == "\u{8}" ? "backspace"
            : text == "\u{f704}" ? "f1"
            : text == "\u{f705}" ? "f2"
            : text == "\u{f706}" ? "f3"
            : text == "\u{f707}" ? "f4"
            : text == "\u{f708}" ? "f5"
            : text == "\u{f709}" ? "f6"
            : text == "\u{f70a}" ? "f7"
            : text == "\u{f70b}" ? "f8"
            : text == "\u{f70c}" ? "f9"
            : text == "\u{f70d}" ? "f10"
            : text == "\u{f70e}" ? "f11"
            : text == "\u{f70f}" ? "f12"
            : text;
    }

    function normalize-hotkey-text(text: string) -> string {
        let normalized = root.normalize-layout-hotkey(
            root.normalize-control-hotkey(
                root.normalize-special-hotkey(text.to-lowercase())
            )
        );
        normalized == "?" ? "/" : normalized;
    }

    function append-combo(base: string, next: string) -> string {
        if next == "" {
            return base;
        }
        if base == "" {
            return next;
        }
        return base + "+" + next;
    }

    function display-key-name(key: string) -> string {
        if key == " " { "Space" }
        else if key == "f1" { "F1" } else if key == "f2" { "F2" } else if key == "f3" { "F3" } else if key == "f4" { "F4" } else if key == "f5" { "F5" } else if key == "f6" { "F6" } else if key == "f7" { "F7" } else if key == "f8" { "F8" } else if key == "f9" { "F9" } else if key == "f10" { "F10" } else if key == "f11" { "F11" } else if key == "f12" { "F12" }
        else if key == "escape" { "Esc" }
        else if key == "delete" { "Del" }
        else if key == "backspace" { "Backspace" }
        else if key == "enter" { "Enter" }
        else if key == "tab" { "Tab" }
        else if key == "arrowup" { "Up" }
        else if key == "arrowdown" { "Down" }
        else if key == "arrowleft" { "Left" }
        else if key == "arrowright" { "Right" }
        else if key == "a" { "A" } else if key == "b" { "B" } else if key == "c" { "C" } else if key == "d" { "D" } else if key == "e" { "E" } else if key == "f" { "F" } else if key == "g" { "G" } else if key == "h" { "H" } else if key == "i" { "I" } else if key == "j" { "J" } else if key == "k" { "K" } else if key == "l" { "L" } else if key == "m" { "M" } else if key == "n" { "N" } else if key == "o" { "O" } else if key == "p" { "P" } else if key == "q" { "Q" } else if key == "r" { "R" } else if key == "s" { "S" } else if key == "t" { "T" } else if key == "u" { "U" } else if key == "v" { "V" } else if key == "w" { "W" } else if key == "x" { "X" } else if key == "y" { "Y" } else if key == "z" { "Z" }
        else { key }
    }

    function set-modifiers(ctrl: bool, shift: bool, alt: bool) {
        root.pressed-ctrl = ctrl;
        root.pressed-shift = shift;
        root.pressed-alt = alt;
    }

    function handle-key-down(text: string, ctrl: bool, shift: bool, alt: bool) {
        root.set-modifiers(ctrl, shift, alt);
        let key = root.normalize-hotkey-text(text);
        if key != "" && key != "control" && key != "shift" && key != "alt" {
            root.pressed-key = key;
        }
    }

    function handle-key-up(text: string, ctrl: bool, shift: bool, alt: bool) {
        root.set-modifiers(ctrl, shift, alt);
        let key = root.normalize-hotkey-text(text);
        if key == root.pressed-key {
            root.pressed-key = "";
        }
    }

    function handle-pointer-button(button: string, down: bool, ctrl: bool, shift: bool, alt: bool) {
        root.set-modifiers(ctrl, shift, alt);
        if button == "LBM" {
            root.pressed-lbm = down;
        } else if button == "RBM" {
            root.pressed-rbm = down;
        } else if button == "MBM" {
            root.pressed-mbm = down;
        }
    }

    function clear-library-drag() {
        root.drag-state = DragState.None;
        root.dragging-component-id = "";
        root.dragging-component-name = "";
        root.dragging-component-icon = "";
    }

    function set-ui-visibility(visible: bool) {
        if visible == root.ui-chrome-visible {
            return;
        }
        if !visible {
            root.sidebar-button-before-hidden = root.active-sidebar-button;
            root.active-sidebar-button = 0;
            root.ui-chrome-visible = false;
            return;
        }

        root.ui-chrome-visible = true;
        if root.active-sidebar-button == 0 && root.sidebar-button-before-hidden != 0 {
            root.active-sidebar-button = root.sidebar-button-before-hidden;
        }
    }

    function set-comments-visibility(visible: bool) {
        root.comments-visible = visible;
    }

    function pressed-combo-text() -> string {
        let combo-ctrl = root.pressed-ctrl ? "Ctrl" : "";
        let combo-shift = root.pressed-shift ? root.append-combo(combo-ctrl, "Shift") : combo-ctrl;
        let combo-alt = root.pressed-alt ? root.append-combo(combo-shift, "Alt") : combo-shift;
        let combo-key = root.pressed-key != "" ? root.append-combo(combo-alt, root.display-key-name(root.pressed-key)) : combo-alt;
        let combo-lbm = root.pressed-keys-show-mouse-buttons && root.pressed-lbm ? root.append-combo(combo-key, "LBM") : combo-key;
        let combo-rbm = root.pressed-keys-show-mouse-buttons && root.pressed-rbm ? root.append-combo(combo-lbm, "RBM") : combo-lbm;
        return root.pressed-keys-show-mouse-buttons && root.pressed-mbm ? root.append-combo(combo-rbm, "MBM") : combo-rbm;
    }

    function open-hotkey-rename-dialog_for_selected() {
        if root.selected-element-id == "" {
            return;
        }
        let default-name = root.selected-element-name != ""
            ? root.selected-element-name
            : (root.selected-element-type != "" ? root.selected-element-type : "Object");
        root.hotkey-rename-value = default-name;
        root.hotkey-rename-dialog-open = true;
    }

    function close-hotkey-rename-dialog() {
        root.hotkey-rename-dialog-open = false;
    }

    function commit-hotkey-rename(new-name: string) {
        let target-id = root.selected-element-id;
        root.hotkey-rename-dialog-open = false;
        if target-id != "" && new-name != "" {
            root.rename-element(target-id, new-name);
        }
    }

    function clamp-sidebar-width(next-width: length) -> length {
        next-width < 150px ? 150px
            : next-width > 400px ? 400px
            : next-width;
    }

    function begin-sidebar-resize(pointer-x: length) {
        root.sidebar-resize-active = true;
        root.sidebar-resize-start-pointer-x = pointer-x;
        root.sidebar-resize-start-width = root.sidebar-width;
        root.sidebar-resize-pending-width = root.sidebar-width;
    }

    function update-sidebar-resize(pointer-x: length) {
        if !root.sidebar-resize-active {
            return;
        }
        let delta = pointer-x - root.sidebar-resize-start-pointer-x;
        let target-width = root.clamp-sidebar-width(root.sidebar-resize-start-width + delta);
        root.sidebar-resize-pending-width = target-width;
        if Math.abs((target-width - root.sidebar-width) / 1px) >= root.sidebar-resize-step-px {
            root.sidebar-width = target-width;
        }
    }

    function stop-sidebar-resize() {
        if root.sidebar-resize-active {
            root.sidebar-width = root.sidebar-resize-pending-width;
        }
        root.sidebar-resize-active = false;
    }

    function matches-hotkey-binding(
        text: string,
        ctrl: bool,
        shift: bool,
        alt: bool,
        binding: HotkeyBinding
    ) -> bool {
        let expected = binding.key.to-lowercase();
        let normalized = root.normalize-hotkey-text(text);
        binding.key != ""
            && ctrl == binding.ctrl
            && shift == binding.shift
            && alt == binding.alt
            && (
                normalized == expected
                || (expected == "/" && normalized == ".")
                || (expected == "." && normalized == "/")
                || (binding.ctrl && expected == "h" && normalized == "backspace")
            );
    }

    hotkey-scope := FocusScope {
        width: parent.width;
        height: parent.height;
        focus-on-click: true;
        init => { self.focus(); }

        key-pressed(event) => {
            root.handle-key-down(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt
            );
            if canvas-view.comment-editor-active {
                return reject;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.select-all-hotkey
            ) {
                root.select-all-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.undo-hotkey
            ) {
                root.undo-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.redo-hotkey
            ) {
                root.redo-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.cut-hotkey
            ) {
                root.cut-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.copy-hotkey
            ) {
                root.copy-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.paste-hotkey
            ) {
                root.paste-requested(canvas-view.cursor-canvas-x, canvas-view.cursor-canvas-y);
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.paste-replace-hotkey
            ) {
                root.paste-replace-requested(canvas-view.cursor-canvas-x, canvas-view.cursor-canvas-y);
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.hide-selection-hotkey
            ) {
                root.hide-selection-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.delete-hotkey
            ) {
                root.delete-element("");
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.rename-hotkey
            ) {
                root.open-hotkey-rename-dialog_for_selected();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.exit-project-hotkey
            ) {
                root.exit-project-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.create-menu-hotkey
            ) {
                canvas-view.open-context-menu-at-cursor();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.create-comment-hotkey
            ) {
                canvas-view.create-comment-at-cursor();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.toggle-ui-hotkey
            ) {
                root.set-ui-visibility(!root.ui-chrome-visible);
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.toggle-comments-hotkey
            ) {
                root.set-comments-visibility(!root.comments-visible);
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.reset-view-hotkey
            ) {
                canvas-view.reset-view();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.outline-prev-hotkey
            ) {
                root.outline-select-prev-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.outline-next-hotkey
            ) {
                root.outline-select-next-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.group-hotkey
            ) {
                root.group-selected();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.ungroup-hotkey
            ) {
                root.ungroup-selected();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.flip-vertical-hotkey
            ) {
                root.flip-vertical-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.flip-horizontal-hotkey
            ) {
                root.flip-horizontal-requested();
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.explorer-hotkey
            ) {
                root.ui-chrome-visible = true;
                root.active-sidebar-button = 1;
                return accept;
            }
            if root.matches-hotkey-binding(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt,
                root.library-hotkey
            ) {
                root.ui-chrome-visible = true;
                root.active-sidebar-button = 2;
                return accept;
            }
            reject
        }

        key-released(event) => {
            root.handle-key-up(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt
            );
            accept
        }
    }

    content-layout := HorizontalBox {
        padding: 0;
        spacing: 0;

        if root.ui-chrome-visible: hot-sidebar := VisualHotSidebar {
            active-button <=> root.active-sidebar-button;
            new-page-clicked => { root.new-page-requested(); }
            blueprint-clicked => { root.open-active-page-blueprint-requested(); }
            show-tooltip(text, anchor-y) => {
                root.sidebar-tooltip-text = text;
                root.sidebar-tooltip-anchor-y = anchor-y;
                root.sidebar-tooltip-visible = true;
            }
            hide-tooltip => {
                root.sidebar-tooltip-visible = false;
            }
        }

        if root.ui-chrome-visible: Separator-V {}

        if root.ui-chrome-visible && active-sidebar-button != 0: VisualSidebarPanel {
            z: 220;
            width: root.sidebar-width;
            active-content: root.active-sidebar-button;
            outline-elements: root.outline-elements;
            timeline-events: root.timeline-events;
            active-timeline-index: root.active-timeline-index;
            project-page-items: root.project-page-items;
            active-project-page-index: root.active-page-index;
            selected-element-id: root.selected-element-id;
            project-name: root.project-name;
            selected-element-type: root.selected-element-type;
            selected-element-bounds: root.selected-element-bounds;
            selected-element-rotation: root.selected-element-rotation;
            selected-element-text: root.selected-element-text;
            selected-element-checked: root.selected-element-checked;
            selected-element-container-mode: root.selected-element-container-mode;
            selected-element-allow-absolute-children: root.selected-element-allow-absolute-children;
            selected-element-layout-padding: root.selected-element-layout-padding;
            selected-element-layout-padding-left: root.selected-element-layout-padding-left;
            selected-element-layout-padding-right: root.selected-element-layout-padding-right;
            selected-element-layout-padding-top: root.selected-element-layout-padding-top;
            selected-element-layout-padding-bottom: root.selected-element-layout-padding-bottom;
            selected-element-layout-spacing: root.selected-element-layout-spacing;
            selected-element-layout-margin: root.selected-element-layout-margin;
            selected-element-layout-margin-left: root.selected-element-layout-margin-left;
            selected-element-layout-margin-right: root.selected-element-layout-margin-right;
            selected-element-layout-margin-top: root.selected-element-layout-margin-top;
            selected-element-layout-margin-bottom: root.selected-element-layout-margin-bottom;
            selected-element-layout-order: root.selected-element-layout-order;
            selected-element-stack-alignment: root.selected-element-stack-alignment;
            selected-element-flex-direction: root.selected-element-flex-direction;
            selected-element-flex-wrap: root.selected-element-flex-wrap;
            selected-element-justify-items: root.selected-element-justify-items;
            selected-element-justify-content: root.selected-element-justify-content;
            selected-element-align-items: root.selected-element-align-items;
            selected-element-align-content: root.selected-element-align-content;
            selected-element-place-items: root.selected-element-place-items;
            selected-element-flex-flow: root.selected-element-flex-flow;
            selected-element-grid-template-columns: root.selected-element-grid-template-columns;
            selected-element-grid-template-rows: root.selected-element-grid-template-rows;
            selected-element-grid-template-areas: root.selected-element-grid-template-areas;
            selected-element-checkbox-box-side: root.selected-element-checkbox-box-side;
            selected-element-checkbox-check-color: root.selected-element-checkbox-check-color;
            selected-element-checkbox-box-color: root.selected-element-checkbox-box-color;
            selected-element-checkbox-box-border-color: root.selected-element-checkbox-box-border-color;
            selected-element-checkbox-box-border-width: root.selected-element-checkbox-box-border-width;
            selected-element-checkbox-space-between: root.selected-element-checkbox-space-between;
            selected-element-background: root.selected-element-background;
            selected-element-border-color: root.selected-element-border-color;
            selected-element-border-width: root.selected-element-border-width;
            selected-element-border-radius: root.selected-element-border-radius;
            selected-element-font-size: root.selected-element-font-size;
            selected-element-font-family: root.selected-element-font-family;
            selected-element-text-wrap: root.selected-element-text-wrap;
            selected-element-text-color: root.selected-element-text-color;
            selected-element-placeholder: root.selected-element-placeholder;
            selected-element-background-image: root.selected-element-background-image;
            selected-element-image-source: root.selected-element-image-source;
            selected-element-image-source-display: root.selected-element-image-source-display;
            selected-element-opacity: root.selected-element-opacity;
            selected-element-display-mode: root.selected-element-display-mode;
            selected-element-inherit-text-style: root.selected-element-inherit-text-style;
            dragging-component-id <=> root.dragging-component-id;
            dragging-component-name <=> root.dragging-component-name;
            dragging-component-icon <=> root.dragging-component-icon;
            drag-state <=> root.drag-state;

            element-select-requested(id, additive, deep-select) => {
                hotkey-scope.focus();
                root.element-select-requested(id, additive, deep-select);
            }
            element-updated(id, x, y, w, h, r) => { root.element-updated(id, x, y, w, h, r); }
            element-text-edited(id, text) => { root.element-text-edited(id, text); }
            element-style-updated(id, bg, border, bw, br, fs, tc, ff, tw, ph, bg_image, image_src, inherit_text_style, checked, checkbox_box_side, checkbox_check_color, checkbox_box_color, checkbox_box_border_color, checkbox_box_border_width, checkbox_space_between, opacity, display_mode) => {
                root.element-style-updated(
                    id,
                    bg,
                    border,
                    bw,
                    br,
                    fs,
                    tc,
                    ff,
                    tw,
                    ph,
                    bg_image,
                    image_src,
                    inherit_text_style,
                    checked,
                    checkbox_box_side,
                    checkbox_check_color,
                    checkbox_box_color,
                    checkbox_box_border_color,
                    checkbox_box_border_width,
                    checkbox_space_between,
                    opacity,
                    display_mode
                );
            }
            element-container-settings-updated(id, container_mode, allow_absolute_children, layout_padding, layout_padding_left, layout_padding_right, layout_padding_top, layout_padding_bottom, layout_spacing, layout_margin, layout_margin_left, layout_margin_right, layout_margin_top, layout_margin_bottom, layout_order, stack_alignment, flex_direction, flex_wrap, justify_items, justify_content, align_items, align_content, place_items, flex_flow, grid_template_columns, grid_template_rows, grid_template_areas) => {
                root.element-container-settings-updated(
                    id,
                    container_mode,
                    allow_absolute_children,
                    layout_padding,
                    layout_padding_left,
                    layout_padding_right,
                    layout_padding_top,
                    layout_padding_bottom,
                    layout_spacing,
                    layout_margin,
                    layout_margin_left,
                    layout_margin_right,
                    layout_margin_top,
                    layout_margin_bottom,
                    layout_order,
                    stack_alignment,
                    flex_direction,
                    flex_wrap,
                    justify_items,
                    justify_content,
                    align_items,
                    align_content,
                    place_items,
                    flex_flow,
                    grid_template_columns,
                    grid_template_rows,
                    grid_template_areas
                );
            }
            browse-image-source-requested(id) => { root.browse-image-source-requested(id); }
            toggle-outline-node(id) => { root.toggle-outline-node(id); }
            reparent-element(child-id, parent-id) => { root.reparent-element(child-id, parent-id); }
            rename-element(id, new-name) => { root.rename-element(id, new-name); }
            cut-requested => { root.cut-requested(); }
            copy-requested => { root.copy-requested(); }
            open-project-page(page-index) => { root.open-project-page(page-index); }
            rename-project-page(page-index, page-name) => { root.rename-project-page(page-index, page-name); }
            delete-element(id) => { root.delete-element(id); }
            delete-project-page(page-index) => { root.delete-project-page(page-index); }
            timeline-entry-selected(index) => { root.timeline-entry-selected(index); }
        }

        if root.ui-chrome-visible && active-sidebar-button != 0: sidebar-resize-handle := Rectangle {
            width: 8px;
            background: transparent;
            z: 230;


            resize-touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: MouseCursor.col-resize;

                pointer-event(ev) => {
                    if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                        root.begin-sidebar-resize(sidebar-resize-handle.x + self.mouse-x);
                    }
                    if ev.kind == PointerEventKind.move {
                        root.update-sidebar-resize(sidebar-resize-handle.x + self.mouse-x);
                    }
                    if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                        root.stop-sidebar-resize();
                    }
                    if ev.kind == PointerEventKind.cancel {
                        root.stop-sidebar-resize();
                    }
                }
            }
        }

        canvas-column := VerticalBox {
            padding: 0;
            horizontal-stretch: 1;
            spacing: 0;

            if root.ui-chrome-visible: PageTabsBar {
                documents: root.editor-documents;
                active-document-index: root.active-document-index;
                show-new-button: true;
                document-selected(idx) => { root.document-selected(idx); }
                document-closed(idx) => { root.document-closed(idx); }
                new-page-requested => { root.new-page-requested(); }
            }

            canvas-view := Canvas {
                state: { zoom-level: root.zoom-level, offset: { x: 0px, y: 0px }, grid-visible: true, grid-size: 20px, snap-to-grid: true, show-rulers: true };
                elements: root.canvas-elements;
                comments: root.canvas-comments;
                drag-state: root.drag-state;
                selected-element-id: root.selected-element-id;
                dragging-component-id: root.dragging-component-id;
                dragging-component-name: root.dragging-component-name;
                dragging-component-icon: root.dragging-component-icon;
                page-width: root.page-width;
                page-height: root.page-height;
                ui-helpers-visible: root.ui-chrome-visible;
                comments-visible: root.comments-visible;

                element-select-requested(id, additive, deep-select) => {
                    root.element-select-requested(id, additive, deep-select);
                }
                marquee-select-requested(x1, y1, x2, y2, additive) => {
                    hotkey-scope.focus();
                    root.exit-history-preview-requested();
                    root.marquee-select-requested(x1, y1, x2, y2, additive);
                }
                transform-previewed(id, x, y, w, h, r) => {
                    root.transform-previewed(id, x, y, w, h, r);
                }
                transform-finished(id, commit, x, y, w, h, r) => {
                    root.transform-finished(id, commit, x, y, w, h, r);
                }

                element-dropped(component-id, x, y, width, height, parent-id) => {
                    root.clear-library-drag();
                    root.element-dropped(component-id, x, y, width, height, parent-id);
                }
                drag-cancelled() => {
                    root.clear-library-drag();
                }

                element-text-edited(id, text) => { root.element-text-edited(id, text); }

                canvas-clicked(_x, _y) => {
                    hotkey-scope.focus();
                    root.exit-history-preview-requested();
                    root.element-select-requested("", false, true);
                }

                zoom-changed(zoom) => { root.zoom-level = zoom; }
                element-settings-requested(id) => {
                    root.ui-chrome-visible = true;
                    root.active-sidebar-button = 3;
                    root.element-settings-requested(id);
                }
                go-to-blueprint-requested(id) => {
                    root.open-selected-element-blueprint(id);
                }
                pointer-button-state-changed(button, down, ctrl, shift, alt) => {
                    root.handle-pointer-button(button, down, ctrl, shift, alt);
                }
                copy-requested => { root.copy-requested(); }
                paste-requested(x, y) => { root.paste-requested(x, y); }
                paste-replace-requested(x, y) => { root.paste-replace-requested(x, y); }
                group-requested => { root.group-selected(); }
                ungroup-requested => { root.ungroup-selected(); }
                flip-vertical-requested => { root.flip-vertical-requested(); }
                flip-horizontal-requested => { root.flip-horizontal-requested(); }
                set-ui-visibility-requested(visible) => { root.set-ui-visibility(visible); }
                set-comments-visibility-requested(visible) => { root.set-comments-visibility(visible); }
                create-comment-requested(x, y) => { root.create-comment-requested(x, y); }
                update-comment-content-requested(comment-id, title, body) => {
                    root.update-comment-content-requested(comment-id, title, body);
                }
                update-comment-position-requested(comment-id, x, y) => {
                    root.update-comment-position-requested(comment-id, x, y);
                }
                update-comment-size-requested(comment-id, width, body-height) => {
                    root.update-comment-size-requested(comment-id, width, body-height);
                }
                update-comment-font-sizes-requested(comment-id, title-size, body-size) => {
                    root.update-comment-font-sizes-requested(comment-id, title-size, body-size);
                }
                delete-comment-requested(comment-id) => { root.delete-comment-requested(comment-id); }
                paste-comment-image-requested(comment-id) => {
                    root.paste-comment-image-requested(comment-id);
                }
                clear-comment-image-requested(comment-id) => {
                    root.clear-comment-image-requested(comment-id);
                }
            }
        }
    }

    if root.drag-state == DragState.Dragging: Rectangle {
        z: 2250;
        x: 0;
        y: 0;
        width: content-layout.x + canvas-column.x + canvas-view.x;
        height: root.height;
        background: transparent;

        TouchArea {
            mouse-cursor: MouseCursor.copy;
            pointer-event(ev) => {
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.clear-library-drag();
                }
                if ev.kind == PointerEventKind.cancel {
                    root.clear-library-drag();
                }
            }
        }
    }

    if root.drag-state == DragState.Dragging: Rectangle {
        z: 2250;
        x: content-layout.x + canvas-column.x + canvas-view.x;
        y: 0;
        width: canvas-view.width;
        height: content-layout.y + canvas-column.y + canvas-view.y;
        background: transparent;

        TouchArea {
            mouse-cursor: MouseCursor.copy;
            pointer-event(ev) => {
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.clear-library-drag();
                }
                if ev.kind == PointerEventKind.cancel {
                    root.clear-library-drag();
                }
            }
        }
    }

    if root.drag-state == DragState.Dragging: Rectangle {
        z: 2250;
        x: content-layout.x + canvas-column.x + canvas-view.x + canvas-view.width;
        y: 0;
        width: root.width - self.x;
        height: root.height;
        background: transparent;

        TouchArea {
            mouse-cursor: MouseCursor.copy;
            pointer-event(ev) => {
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.clear-library-drag();
                }
                if ev.kind == PointerEventKind.cancel {
                    root.clear-library-drag();
                }
            }
        }
    }

    if root.drag-state == DragState.Dragging: Rectangle {
        z: 2250;
        x: content-layout.x + canvas-column.x + canvas-view.x;
        y: content-layout.y + canvas-column.y + canvas-view.y + canvas-view.height;
        width: canvas-view.width;
        height: root.height - self.y;
        background: transparent;

        TouchArea {
            mouse-cursor: MouseCursor.copy;
            pointer-event(ev) => {
                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                    root.clear-library-drag();
                }
                if ev.kind == PointerEventKind.cancel {
                    root.clear-library-drag();
                }
            }
        }
    }

    if root.ui-chrome-visible && root.sidebar-resize-active: TouchArea {
        z: 2300;
        width: parent.width;
        height: parent.height;
        mouse-cursor: MouseCursor.col-resize;

        pointer-event(ev) => {
            if ev.kind == PointerEventKind.move {
                root.update-sidebar-resize(self.mouse-x);
            }
            if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                root.stop-sidebar-resize();
            }
            if ev.kind == PointerEventKind.cancel {
                root.stop-sidebar-resize();
            }
        }
    }

    RenameDialog {
        z: 320;
        width: parent.width;
        height: parent.height;
        show-dialog: root.hotkey-rename-dialog-open;
        dialog-title: I18n.t("Rename element");
        confirm-label: I18n.t("Rename");
        input-text <=> root.hotkey-rename-value;
        cancelled => { root.close-hotkey-rename-dialog(); }
        confirmed(new-name) => { root.commit-hotkey-rename(new-name); }
    }

    if root.ui-chrome-visible && root.sidebar-tooltip-visible: Tooltip {
        z: 2600;
        x: content-layout.x + 62px;
        y: Math.max(
            8px,
            Math.min(
                root.height - self.height - 8px,
                content-layout.y + root.sidebar-tooltip-anchor-y - self.height / 2
            )
        );
        text: root.sidebar-tooltip-text;
        placement: "left";
        show: true;
    }

    if root.pressed-keys-enabled && root.pressed-combo-text() != "": PressedKeysOverlay {
        z: 2001;
        x: parent.width - self.width - 16px;
        y: parent.height - self.height - 16px;
        combo-text: root.pressed-combo-text();
    }

    if root.history-preview-active: HistoryPreviewOverlay {
        z: 2000;
        x: parent.width - self.width - 16px;
        y: root.pressed-keys-enabled && root.pressed-combo-text() != ""
            ? parent.height - self.height - 52px
            : parent.height - self.height - 16px;
    }
}
